\uc0\u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473  [\u52309 \u53552 4] \u51312 \u50668 \u50724 \u45716  \u50732 \u44032 \u48120  \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \
\uc0\u44536 \u45216  \u48164  \u48124 \u51456 \u51008  \u51104 \u51012  \u51088 \u51648  \u50506 \u50520 \u49845 \u45768 \u45796 . \u51221 \u54869 \u55176 \u45716  \u51088 \u47140 \u44256  \u54664 \u51648 \u47564  \u51104 \u51060  \u50724 \u51648  \u50506 \u50520 \u49845 \u45768 \u45796 . \u52840 \u45824 \u50640  \u45572 \u50912 \u45796 \u44032 , \u45796 \u49884  \u51068 \u50612 \u45208  \u44144 \u49892 \u47196  \u45208 \u50772 \u49845 \u45768 \u45796 . \u45257 \u51109 \u44256 \u50640 \u49436  \u47589 \u51452 \u47484  \u44732 \u45236  \u53441 \u51088  \u50948 \u50640  \u45459 \u50520 \u49845 \u45768 \u45796 . \u47560 \u49884 \u47140 \u44256  \u44732 \u45240  \u44163 \u51060  \u50500 \u45768 \u50632 \u49845 \u45768 \u45796 . \u44536 \u45285  \u47956 \u44032  \u49552  \u50504 \u50640  \u51536 \u44256  \u51080 \u44256  \u49910 \u50632 \u49845 \u45768 \u45796 . \u52884 \u51012  \u49552 \u48148 \u45797  \u50504 \u50640 \u49436  \u46028 \u47532 \u45796 \u44032  \u45236 \u47140 \u45459 \u45796 \u44032 , \u48124 \u51456 \u51008  \u52380 \u51109 \u51012  \u50732 \u47140 \u45796 \u48372 \u50520 \u49845 \u45768 \u45796 . \u51312 \u50857 \u54620  \u49352 \u48317  \u44144 \u49892 \u50640  \u45257 \u51109 \u44256  \u46028 \u50500 \u44032 \u45716  \u49548 \u47532 \u47564  \u45230 \u44172  \u44628 \u47160 \u49845 \u45768 \u45796 .\
7\uc0\u45380  \u51204 \u51060  \u46496 \u50732 \u46992 \u49845 \u45768 \u45796 .\
\uc0\u49436 \u50980 \u51060  \u51664 \u51012  \u49912 \u45912  \u45216 \u51060 \u50632 \u49845 \u45768 \u45796 . \u52840 \u49892 \u50640 \u49436  \u44032 \u48169 \u51012  \u44732 \u45236  \u50743 \u44032 \u51648 \u47484  \u45347 \u45716  \u49548 \u47532 \u44032  \u46308 \u47160 \u49845 \u45768 \u45796 . \u48124 \u51456 \u51008  \u44536  \u49548 \u47532 \u47484  \u46308 \u51004 \u47732 \u49436  \u44144 \u49892  \u49548 \u54028 \u50640  \u50505 \u50500  \u51080 \u50632 \u49845 \u45768 \u45796 . \u46308 \u50612 \u44032 \u51648  \u50506 \u50520 \u49845 \u45768 \u45796 . \u46308 \u50612 \u44032 \u49436  \u47924 \u49832  \u47568 \u51012  \u54644 \u50556  \u54624 \u51648  \u47792 \u46992 \u49845 \u45768 \u45796 . \u51613 \u44144 \u44032  \u51080 \u50632 \u44256 , \u50612 \u47672 \u45768 \u44032  \u44208 \u47200 \u51012  \u45236 \u47160 \u44256 , \u48320 \u54840 \u49324 \u44620 \u51648  \u49440 \u51076 \u46108  \u49345 \u53468 \u50688 \u49845 \u45768 \u45796 . \u48124 \u51456 \u51008  \u44536 \u51200  \u44536  \u55120 \u47492  \u50504 \u50640  \u51080 \u50632 \u49845 \u45768 \u45796 . \u50612 \u46360 \u44032 \u50640 \u49436  \u51096 \u47803 \u46096 \u45796 \u45716  \u45712 \u45196 \u51060  \u50630 \u50632 \u45912  \u44163 \u51008  \u50500 \u45768 \u50632 \u49845 \u45768 \u45796 . \u45796 \u47564  \u44536  \u45712 \u45196 \u51012  \u44732 \u45244  \u51088 \u47532 \u44032  \u50630 \u50632 \u49845 \u45768 \u45796 . \u51096 \u47803 \u46108  \u44163 \u51060  \u51080 \u45796 \u47732  \u49436 \u50980 \u51060  \u51649 \u51217  \u47568 \u54664 \u50612 \u50556  \u54664 \u49845 \u45768 \u45796 . \u44536 \u47088 \u45936  \u49436 \u50980 \u51008  \u47568 \u54616 \u51648  \u50506 \u50520 \u49845 \u45768 \u45796 .\
\uc0\u49436 \u50980 \u51060  \u44032 \u48169 \u51012  \u46308 \u44256  \u54788 \u44288 \u50640  \u49456 \u51012  \u46412 , \u48124 \u51456 \u51008  \u49548 \u54028 \u50640 \u49436  \u51068 \u50612 \u45208 \u51648  \u50506 \u50520 \u49845 \u45768 \u45796 . \u49436 \u50980 \u51060  \u49888 \u48156 \u51012  \u49888 \u45716  \u49548 \u47532 \u44032  \u45228 \u49845 \u45768 \u45796 . \u44536 \u47532 \u44256  \u47928 \u51060  \u50676 \u47160 \u49845 \u45768 \u45796 . \u45803 \u54804 \u49845 \u45768 \u45796 . \u44536 \u44172  \u51204 \u48512 \u50688 \u49845 \u45768 \u45796 . \u49436 \u50980 \u51008  \u45149 \u44620 \u51648  \u50500 \u47924  \u47568 \u46020  \u54616 \u51648  \u50506 \u50520 \u49845 \u45768 \u45796 . \u50613 \u50872 \u54616 \u45796 \u44256  \u54616 \u51648  \u50506 \u50520 \u44256 , \u54644 \u47749 \u54616 \u51648  \u50506 \u50520 \u44256 , \u50872 \u51648 \u46020  \u50506 \u50520 \u49845 \u45768 \u45796 . \u44536  \u52840 \u47925 \u51060  \u44536 \u46412  \u48124 \u51456 \u50640 \u44172 \u45716  \u51064 \u51221 \u52376 \u47100  \u48372 \u50688 \u49845 \u45768 \u45796 . \u51648 \u44552 \u51008  \u45804 \u46992 \u49845 \u45768 \u45796 .\
"\uc0\u54841 \u49884  \u45236 \u44032  \u45459 \u52828  \u44172  \u51080 \u50632 \u45208 ."\
\uc0\u51473 \u50620 \u44144 \u47536  \u47568 \u51060  \u44144 \u49892  \u50504 \u50640  \u51312 \u50857 \u55176  \u54140 \u51276 \u49845 \u45768 \u45796 . \u47589 \u51452  \u52884 \u51008  \u44536 \u45824 \u47196  \u53441 \u51088  \u50948 \u50640  \u45459 \u50668  \u51080 \u50632 \u44256 , \u49352 \u48317  \u46160 \u49884 \u51032  \u44144 \u49892 \u51008  \u44256 \u50836 \u54664 \u49845 \u45768 \u45796 . \u51076 \u49888 \u51060 \u46972 \u45716  \u47568 . \u49436 \u50980 \u51008  \u54620  \u48264 \u46020  \u54616 \u51648  \u50506 \u50520 \u49845 \u45768 \u45796 . \u50500 \u51060 \u46972 \u45716  \u47568 \u46020  \u50630 \u50632 \u49845 \u45768 \u45796 . \u50612 \u47672 \u45768  \u47568 \u47196 \u45716  \u44536  \u50500 \u51060 \u44032  \u51068 \u44273  \u49332 \u51060 \u46972 \u44256  \u54664 \u49845 \u45768 \u45796 . 7\u45380  \u51204 \u51060 \u47732 . \u49436 \u50980 \u51060  \u51665 \u51012  \u45208 \u44032 \u45912  \u48148 \u47196  \u44536 \u51592 \u51020 \u51060 \u47732 . \u48124 \u51456 \u51008  \u49552 \u51004 \u47196  \u50620 \u44404 \u51012  \u44048 \u49932 \u49845 \u45768 \u45796 . \u44228 \u49328 \u51060  \u45320 \u47924  \u49440 \u47749 \u54616 \u44172  \u47582 \u50500 \u46504 \u50612 \u51276 \u49845 \u45768 \u45796 . \u44536  \u49440 \u47749 \u54632 \u51060  \u50724 \u55176 \u47140  \u45908  \u47924 \u44144 \u50912 \u49845 \u45768 \u45796 .\
\uc0\u47728 \u52832  \u46244 , \u51221 \u55148 \u45716  \u49688 \u51652 \u51012  \u45796 \u49884  \u48520 \u47104 \u49845 \u45768 \u45796 . \u51060 \u48264 \u50640 \u45716  \u45824 \u54364 \u49892 \u51060  \u50500 \u45772  \u54924 \u49324  \u50808 \u48512 \u51032  \u51312 \u50857 \u54620  \u52852 \u54168 \u50688 \u49845 \u45768 \u45796 . \u46160  \u49324 \u46988 \u51060  \u47560 \u51452  \u50505 \u51008  \u53580 \u51060 \u48660  \u50948 \u50640  \u52964 \u54588  \u46160  \u51092 \u51060  \u45459 \u50688 \u44256 , \u51221 \u55148 \u45716  \u52981 \u51012  \u49552 \u51004 \u47196  \u44048 \u49912 \u51540  \u52292  \u52380 \u52380 \u55176  \u51077 \u51012  \u50676 \u50632 \u49845 \u45768 \u45796 .\
"\uc0\u50500 \u51060  \u52636 \u49373  \u44592 \u47197 , \u51221 \u54869 \u55176  \u54869 \u51064 \u54664 \u50612 \u50836 ?"\
\uc0\u49688 \u51652 \u51008  \u44256 \u44060 \u47484  \u45124 \u45909 \u50688 \u49845 \u45768 \u45796 . \u54364 \u51221 \u51008  \u50668 \u51204 \u55176  \u52264 \u48516 \u54664 \u49845 \u45768 \u45796 .\
"\uc0\u45348 . \u52636 \u49373  \u49888 \u44256  \u44592 \u51456 \u51004 \u47196  \u51648 \u44552  \u47564  7\u49332 \u51077 \u45768 \u45796 . \u49436 \u50980 \u50472 \u44032  \u51060 \u54844  \u54980  \u54844 \u51088  \u45235 \u51008  \u44152 \u47196  \u46104 \u50612  \u51080 \u44256 \u50836 . \u50500 \u48260 \u51648  \u46976 \u51008  \u44277 \u46976 \u51077 \u45768 \u45796 ."\
\uc0\u51221 \u55148 \u45716  \u52964 \u54588 \u47484  \u54620  \u47784 \u44552  \u47560 \u49884 \u51648  \u50506 \u44256  \u53441 \u51088  \u50948 \u50640  \u45236 \u47140 \u45459 \u50520 \u49845 \u45768 \u45796 .\
"\uc0\u44277 \u46976 ."\
\uc0\u51687 \u44172  \u46104 \u45516 \u50632 \u49845 \u45768 \u45796 . \u49688 \u51652 \u51008  \u49884 \u49440 \u51012  \u51104 \u44624  \u45236 \u47160 \u45796 \u44032  \u45796 \u49884  \u51221 \u55148 \u47484  \u48372 \u50520 \u49845 \u45768 \u45796 . \u51221 \u55148 \u51032  \u45576 \u51060  \u47956 \u44032 \u47484  \u49373 \u44033 \u54616 \u44256  \u51080 \u50632 \u49845 \u45768 \u45796 . \u49688 \u51652 \u51008  \u44536  \u45576 \u51060  \u51088 \u49888 \u51012  \u54693 \u54616 \u44256  \u51080 \u45716  \u44148 \u51648 , \u50500 \u45768 \u47732  \u44536  \u45320 \u47672  \u50612 \u46360 \u44032 \u47484  \u54693 \u54616 \u44256  \u51080 \u45716  \u44148 \u51648  \u50508  \u49688  \u50630 \u50612 \u49436  \u45908  \u44596 \u51109 \u54664 \u49845 \u45768 \u45796 .\
"\uc0\u44536  \u44032 \u44172  \u51452 \u48320 , CCTV \u50948 \u52824 \u46993  \u52852 \u46300  \u49324 \u50857  \u45236 \u50669 \u46020  \u54869 \u51064 \u54644 \u48400 \u50836 . \u49436 \u50980 \u50472 \u44032  \u50612 \u46356 \u49436  \u47960  \u54616 \u44256  \u45796 \u45768 \u45716 \u51648  \u51328  \u45908  \u54028 \u50501 \u54644 \u50556 \u44192 \u50612 \u50836 ."\
\uc0\u49688 \u51652 \u51008  \u51104 \u49884  \u47672 \u47943 \u44144 \u47160 \u49845 \u45768 \u45796 . \u44536  \u47672 \u47943 \u44144 \u47548 \u51060  \u50892 \u45209  \u51687 \u50500 \u49436  \u51221 \u55148 \u44032  \u50508 \u50500 \u52264 \u47160 \u45716 \u51648 \u45716  \u47784 \u47484  \u51068 \u51060 \u50632 \u49845 \u45768 \u45796 .\
"\uc0\u50508 \u44192 \u49845 \u45768 \u45796 ."\
\uc0\u52852 \u54168 \u47484  \u45208 \u50728  \u46244  \u49688 \u51652 \u51008  \u52264 \u50640  \u50724 \u47476 \u51648  \u50506 \u44256  \u51104 \u49884  \u44148 \u47932  \u48317 \u50640  \u46321 \u51012  \u44592 \u45844 \u49845 \u45768 \u45796 . \u45824 \u54364 \u45784 \u51060  \u51060  \u51221 \u46020 \u44620 \u51648  \u54028 \u44256 \u46308 \u44592  \u49884 \u51089 \u54616 \u47732  \u47688 \u52628 \u51648  \u50506 \u51012  \u44163 \u51060 \u50632 \u49845 \u45768 \u45796 . CCTV, \u52852 \u46300  \u45236 \u50669 , \u52636 \u49373  \u44592 \u47197 . \u54616 \u45208 \u50473  \u44732 \u45236 \u45796  \u48372 \u47732  \u44208 \u44397  \u45908  \u44618 \u51008  \u44275 \u44620 \u51648  \u46308 \u50612 \u50724 \u44172  \u46121 \u45768 \u45796 . \u44536 \u46412 \u45716  \u51648 \u44552 \u48372 \u45796  \u55016 \u50476  \u50948 \u54744 \u54664 \u49845 \u45768 \u45796 . \u49688 \u51652 \u51008  \u54648 \u46300 \u54256 \u51012  \u44732 \u45256 \u49845 \u45768 \u45796 . \u54924 \u49324  \u51204 \u49328  \u45812 \u45817 \u51088 \u50640 \u44172  \u47928 \u51088 \u47484  \u48372 \u45256 \u49845 \u45768 \u45796 . \u50724 \u45720  \u50724 \u54980 \u50640  \u51104 \u44624  \u48380  \u49688  \u51080 \u45264 \u44256 . \u51060 \u50976 \u45716  \u51201 \u51648  \u50506 \u50520 \u49845 \u45768 \u45796 .\
\uc0\u44536 \u45216  \u50724 \u54980  \u49688 \u51652 \u51008  \u54924 \u49324  \u51204 \u49328 \u49892 \u50640  \u45236 \u47140 \u44052 \u49845 \u45768 \u45796 . \u45812 \u45817 \u51088 \u45716  \u51210 \u51008  \u51649 \u50896 \u51060 \u50632 \u44256 , \u49688 \u51652 \u51060  \u50836 \u52397 \u54616 \u47732  \u44400 \u47568  \u50630 \u51060  \u46384 \u46972 \u51452 \u45716  \u54200 \u51060 \u50632 \u49845 \u45768 \u45796 . \u49688 \u51652 \u51008  7\u45380  \u51204  \u44208 \u51116  \u47928 \u49436  \u51473  \u51068 \u48512 \u47484  \u50756 \u51204 \u55176  \u45934 \u50612 \u50416 \u45716  \u51089 \u50629 \u51012  \u50836 \u52397 \u54664 \u49845 \u45768 \u45796 . \u51060 \u50976 \u45716  \u44060 \u51064 \u51221 \u48372  \u48372 \u54840  \u52264 \u50896 \u51032  \u51221 \u44592  \u49325 \u51228 \u46972 \u44256  \u54664 \u49845 \u45768 \u45796 . \u45812 \u45817 \u51088 \u45716  \u51104 \u44624  \u54868 \u47732 \u51012  \u48372 \u45796 \u44032  \u44256 \u44060 \u47484  \u45124 \u45909 \u50688 \u49845 \u45768 \u45796 . \u49688 \u51652 \u51008  \u44536  \u51089 \u50629 \u51060  \u45149 \u45208 \u45716  \u46041 \u50504  \u50694 \u50640 \u49436  \u54868 \u47732 \u51012  \u51648 \u53020 \u48372 \u50520 \u49845 \u45768 \u45796 . \u54868 \u47732  \u50504 \u50640 \u49436  \u54028 \u51068 \u46308 \u51060  \u54616 \u45208 \u50473  \u49324 \u46972 \u51276 \u49845 \u45768 \u45796 . \u49324 \u46972 \u51656  \u46412 \u47560 \u45796  \u44032 \u49844  \u54620 \u53024 \u51060  \u44032 \u48316 \u50892 \u51648 \u45716  \u44172  \u50500 \u45768 \u46972 , \u50724 \u55176 \u47140  \u45908  \u47924 \u44144 \u50892 \u51648 \u45716  \u44163  \u44057 \u50520 \u49845 \u45768 \u45796 .\
\uc0\u49688 \u51652 \u51008  \u51089 \u50629 \u51060  \u45149 \u45208 \u45716  \u44163 \u51012  \u54869 \u51064 \u54616 \u44256  \u51204 \u49328 \u49892 \u51012  \u45208 \u50772 \u49845 \u45768 \u45796 . \u48373 \u46020 \u47484  \u44152 \u50612 \u44032 \u47732 \u49436  \u46160  \u49552 \u51012  \u51116 \u53431  \u51452 \u47672 \u45768  \u44618 \u49689 \u51060  \u45347 \u50632 \u49845 \u45768 \u45796 . \u49552 \u51060  \u52264 \u44032 \u50912 \u49845 \u45768 \u45796 . \u51312 \u44552 \u50473  \u45908  \u44618 \u51060  \u46308 \u50612 \u44032 \u44256  \u51080 \u50632 \u49845 \u45768 \u45796 . \u52376 \u51020 \u50640 \u45716  \u44536 \u45285  \u54616 \u45208 \u51032  \u44144 \u51667 \u47568 \u51060 \u50632 \u49845 \u45768 \u45796 . \u44536 \u45796 \u51020 \u51008  \u44536  \u44144 \u51667 \u47568 \u51012  \u51648 \u53412 \u44592  \u50948 \u54620  \u49436 \u47448 \u50688 \u44256 , \u51648 \u44552 \u51008  \u44536  \u49436 \u47448 \u47484  \u51648 \u50864 \u44592  \u50948 \u54620  \u51089 \u50629 \u51060 \u50632 \u49845 \u45768 \u45796 . \u50620 \u47560 \u45208  \u45908  \u44618 \u50612 \u51256 \u50556  \u45149 \u51060  \u45208 \u45716 \u51648  \u49688 \u51652 \u51008  \u50508  \u49688  \u50630 \u50632 \u49845 \u45768 \u45796 .\
\uc0\u44536  \u47924 \u47157  \u49436 \u50980 \u51008  \u50500 \u46308 \u51012  \u54617 \u44368 \u50640  \u48372 \u45236 \u44256  \u51109 \u51012  \u48372 \u47084  \u45208 \u50772 \u49845 \u45768 \u45796 . \u49884 \u51109  \u46244 \u54200  \u51089 \u51008  \u47560 \u53944 \u50640 \u49436  \u45796 \u51020  \u45216  \u48152 \u52268  \u51116 \u47308 \u47484  \u44256 \u47476 \u45716  \u51473 \u51060 \u50632 \u49845 \u45768 \u45796 . \u46160 \u48512  \u54620  \u47784 , \u49884 \u44552 \u52824  \u54620  \u45800 , \u45804 \u44096  \u54620  \u54032 . \u51109 \u48148 \u44396 \u45768 \u50640  \u54616 \u45208 \u50473  \u45812 \u51004 \u47732 \u49436  \u49436 \u50980 \u51008  \u47672 \u47551 \u49549 \u51004 \u47196  \u45236 \u51068  \u44032 \u44172  \u47700 \u45684 \u47484  \u51221 \u47532 \u54664 \u49845 \u45768 \u45796 . \u51221 \u55148 \u47484  \u49884 \u51109 \u50640 \u49436  \u47560 \u51452 \u52828  \u51060 \u54980 \u47196  \u47560 \u51020 \u51060  \u54200 \u54616 \u51648  \u50506 \u50520 \u49845 \u45768 \u45796 . \u50616 \u51228  \u45796 \u49884  \u45208 \u53440 \u45216 \u51648 , \u50612 \u46500  \u48169 \u49885 \u51004 \u47196  \u51217 \u44540 \u54644 \u50732 \u51648  \u50508  \u49688  \u50630 \u50632 \u49845 \u45768 \u45796 . \u54616 \u51648 \u47564  \u46020 \u47581 \u44040  \u49688 \u45716  \u50630 \u50632 \u49845 \u45768 \u45796 . 7\u45380  \u46041 \u50504  \u51060  \u51088 \u47532 \u47484  \u51648 \u53020 \u50728  \u44163 \u51008  \u46020 \u47581 \u52824 \u51648  \u50506 \u44592  \u50948 \u54644 \u49436 \u50688 \u49845 \u45768 \u45796 .\
\uc0\u47560 \u53944 \u47484  \u45208 \u50752  \u49884 \u51109  \u46244 \u54200  \u44264 \u47785 \u51004 \u47196  \u51217 \u50612 \u46300 \u45716  \u49692 \u44036 , \u49436 \u50980 \u51032  \u48156 \u44152 \u51020 \u51060  \u51200 \u51208 \u47196  \u45712 \u47140 \u51276 \u49845 \u45768 \u45796 . \u44264 \u47785  \u51473 \u44036 \u52196 \u50640  \u45572 \u44400 \u44032  \u49436  \u51080 \u50632 \u49845 \u45768 \u45796 . \u52376 \u51020 \u50640 \u45716  \u44536 \u45285  \u51648 \u45208 \u44032 \u45716  \u49324 \u46988 \u51064 \u44032  \u49910 \u50632 \u49845 \u45768 \u45796 . \u44536 \u47088 \u45936  \u44536  \u49324 \u46988 \u51060  \u50880 \u51649 \u51060 \u51648  \u50506 \u50520 \u49845 \u45768 \u45796 . \u44536 \u45285  \u49436 \u49436  \u54648 \u46300 \u54256  \u54868 \u47732 \u51012  \u46308 \u50668 \u45796 \u48372 \u44256  \u51080 \u50632 \u49845 \u45768 \u45796 . \u49436 \u50980 \u51060  \u44032 \u44620 \u51060  \u45796 \u44032 \u44032 \u47732 \u49436  \u50620 \u44404 \u51060  \u48372 \u51060 \u44592  \u49884 \u51089 \u54664 \u49845 \u45768 \u45796 .\
\uc0\u51060 \u49688 \u51652 \u51060 \u50632 \u49845 \u45768 \u45796 .\
\uc0\u49436 \u50980 \u51008  \u44152 \u51020 \u51012  \u47688 \u52628 \u50632 \u49845 \u45768 \u45796 . \u51109 \u48148 \u44396 \u45768  \u49552 \u51105 \u51060 \u47484  \u51540  \u49552 \u50640  \u55192 \u51060  \u46308 \u50612 \u44052 \u49845 \u45768 \u45796 . \u49688 \u51652 \u46020  \u44536  \u49692 \u44036  \u44256 \u44060 \u47484  \u46308 \u50632 \u49845 \u45768 \u45796 . \u46160  \u49324 \u46988 \u51032  \u45576 \u51060  \u47560 \u51452 \u52452 \u49845 \u45768 \u45796 . \u49688 \u51652 \u51032  \u54364 \u51221 \u51060  \u50500 \u51452  \u51104 \u44624  \u44403 \u50632 \u45796 \u44032 , \u48148 \u47196  \u50896 \u47000 \u45824 \u47196  \u46028 \u50500 \u50772 \u49845 \u45768 \u45796 .\
\uc0\u49436 \u50980 \u51008  \u44536  \u50620 \u44404 \u51012  \u48148 \u46972 \u48372 \u47732 \u49436  \u44592 \u50613 \u51060  \u48736 \u47476 \u44172  \u46104 \u44048 \u44220 \u49845 \u45768 \u45796 . \u51060 \u49688 \u51652 . \u48124 \u51456 \u51060  \u44208 \u54844  \u51204 \u50640  \u50724 \u47000  \u49324 \u44480 \u50632 \u45796 \u45716  \u50668 \u51088 . \u48124 \u51456 \u44284  \u54756 \u50612 \u51652  \u46244 \u50640 \u46020  \u54924 \u49324  \u49688 \u54665 \u48708 \u49436 \u47196  \u45224 \u50500 \u49436  \u51221 \u55148  \u50694 \u50640  \u48537 \u50612  \u51080 \u50632 \u49845 \u45768 \u45796 . \u52376 \u51020  \u49436 \u50980 \u51060  \u54924 \u49324 \u50640  \u46308 \u50612 \u44052 \u51012  \u46412  \u49688 \u51652 \u51008  \u50616 \u51228 \u45208  \u45800 \u51221 \u54616 \u44256  \u51312 \u50857 \u54664 \u49845 \u45768 \u45796 . \u54364 \u47732 \u51201 \u51004 \u47196 \u45716  \u50500 \u47924  \u47928 \u51228 \u44032  \u50630 \u50632 \u49845 \u45768 \u45796 . \u44536 \u47088 \u45936  \u49436 \u50980 \u51008  \u51060 \u49345 \u54616 \u44172  \u49688 \u51652  \u50526 \u50640 \u49436  \u54200 \u54620  \u51201 \u51060  \u50630 \u50632 \u49845 \u45768 \u45796 . \u45576 \u51060  \u47560 \u51452 \u52832  \u46412 \u47560 \u45796  \u47956 \u44032  \u51116 \u44256  \u51080 \u45716  \u49324 \u46988 \u52376 \u47100  \u45712 \u44788 \u51276 \u49845 \u45768 \u45796 . \u44536  \u44048 \u44033 \u51060  \u44536 \u45285  \u52265 \u44033 \u51060 \u44192 \u44144 \u45768  \u54616 \u44256  \u45336 \u44220 \u45912  \u44163 \u51060  7\u45380  \u51204 \u51060 \u50632 \u49845 \u45768 \u45796 .\
\uc0\u44536 \u47088 \u45936  \u51648 \u44552 . \u51221 \u55148 \u44032  \u49884 \u51109 \u50640 \u49436  \u51088 \u49888 \u51012  \u48156 \u44204 \u54620  \u48148 \u47196  \u47728 \u52832  \u46244 , \u51060  \u50668 \u51088 \u44032  \u51088 \u49888 \u51060  \u49324 \u45716  \u46041 \u45348  \u44264 \u47785 \u50640  \u49436  \u51080 \u50632 \u49845 \u45768 \u45796 . \u50864 \u50672 \u51068  \u49688 \u44032  \u50630 \u50632 \u49845 \u45768 \u45796 . \u49436 \u50980 \u51008  \u51109 \u48148 \u44396 \u45768 \u47484  \u45796 \u47480  \u49552 \u51004 \u47196  \u48148 \u45012  \u51536 \u47728  \u52380 \u52380 \u55176  \u49688 \u51652 \u51012  \u48148 \u46972 \u48372 \u50520 \u49845 \u45768 \u45796 . \u49688 \u51652 \u51008  \u49884 \u49440 \u51012  \u47676 \u51200  \u54588 \u54664 \u49845 \u45768 \u45796 . \u54648 \u46300 \u54256  \u54868 \u47732 \u51004 \u47196  \u45576 \u51012  \u45236 \u47532 \u44628 \u45908 \u45768 , \u50500 \u47924  \u51068 \u46020  \u50630 \u45716  \u49324 \u46988 \u52376 \u47100  \u44264 \u47785  \u45149  \u51901 \u51004 \u47196  \u44152 \u50612 \u44032 \u44592  \u49884 \u51089 \u54664 \u49845 \u45768 \u45796 .\
\uc0\u49436 \u50980 \u51008  \u44536  \u46263 \u47784 \u49845 \u51012  \u48148 \u46972 \u48372 \u50520 \u49845 \u45768 \u45796 . \u44032 \u49844  \u50504 \u51901 \u50640 \u49436  \u47956 \u44032 \u44032  \u51312 \u50857 \u55176  \u44403 \u50612 \u51648 \u45716  \u44163 \u51012  \u45712 \u44808 \u49845 \u45768 \u45796 . \u50780  \u54616 \u54596  \u51648 \u44552  \u51200  \u50668 \u51088 \u44032  \u45236  \u50526 \u50640  \u45208 \u53440 \u45212  \u44163 \u51064 \u51648 . \u44536 \u47532 \u44256  \u50780  \u45576 \u51060  \u47560 \u51452 \u52824 \u51088 \u47560 \u51088  \u47676 \u51200  \u49884 \u49440 \u51012  \u54588 \u54620  \u44163 \u51064 \u51648 . \u44536  \u46160  \u44032 \u51648 \u44032  \u47672 \u47551 \u49549 \u50640 \u49436  \u47582 \u47932 \u47532 \u47732 \u49436  7\u45380  \u51204 \u50640  \u50612 \u47156 \u54411 \u51060  \u49828 \u52452 \u45912  \u44048 \u44033 \u51060  \u45796 \u49884  \u49332 \u50500 \u45228 \u49845 \u45768 \u45796 . \u45817 \u49884 \u50640 \u45716  \u54869 \u51064 \u54624  \u48169 \u48277 \u46020 , \u54869 \u51064 \u54624  \u50857 \u44592 \u46020  \u50630 \u50632 \u49845 \u45768 \u45796 . \u54924 \u49324 \u50640 \u49436  \u51923 \u44200 \u45208 \u44256 , \u51060 \u54844  \u49436 \u47448 \u50640  \u46020 \u51109 \u51012  \u52237 \u44256 , \u48176  \u49549 \u51032  \u50500 \u51060 \u47484  \u54844 \u51088  \u54408 \u51008  \u52292 \u47196  \u45231 \u49440  \u46020 \u49884 \u47196  \u45236 \u47140 \u50772 \u49845 \u45768 \u45796 . \u44536 \u46412 \u51032  \u49436 \u50980 \u50640 \u44172 \u45716  \u51652 \u49892 \u51012  \u54028 \u54756 \u52832  \u55192 \u51060  \u50630 \u50632 \u49845 \u45768 \u45796 . \u49332 \u50500 \u45236 \u45716  \u44163 \u47564 \u51004 \u47196 \u46020  \u48261 \u52284 \u49845 \u45768 \u45796 .\
\uc0\u51648 \u44552 \u51008  \u45804 \u46992 \u49845 \u45768 \u45796 . \u50500 \u51060 \u44032  \u51080 \u50632 \u49845 \u45768 \u45796 . \u44536  \u50500 \u51060 \u44032  \u51088 \u49888 \u51012  \u50668 \u44592 \u44620 \u51648  \u48260 \u54000 \u44172  \u54664 \u44256 , \u50526 \u51004 \u47196 \u46020  \u48260 \u54000 \u44172  \u54624  \u44163 \u51060 \u50632 \u49845 \u45768 \u45796 . \u49436 \u50980 \u51008  \u49688 \u51652 \u51060  \u49324 \u46972 \u51652  \u44264 \u47785  \u45149 \u51012  \u48148 \u46972 \u48372 \u45796 \u44032 , \u52380 \u52380 \u55176  \u48156 \u44152 \u51020 \u51012  \u50734 \u44220 \u49845 \u45768 \u45796 . \u51109 \u48148 \u44396 \u45768 \u44032  \u49552 \u47785 \u50640 \u49436  \u55124 \u46308 \u47160 \u49845 \u45768 \u45796 . \u50864 \u50672 \u51060  \u50500 \u45772  \u44163 \u46308 \u51060  \u54616 \u45208 \u50473  \u51228  \u47784 \u49845 \u51012  \u46300 \u47084 \u45236 \u44592  \u49884 \u51089 \u54616 \u44256  \u51080 \u50632 \u49845 \u45768 \u45796 . \u44536 \u47532 \u44256  \u49436 \u50980 \u51008  \u51060 \u48264 \u47564 \u53372 \u51008 , \u45576 \u51012  \u44048 \u44256  \u51648 \u45208 \u52824 \u51648  \u50506 \u51012  \u44163 \u51060 \u50632 \u49845 \u45768 \u45796 .\
