\uc0\u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473  [\u52309 \u53552 10] \u49352 \u47196 \u50868  \u50500 \u52840  \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \
\uc0\u49688 \u51652 \u51008  \u44536 \u45216 \u47196  \u54924 \u49324 \u47484  \u45208 \u50772 \u49845 \u45768 \u45796 .\
\uc0\u54644 \u44256 \u45716  \u51312 \u50857 \u54616 \u44256  \u48736 \u47476 \u44172  \u52376 \u47532 \u46096 \u49845 \u45768 \u45796 . \u48277 \u47924 \u54016 \u51060  \u49436 \u47448 \u47484  \u51456 \u48708 \u54664 \u44256 , \u44048 \u49324 \u54016 \u51060  \u46041 \u54665 \u54664 \u49845 \u45768 \u45796 . \u49688 \u51652 \u51008  \u51088 \u49888 \u51032  \u51088 \u47532 \u50640 \u49436  \u51664 \u51012  \u52313 \u44592 \u45716  \u46041 \u50504  \u50500 \u47924  \u47568 \u46020  \u54616 \u51648  \u50506 \u50520 \u49845 \u45768 \u45796 . \u51649 \u50896 \u46308 \u51060  \u44536  \u47784 \u49845 \u51012  \u48148 \u46972 \u48372 \u50520 \u51648 \u47564 , \u45572 \u44396 \u46020  \u45796 \u44032 \u44032 \u51648  \u50506 \u50520 \u49845 \u45768 \u45796 . 15\u45380 \u51012  \u54632 \u44760 \u54620  \u49324 \u46988 \u46308 \u51060 \u50632 \u45716 \u45936 , \u50500 \u47924 \u46020  \u45576 \u51060  \u47560 \u51452 \u52824 \u47140  \u54616 \u51648  \u50506 \u50520 \u49845 \u45768 \u45796 . \u49688 \u51652 \u51008  \u51089 \u51008  \u48149 \u49828  \u54616 \u45208 \u47484  \u46308 \u44256  \u44148 \u47932 \u51012  \u45208 \u44052 \u49845 \u45768 \u45796 .\
\uc0\u44536 \u47196 \u48512 \u53552  \u47728 \u52832  \u46244 , \u49688 \u51652 \u50640 \u44172  \u49324 \u47928 \u49436  \u50948 \u51312 \u50752  \u54945 \u47161  \u51312 \u51089  \u54800 \u51032 \u47196  \u49688 \u49324  \u53685 \u48372 \u44032  \u45236 \u47140 \u50772 \u49845 \u45768 \u45796 . \u54924 \u49324  \u52769 \u51060  \u45433 \u52712 \u50752  \u48373 \u44396 \u46108  \u49436 \u48260  \u51088 \u47308 \u47484  \u51613 \u44144 \u47196  \u51228 \u52636 \u54664 \u49845 \u45768 \u45796 . \u49688 \u51652 \u51032  \u51060 \u47492 \u51060  \u50629 \u44228 \u50640  \u54140 \u51648 \u45716  \u45936 \u45716  \u50724 \u47000  \u44152 \u47532 \u51648  \u50506 \u50520 \u49845 \u45768 \u45796 . \u52828 \u52377 \u46308 \u46020 , \u50724 \u47004  \u51648 \u51064 \u46308 \u46020 , \u51204  \u51649 \u51109  \u46041 \u47308 \u46308 \u46020  \u50500 \u47924 \u46020  \u44048 \u49912 \u51648  \u50506 \u50520 \u49845 \u45768 \u45796 . 15\u45380 \u51012  \u45216 \u52852 \u47213 \u44172 , \u48712 \u53960 \u50630 \u51060  \u49332 \u50500 \u50772 \u51648 \u47564  \u44536  \u45149 \u51060  \u51060 \u47111 \u44172  \u45225 \u51089 \u54616 \u44172  \u44032 \u46972 \u50505 \u51012  \u44144 \u46972 \u44256 \u45716  \u50500 \u47560  \u49688 \u51652  \u51088 \u49888 \u46020  \u47792 \u46992 \u51012  \u44163 \u51060 \u50632 \u49845 \u45768 \u45796 .\
\uc0\u44536 \u49324 \u51060  \u48124 \u51456 \u51008  \u49884 \u51109  \u44264 \u47785 \u51004 \u47196  \u45236 \u47140 \u44052 \u49845 \u45768 \u45796 .\
\uc0\u51060 \u49324 \u54924 \u44032  \u45149 \u45212  \u45796 \u51020  \u45216  \u50500 \u52840 \u51060 \u50632 \u49845 \u45768 \u45796 . \u44032 \u44172  \u47928 \u51060  \u50676 \u47532 \u44592  \u51204 \u51060 \u50632 \u45716 \u45936 , \u49436 \u50980 \u51060  \u49492 \u53552 \u47484  \u50732 \u47532 \u45716  \u49548 \u47532 \u44032  \u46308 \u47160 \u49845 \u45768 \u45796 . \u48124 \u51456 \u51008  \u44264 \u47785  \u51077 \u44396  \u51901 \u50640  \u49436 \u49436  \u44592 \u45796 \u47160 \u49845 \u45768 \u45796 . \u49436 \u50980 \u51060  \u44032 \u44172  \u47928 \u51012  \u50676 \u44256  \u45208 \u50724 \u45796 \u44032  \u44264 \u47785  \u51077 \u44396 \u50640  \u49436  \u51080 \u45716  \u48124 \u51456 \u51012  \u48156 \u44204 \u54616 \u44256  \u47688 \u52628 \u50632 \u49845 \u45768 \u45796 . \u46160  \u49324 \u46988 \u51032  \u45576 \u51060  \u47560 \u51452 \u52452 \u49845 \u45768 \u45796 .\
\uc0\u48124 \u51456 \u51008  \u52380 \u52380 \u55176  \u44152 \u50612 \u44052 \u49845 \u45768 \u45796 . \u44032 \u44172  \u50526 \u50640  \u49436 \u51088  \u44536 \u45824 \u47196  \u47924 \u47502 \u51012  \u44999 \u50632 \u49845 \u45768 \u45796 . \u44264 \u47785  \u48148 \u45797 \u51060  \u52264 \u44049 \u44256  \u46385 \u46385 \u54664 \u49845 \u45768 \u45796 . \u44536  \u52264 \u44032 \u50880 \u51060  \u45712 \u44788 \u51276 \u51648 \u47564  \u51068 \u50612 \u45208 \u51648  \u50506 \u50520 \u49845 \u45768 \u45796 . \u51648 \u45208 \u44032 \u45912  \u49884 \u51109  \u49345 \u51064  \u54616 \u45208 \u44032  \u55128 \u44611  \u48148 \u46972 \u48372 \u45796  \u51648 \u45208 \u44052 \u49845 \u45768 \u45796 . \u48124 \u51456 \u51008  \u49888 \u44221  \u50416 \u51648  \u50506 \u50520 \u49845 \u45768 \u45796 .\
