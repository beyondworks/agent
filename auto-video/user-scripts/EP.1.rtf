\uc0\u49436 \u50980 \u51008  \u54620 \u46041 \u50504  \u50500 \u47924  \u47568 \u46020  \u54616 \u51648  \u50506 \u50520 \u49845 \u45768 \u45796 . \u47924 \u47502 \u51012  \u44999 \u51008  \u48124 \u51456 \u51012  \u45236 \u47140 \u45796 \u48372 \u47732 \u49436  \u44536 \u45285  \u49436  \u51080 \u50632 \u49845 \u45768 \u45796 . \u44264 \u47785  \u50504 \u51901 \u50640 \u49436  \u49884 \u51109  \u49345 \u51064 \u46308 \u51060  \u49688 \u47112 \u47484  \u45132 \u44256  \u51648 \u45208 \u44032 \u45716  \u49548 \u47532 \u44032  \u46308 \u47160 \u49845 \u45768 \u45796 . \u51060 \u47480  \u50500 \u52840 \u51032  \u49884 \u51109 \u51060  \u44648 \u50612 \u45208 \u45716  \u49548 \u47532 \u50688 \u49845 \u45768 \u45796 . \u49436 \u50980 \u51008  \u48124 \u51456 \u51032  \u44403 \u50612 \u51652  \u50612 \u44648 \u47484  \u48148 \u46972 \u48372 \u50520 \u49845 \u45768 \u45796 . 7\u45380 \u51060 \u50632 \u49845 \u45768 \u45796 . \u51060  \u49324 \u46988 \u46020  7\u45380 \u51012  \u49332 \u50520 \u49845 \u45768 \u45796 . \u50612 \u46523 \u44172  \u49332 \u50520 \u45716 \u51648 \u45716  \u47784 \u47476 \u51648 \u47564 , \u44536  \u49884 \u44036 \u51060  \u44032 \u48316 \u50912 \u51012  \u47532  \u50630 \u45796 \u45716  \u44163  \u51221 \u46020 \u45716  \u50508 \u50520 \u49845 \u45768 \u45796 . \u44536 \u47000 \u46020  \u49789 \u44172  \u45459 \u50500 \u51460  \u49688 \u45716  \u50630 \u50632 \u49845 \u45768 \u45796 . \u50500 \u51649 \u51008 .\
