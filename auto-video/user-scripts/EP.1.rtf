\uc0\u51221 \u55148 \u45716  \u51687 \u44172  \u44256 \u44060 \u47484  \u45124 \u45909 \u51060 \u44256  \u44263 \u51109  \u52285 \u48150 \u51004 \u47196  \u49884 \u49440 \u51012  \u46028 \u47160 \u49845 \u45768 \u45796 . \u49688 \u51652 \u51008  \u50526 \u51012  \u48372 \u47728  \u49884 \u46041 \u51012  \u44152 \u50632 \u49845 \u45768 \u45796 . \u48177 \u48120 \u47084  \u50504 \u50640  \u51221 \u55148 \u51032  \u45576 \u51060  \u51104 \u44624  \u48708 \u52452 \u49845 \u45768 \u45796 . \u44536  \u45576 \u51060  \u51088 \u49888 \u51012  \u48372 \u44256  \u51080 \u45716  \u44163 \u51064 \u51648 , \u50500 \u45768 \u47732  \u44536 \u45285  \u47676  \u44275 \u51012  \u48372 \u44256  \u51080 \u45716  \u44163 \u51064 \u51648  \u49688 \u51652 \u51008  \u50508  \u49688  \u50630 \u50632 \u49845 \u45768 \u45796 . \u44536 \u47000 \u49436  \u45908  \u51312 \u49900 \u49828 \u47101 \u44172  \u49884 \u49440 \u51012  \u46020 \u47196 \u47196  \u50734 \u44220 \u49845 \u45768 \u45796 . \u52264 \u44032  \u52380 \u52380 \u55176  \u49884 \u51109  \u44264 \u47785 \u51012  \u48736 \u51256 \u45208 \u44032 \u44592  \u49884 \u51089 \u54664 \u49845 \u45768 \u45796 .\
\uc0\u49688 \u51652 \u51008  \u44536 \u45216  \u51060 \u54980 \u47196  \u50508 \u44256  \u51080 \u50632 \u49845 \u45768 \u45796 . \u51221 \u55148 \u44032  \u54620 \u48264  \u47932 \u44592  \u49884 \u51089 \u54616 \u47732  \u45459 \u51648  \u50506 \u45716 \u45796 \u45716  \u44163 \u51012 . 15\u45380 \u51012  \u44225 \u50640 \u49436  \u51648 \u53020 \u48400 \u50728  \u49324 \u46988 \u51004 \u47196 \u49436 , \u45572 \u44396 \u48372 \u45796  \u51096  \u50508 \u44256  \u51080 \u50632 \u49845 \u45768 \u45796 . \u54801 \u47141 \u50629 \u52404 \u50752 \u51032  \u44040 \u46321 , \u51076 \u50896 \u46308 \u44284 \u51032  \u48516 \u51137 , \u47588 \u44033  \u50948 \u44592 \u44620 \u51648  \u47792 \u47160 \u45912  \u44536  \u47751  \u45380 . \u51221 \u55148 \u44032  \u54252 \u44592 \u54620  \u44163 \u51012  \u49688 \u51652 \u51008  \u45800  \u54620  \u48264 \u46020  \u48376  \u51201 \u51060  \u50630 \u50632 \u49845 \u45768 \u45796 . \u44536 \u47111 \u44592  \u46412 \u47928 \u50640  \u51648 \u44552  \u51060  \u49692 \u44036 \u51060  \u46160 \u47140 \u50912 \u49845 \u45768 \u45796 . \u51312 \u49324 \u47484  \u47585 \u51008  \u44148  \u51088 \u49888 \u51060 \u50632 \u49845 \u45768 \u45796 . \u50612 \u46356 \u49436  \u47924 \u50631 \u51012  \u52286 \u50500 \u45236 \u45712 \u45264 \u46020  \u51088 \u49888 \u50640 \u44172  \u45804 \u47140  \u51080 \u50632 \u49845 \u45768 \u45796 . \u54616 \u51648 \u47564  \u51221 \u55148 \u45716  \u47688 \u52628 \u51648  \u50506 \u51012  \u44163 \u51060 \u50632 \u49845 \u45768 \u45796 . \u49688 \u51652 \u51060  \u50612 \u46500  \u44208 \u44284 \u47484  \u44032 \u51256 \u50724 \u46304 , \u44536 \u44163 \u50640  \u47564 \u51313 \u54616 \u51648  \u50506 \u44256  \u45908  \u54028 \u44256 \u46308  \u44163 \u51060 \u50632 \u49845 \u45768 \u45796 . \u54648 \u46308 \u51012  \u51540  \u49552 \u50640  \u55192 \u51060  \u46308 \u50612 \u44052 \u49845 \u45768 \u45796 . \u52285 \u48150 \u51004 \u47196  \u49884 \u51109  \u44264 \u47785 \u51032  \u44036 \u54032 \u46308 \u51060  \u54616 \u45208 \u50473  \u46244 \u47196  \u49324 \u46972 \u51276 \u49845 \u45768 \u45796 . \u49688 \u51652 \u51008  \u50526 \u51012  \u48372 \u47732 \u49436  \u49549 \u51004 \u47196  \u44228 \u49328 \u54664 \u49845 \u45768 \u45796 . \u50612 \u46356 \u44620 \u51648  \u47561 \u51012  \u49688  \u51080 \u51012 \u51648 . \u50612 \u46356 \u49436 \u48512 \u53552  \u55124 \u46308 \u47540 \u51648 . \u44536  \u44221 \u44228 \u49440 \u51012  \u50500 \u51649  \u52286 \u51648  \u47803 \u54664 \u49845 \u45768 \u45796 .\
