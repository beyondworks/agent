\uc0\u54028 \u51068 \u51008  \u49340 \u48516 \u51060  \u51312 \u44552  \u45336 \u50632 \u49845 \u45768 \u45796 . \u48124 \u51456 \u51008  \u44536 \u44163 \u51012  \u52376 \u51020 \u48512 \u53552  \u45149 \u44620 \u51648  \u49464  \u48264  \u46308 \u50632 \u49845 \u45768 \u45796 . \u52395  \u48264 \u51704 \u45716  \u45236 \u50857 \u51012  \u54028 \u50501 \u54616 \u45712 \u46972  \u50500 \u47924 \u47088  \u44048 \u51221 \u46020  \u50630 \u51060  \u46308 \u50632 \u49845 \u45768 \u45796 . \u46160  \u48264 \u51704 \u45716  \u49688 \u51652 \u51032  \u47785 \u49548 \u47532 \u50640 \u49436  \u45576 \u50640  \u51061 \u51008  \u49324 \u46988 \u51032  \u50620 \u44404 \u51060  \u44217 \u52432 \u50724 \u47732 \u49436  \u49552 \u51060  \u46504 \u47160 \u49845 \u45768 \u45796 . \u49464  \u48264 \u51704 \u45716  \u49548 \u47532  \u50630 \u51060  \u45576 \u47932 \u51060  \u45228 \u49845 \u45768 \u45796 . \u49436 \u50980 \u54620 \u53580  \u51396 \u47484  \u46244 \u51665 \u50612 \u50444 \u50864 \u47140 \u44256  \u47564 \u46304  \u51068 \u51060 \u46972 \u45716  \u44536  \u47568 \u51060 , \u49464  \u48264  \u45796  \u44480 \u47484  \u54028 \u44256 \u46308 \u50632 \u49845 \u45768 \u45796 .\
\uc0\u48124 \u51456 \u51008  \u54648 \u46300 \u54256 \u51012  \u45236 \u47140 \u45459 \u44256  \u52380 \u51109 \u51012  \u50732 \u47140 \u45796 \u48372 \u50520 \u49845 \u45768 \u45796 . \u49548 \u54028  \u50948 \u50640  \u46321 \u51012  \u44592 \u45828  \u52292 \u47196  \u54620 \u46041 \u50504  \u50880 \u51649 \u51060 \u51648  \u50506 \u50520 \u49845 \u45768 \u45796 . \u49436 \u50980 \u51060  \u51665 \u51012  \u45208 \u44032 \u45912  \u44536 \u45216  \u50500 \u52840 \u51060  \u46608  \u46496 \u50732 \u46992 \u49845 \u45768 \u45796 . \u44032 \u48169 \u51012  \u46308 \u44256  \u54788 \u44288 \u51012  \u45208 \u49436 \u45912  \u46263 \u47784 \u49845 . \u46244 \u46028 \u50500 \u48372 \u51648  \u50506 \u50520 \u49845 \u45768 \u45796 . \u54620  \u48264 \u46020 . \u44536 \u46412  \u50780  \u50500 \u47924  \u47568 \u46020  \u54616 \u51648  \u50506 \u50520 \u51012 \u44620 . \u50613 \u50872 \u54616 \u45796 \u44256 , \u51088 \u49888 \u51060  \u54620  \u51068 \u51060  \u50500 \u45768 \u46972 \u44256 . \u44536  \u47568  \u54620 \u47560 \u46356 \u47564  \u54664 \u50612 \u46020  \u45804 \u46972 \u51276 \u51012 \u44620 \u50836 .\
\uc0\u45804 \u46972 \u51648 \u51648  \u50506 \u50520 \u51012  \u44163 \u51077 \u45768 \u45796 . \u44536 \u44163 \u51060  \u48124 \u51456 \u51012  \u44032 \u51109  \u47924 \u44161 \u44172  \u51667 \u45580 \u47104 \u49845 \u45768 \u45796 . \u49436 \u50980 \u51060  \u50500 \u47924 \u47532  \u47568 \u54664 \u50612 \u46020 , \u44536 \u46412 \u51032  \u48124 \u51456 \u51008  \u46308 \u51012  \u51456 \u48708 \u44032  \u46104 \u50612  \u51080 \u51648  \u50506 \u50520 \u49845 \u45768 \u45796 . \u50612 \u47672 \u45768 \u51032  \u44208 \u51221 \u51012  \u46384 \u46992 \u44256 , \u51613 \u44144  \u50526 \u50640 \u49436  \u49373 \u44033 \u51012  \u47688 \u52628 \u50632 \u49845 \u45768 \u45796 . \u44536  \u49324 \u46988 \u51060  \u51088 \u49888 \u51060 \u50632 \u49845 \u45768 \u45796 . \u48124 \u51456 \u51008  \u46160  \u49552 \u51004 \u47196  \u50620 \u44404 \u51012  \u44048 \u49932 \u49845 \u45768 \u45796 .\
\uc0\u45796 \u51020  \u45216  \u50724 \u51204 , \u48124 \u51456 \u51008  \u50612 \u47672 \u45768 \u50640 \u44172  \u51204 \u54868 \u47484  \u44152 \u50632 \u49845 \u45768 \u45796 .\
"\uc0\u45796  \u46308 \u50632 \u49845 \u45768 \u45796 ."\
\uc0\u51221 \u55148 \u45716  \u50500 \u47924  \u47568 \u46020  \u54616 \u51648  \u50506 \u50520 \u49845 \u45768 \u45796 . \u48124 \u51456 \u51060  \u51060 \u50612 \u44052 \u49845 \u45768 \u45796 .\
"\uc0\u51060 \u49324 \u54924  \u49548 \u51665 \u54616 \u49464 \u50836 . \u51228 \u44032  \u44144 \u44592  \u51080 \u50612 \u50556  \u54624  \u44163  \u44057 \u49845 \u45768 \u45796 ."\
\uc0\u51221 \u55148 \u45716  \u51104 \u49884  \u52840 \u47925 \u54664 \u45796 \u44032  \u45230 \u44172  \u47568 \u54664 \u49845 \u45768 \u45796 .\
"\uc0\u50508 \u44192 \u50612 ."\
\uc0\u51060 \u53952  \u46244  \u51060 \u49324 \u54924 \u44032  \u50676 \u47160 \u49845 \u45768 \u45796 . \u44536  \u51204 \u45216 , \u51221 \u55148 \u45716  \u49436 \u50980 \u50640 \u44172  \u47676 \u51200  \u50672 \u46973 \u54664 \u49845 \u45768 \u45796 .\
\uc0\u49884 \u51109  \u44264 \u47785  \u50504  \u51089 \u51008  \u52852 \u54168 \u50640 \u49436  \u46160  \u49324 \u46988 \u51060  \u47560 \u51452  \u50505 \u50520 \u49845 \u45768 \u45796 . \u52376 \u51020 \u51060 \u50632 \u49845 \u45768 \u45796 . 7\u45380  \u51204  \u51060 \u54980 \u47196  \u44057 \u51008  \u44277 \u44036 \u50640 \u49436  \u47560 \u51452  \u50505 \u45716  \u44163 \u51060 . \u49436 \u50980 \u51008  \u52964 \u54588 \u47484  \u48155 \u50500 \u46308 \u50632 \u51648 \u47564  \u47560 \u49884 \u51648  \u50506 \u50520 \u49845 \u45768 \u45796 . \u51221 \u55148 \u46020  \u47560 \u52268 \u44032 \u51648 \u50688 \u49845 \u45768 \u45796 .\
"\uc0\u49436 \u50980 \u50500 , \u45236 \u44032  \u51096 \u47803 \u54664 \u45796 .\'94\
\uc0\u52395 \u47560 \u46356 \u50688 \u49845 \u45768 \u45796 . \u49436 \u50980 \u51008  \u45576 \u51012  \u46308 \u50632 \u49845 \u45768 \u45796 . \u51221 \u55148 \u51032  \u50620 \u44404 \u51060  \u48372 \u50688 \u49845 \u45768 \u45796 . \u44536  \u50620 \u44404 \u51060  7\u45380  \u51204 \u44284 \u45716  \u45804 \u46992 \u49845 \u45768 \u45796 . \u45800 \u45800 \u54616 \u44256  \u52264 \u44049 \u45912  \u44536  \u45576 \u48731 \u51060  \u51648 \u44552 \u51008  \u45796 \u47480  \u44163 \u51012  \u45812 \u44256  \u51080 \u50632 \u49845 \u45768 \u45796 . \u49436 \u50980 \u51008  \u50500 \u47924  \u47568 \u46020  \u54616 \u51648  \u50506 \u50520 \u49845 \u45768 \u45796 .\
"\uc0\u45236 \u51068  \u51060 \u49324 \u54924  \u51088 \u47532 \u50640 \u49436  \u49688 \u51652 \u50472  \u51068 \u51012  \u44277 \u44060 \u54624  \u44144 \u50556 . \u45320 \u50640 \u44172  \u46244 \u51665 \u50612 \u50444 \u50892 \u51652  \u44172  \u47582 \u45796 \u45716  \u44163 \u46020 . \u49436 \u50980 \u51060 \u44032  \u54632 \u44760  \u51080 \u50612 \u51500 \u51004 \u47732  \u54620 \u45796 .\'94\
\uc0\u49436 \u50980 \u51008  \u51104 \u49884  \u52840 \u47925 \u54664 \u49845 \u45768 \u45796 . \u52964 \u54588 \u51092 \u51012  \u49552 \u51004 \u47196  \u44048 \u49912 \u51536 \u45796 \u44032  \u51077 \u51012  \u50676 \u50632 \u49845 \u45768 \u45796 .\
"\uc0\u51228 \u44032  \u44144 \u44592  \u51080 \u51004 \u47732  \u47952 \u44032  \u45804 \u46972 \u51648 \u45208 \u50836 ."\
"\uc0\u45804 \u46972 \u51648 \u51648 . \u45320 \u44032  \u44536  \u51088 \u47532 \u50640  \u51080 \u50612 \u50556  7\u45380  \u51204  \u51068 \u51060  \u51228 \u45824 \u47196  \u46108  \u51088 \u47532 \u47484  \u52286 \u44172 \u46104 \
\uc0\u49436 \u50980 \u51008  \u52285 \u48150 \u51012  \u48148 \u46972 \u48372 \u50520 \u49845 \u45768 \u45796 . \u49884 \u51109  \u44264 \u47785 \u51060  \u48372 \u50688 \u49845 \u45768 \u45796 . 7\u45380 \u51012  \u49332 \u50500 \u50728  \u44275 \u51060 \u50632 \u49845 \u45768 \u45796 . \u50500 \u46308 \u51060  \u45796 \u45768 \u45716  \u54617 \u44368 \u44032  \u51200 \u51901  \u48169 \u54693 \u50640  \u51080 \u50632 \u49845 \u45768 \u45796 . \u54620 \u52280  \u46244 \u50640  \u49436 \u50980 \u51060  \u44256 \u44060 \u47484  \u46028 \u47160 \u49845 \u45768 \u45796 .\
"\uc0\u44032 \u44192 \u49845 \u45768 \u45796 ."\
\uc0\u51221 \u55148 \u45716  \u45576 \u51012  \u45236 \u47160 \u49845 \u45768 \u45796 . \u51060 \u48264 \u50640 \u45716  \u44256 \u44060 \u47484  \u45124 \u45909 \u51060 \u45716  \u44163 \u51004 \u47196  \u45824 \u49888 \u54664 \u49845 \u45768 \u45796 .\
\uc0\u44032 \u51313 \u44284  \u54645 \u49900  \u51076 \u50896 \u46308 , \u44536 \u47532 \u44256  \u48277 \u47924 \u54016 \u51060  \u47784 \u46160  \u52280 \u49437 \u54664 \u49845 \u45768 \u45796 . \u49688 \u51652 \u46020  \u44536  \u51088 \u47532 \u50640  \u51080 \u50632 \u49845 \u45768 \u45796 . \u51221 \u55148 \u44032  \u51649 \u51217  \u52280 \u49437 \u54616 \u46972 \u44256  \u54664 \u44592  \u46412 \u47928 \u51060 \u50632 \u49845 \u45768 \u45796 . \u49688 \u51652 \u51008  \u45800 \u51221 \u54620  \u51088 \u47532 \u50640  \u50505 \u50500  \u54924 \u51032  \u51088 \u47308 \u47484  \u46308 \u50668 \u45796 \u48372 \u45716  \u52377 \u54664 \u51648 \u47564 , \u50504 \u51008  \u45796 \u47480  \u49345 \u53468 \u50688 \u49845 \u45768 \u45796 . \u51060  \u51088 \u47532 \u44032  \u50780  \u44049 \u51088 \u44592  \u49548 \u51665 \u46096 \u45716 \u51648 , \u51088 \u49888 \u51060  \u50780  \u48520 \u47140 \u50772 \u45716 \u51648 . \u44536  \u45813 \u51012  \u51060 \u48120  \u50508 \u44256  \u51080 \u50632 \u49845 \u45768 \u45796 . \u49552 \u51060  \u47924 \u47502  \u50948 \u50640 \u49436  \u51312 \u50857 \u55176  \u51536 \u50612 \u51276 \u49845 \u45768 \u45796 .\
\uc0\u51221 \u55148 \u44032  \u54924 \u51032 \u49892  \u50526 \u50640  \u49456 \u49845 \u45768 \u45796 . \u54217 \u49548 \u50752  \u45796 \u47476 \u51648  \u50506 \u51008  \u51088 \u49464 \u50688 \u51648 \u47564 , \u44536  \u45576 \u51060  \u45804 \u46992 \u49845 \u45768 \u45796 . \u51340 \u51473 \u51012  \u54620 \u48264  \u52380 \u52380 \u55176  \u46168 \u47084 \u48372 \u44256  \u45208 \u49436  \u51077 \u51012  \u50676 \u50632 \u49845 \u45768 \u45796 .\
"\uc0\u50724 \u45720  \u51060  \u51088 \u47532 \u45716  7\u45380  \u51204  \u51068  \u46412 \u47928 \u50640  \u49548 \u51665 \u54664 \u49845 \u45768 \u45796 . \u45796 \u46308  \u44592 \u50613 \u54616 \u49892  \u44161 \u45768 \u45796 . \u45817 \u49884  \u44221 \u50689 \u44592 \u54925 \u54016  \u49548 \u49549 \u51060 \u50632 \u45912  \u54620 \u49436 \u50980 \u50472  \u54945 \u47161  \u49324 \u44148 \u51060 \u50836 ."\
\uc0\u54924 \u51032 \u49892  \u50504 \u51060  \u51312 \u50857 \u54644 \u51276 \u49845 \u45768 \u45796 . \u47751 \u47751  \u51076 \u50896 \u46308 \u51032  \u45576 \u51060  \u50880 \u51649 \u50688 \u49845 \u45768 \u45796 . \u49688 \u51652 \u51008  \u44256 \u44060 \u47484  \u46308 \u51648  \u50506 \u50520 \u49845 \u45768 \u45796 .\
"\uc0\u44536  \u49324 \u44148 \u51012  \u45796 \u49884  \u46308 \u50668 \u45796 \u48420 \u49845 \u45768 \u45796 ."\
\uc0\u51221 \u55148 \u45716  \u47532 \u47784 \u52968 \u51012  \u46308 \u50632 \u49845 \u45768 \u45796 . \u54924 \u51032 \u49892  \u50526  \u49828 \u53356 \u47536 \u50640  \u54028 \u51068 \u51060  \u50676 \u47160 \u49845 \u45768 \u45796 . \u48373 \u44396 \u46108  \u44144 \u47000  \u44592 \u47197 \u51060 \u50632 \u49845 \u45768 \u45796 .\
"\uc0\u51060 \u44172  \u45817 \u49884  \u49436 \u50980 \u50472  \u47749 \u51032 \u47196  \u51060 \u52404 \u46108  \u44163 \u51004 \u47196  \u44592 \u47197 \u46108  \u44144 \u47000  \u45236 \u50669 \u51077 \u45768 \u45796 . \u44536 \u47088 \u45936  \u51060  \u45216 \u51676 , \u49436 \u50980 \u50472 \u44032  \u51648 \u48169  \u52636 \u51109  \u51473 \u51060 \u50632 \u49845 \u45768 \u45796 . \u49436 \u50872  \u48376 \u49324 \u50640  \u50630 \u50632 \u45912  \u45216 \u51060 \u50640 \u50836 ."\
\uc0\u51076 \u50896 \u46308 \u51060  \u54868 \u47732 \u51012  \u48372 \u44592  \u49884 \u51089 \u54664 \u49845 \u45768 \u45796 . \u51221 \u55148 \u44032  \u45796 \u51020  \u54028 \u51068 \u51012  \u46916 \u50912 \u49845 \u45768 \u45796 .\
"\uc0\u44536 \u47532 \u44256  \u51060 \u44172  \u48373 \u44396 \u46108  \u49849 \u51064  \u47196 \u44536 \u51077 \u45768 \u45796 . \u51060  \u44208 \u51116 \u47484  \u52376 \u47532 \u54620  \u44228 \u51221 \u51060  \u45572 \u44396  \u44228 \u51221 \u51064 \u51648  \u54869 \u51064 \u46096 \u49845 \u45768 \u45796 ."\
\uc0\u51221 \u55148 \u44032  \u49688 \u51652 \u51012  \u48148 \u46972 \u48372 \u50520 \u49845 \u45768 \u45796 .\
"\uc0\u49688 \u51652 \u50472 , \u51060  \u44228 \u51221  \u50500 \u51060 \u46356  \u50508 \u50500 \u50836 ?"\
\uc0\u54924 \u51032 \u49892  \u51204 \u52404 \u51032  \u49884 \u49440 \u51060  \u49688 \u51652 \u50640 \u44172  \u50144 \u47160 \u49845 \u45768 \u45796 . \u49688 \u51652 \u51008  \u44256 \u44060 \u47484  \u46308 \u50632 \u49845 \u45768 \u45796 . \u50620 \u44404 \u51060  \u52285 \u48177 \u54664 \u49845 \u45768 \u45796 . \u51077 \u49696 \u51060  \u50880 \u51649 \u50688 \u49845 \u45768 \u45796 .\
"\uc0\u44536 \u44148  \u51228  \u44228 \u51221  \u50500 \u51060 \u46356 \u44032  \u50500 \u45785 \u45768 \u45796 ."\
"\uc0\u49436 \u48260  \u44592 \u47197 \u49345  \u49688 \u51652 \u50472  \u44228 \u51221 \u51060 \u50640 \u50836 ."\
"\uc0\u45817 \u49884 \u50640  \u44228 \u51221  \u44277 \u50976 \u44032  \u51080 \u50632 \u49845 \u45768 \u45796 . \u45572 \u44400 \u44032  \u51228  \u44228 \u51221 \u51012  \u46020 \u50857 \u54664 \u51012  \u49688 \u46020 ."\
\uc0\u51221 \u55148 \u45716  \u45824 \u45813 \u54616 \u51648  \u50506 \u50520 \u49845 \u45768 \u45796 . \u49688 \u51652 \u51032  \u47568 \u51060  \u45149 \u45208 \u51088 \u47560 \u51088  \u47532 \u47784 \u52968 \u51012  \u45796 \u49884  \u46308 \u50632 \u49845 \u45768 \u45796 .\
"\uc0\u47560 \u51648 \u47561 \u51004 \u47196  \u54616 \u45208  \u45908  \u46307 \u44192 \u49845 \u45768 \u45796 ."\
\uc0\u49828 \u54588 \u52964 \u50640 \u49436  \u49548 \u47532 \u44032  \u55128 \u47084 \u45208 \u50772 \u49845 \u45768 \u45796 . \u49688 \u51652 \u51032  \u47785 \u49548 \u47532 \u50688 \u49845 \u45768 \u45796 . \u47728 \u45712 \u47532  \u51923 \u50500 \u45236 \u47140 \u44256  \u47564 \u46304  \u51068 \u51064 \u45936  \u50780  \u51060 \u51228  \u50752 \u49436  \u47928 \u51228 \u44032  \u46076 . \u50612 \u52264 \u54588  7\u45380 \u51060 \u45208  \u51648 \u45212  \u51068 \u51060 \u51094 \u50500 .\
\uc0\u54924 \u51032 \u49892 \u51060  \u44403 \u50632 \u49845 \u45768 \u45796 .\
\uc0\u50500 \u47924 \u46020  \u47568 \u54616 \u51648  \u50506 \u50520 \u49845 \u45768 \u45796 . \u49828 \u54588 \u52964 \u50640 \u49436  \u47560 \u51648 \u47561  \u47568 \u44620 \u51648  \u55128 \u47084 \u45208 \u50724 \u44256  \u54028 \u51068 \u51060  \u47688 \u52628 \u50632 \u49845 \u45768 \u45796 . \u44536  \u51221 \u51201 \u51060  \u44600 \u50632 \u49845 \u45768 \u45796 . \u49688 \u51652 \u51008  \u45576 \u51012  \u45236 \u47536  \u52292 \u47196  \u51080 \u50632 \u49845 \u45768 \u45796 . \u49552 \u51060  \u53580 \u51060 \u48660  \u50948 \u50640 \u49436  \u48120 \u49464 \u54616 \u44172  \u46504 \u47160 \u49845 \u45768 \u45796 .\
\uc0\u54924 \u51032 \u49892  \u54620 \u53024 \u50640  \u50505 \u50500  \u51080 \u45912  \u48124 \u51456 \u51060  \u51032 \u51088 \u50640 \u49436  \u50526 \u51004 \u47196  \u47800 \u51012  \u44592 \u50872 \u50688 \u49845 \u45768 \u45796 . \u50577 \u49552 \u51012  \u53580 \u51060 \u48660  \u50948 \u50640  \u50732 \u47140 \u46160 \u44256  \u45576 \u51012  \u45236 \u47532 \u44628 \u50520 \u49845 \u45768 \u45796 . 7\u45380  \u51204  \u45236 \u51923 \u51008  \u44163 \u51060  \u51088 \u49888 \u51032  \u50500 \u45236 \u50688 \u49845 \u45768 \u45796 . \u48176  \u49549 \u50640  \u50500 \u51060 \u44032  \u51080 \u45912  \u50500 \u45236 \u50688 \u49845 \u45768 \u45796 . \u44536  \u51068 \u51060  \u44228 \u54925 \u46108  \u44163 \u51060 \u50632 \u49845 \u45768 \u45796 . \u45433 \u52712  \u49549  \u49688 \u51652 \u51032  \u47785 \u49548 \u47532 \u44032  \u44480  \u50504 \u50640 \u49436  \u45796 \u49884  \u50872 \u47160 \u49845 \u45768 \u45796 . \u47728 \u45712 \u47532  \u51923 \u50500 \u45236 \u47140 \u44256  \u47564 \u46304  \u51068 . \u44536  \u47568 \u51060  \u49464 \u49345 \u50640 \u49436  \u44032 \u51109  \u49789 \u44172 , \u45320 \u47924  \u44032 \u48333 \u44172  \u45208 \u50772 \u49845 \u45768 \u45796 . 7\u45380 \u51060 \u46972 \u45716  \u49884 \u44036 \u51060  \u44536  \u54620  \u47928 \u51109  \u50504 \u50640  \u46308 \u50612  \u51080 \u50632 \u49845 \u45768 \u45796 . \u48124 \u51456 \u51032  \u53553 \u51060  \u44403 \u50612 \u51276 \u49845 \u45768 \u45796 . \u45576 \u51060  \u46888 \u44144 \u50892 \u51648 \u45716  \u44163 \u51012  \u45712 \u45180 \u47732 \u49436 \u46020  \u50732 \u47140 \u45796 \u48372 \u51648  \u50506 \u50520 \u49845 \u45768 \u45796 . \u51648 \u44552  \u51060  \u51088 \u47532 \u50640 \u49436  \u47924 \u45320 \u51648 \u47732  \u50504  \u46096 \u49845 \u45768 \u45796 . \u51312 \u44552 \u47564  \u45908 . \u51312 \u44552 \u47564  \u45908  \u48260 \u53608 \u50556  \u54664 \u49845 \u45768 \u45796 .\
\uc0\u51221 \u55148 \u44032  \u45796 \u49884  \u51077 \u51012  \u50676 \u50632 \u49845 \u45768 \u45796 .\
"\uc0\u49688 \u51652 \u50472 , \u54644 \u47749 \u54624  \u44172  \u51080 \u51004 \u47732  \u51648 \u44552  \u54616 \u49464 \u50836 ."\
\uc0\u49688 \u51652 \u51060  \u52380 \u52380 \u55176  \u44256 \u44060 \u47484  \u46308 \u50632 \u49845 \u45768 \u45796 . \u51077 \u49696 \u51060  \u50676 \u47160 \u49845 \u45768 \u45796 . \u44536 \u47084 \u45208  \u45208 \u50728  \u47568 \u51008  \u54644 \u47749 \u51060  \u50500 \u45768 \u50632 \u49845 \u45768 \u45796 .\
"\uc0\u45824 \u54364 \u45784 , \u51200 \u45716  \u45824 \u54364 \u45784 \u51012  \u50948 \u54644 \u49436 ."\
"\uc0\u46096 \u50612 \u50836 ."\
\uc0\u51221 \u55148 \u51032  \u47785 \u49548 \u47532 \u44032  \u51096 \u46972 \u45256 \u49845 \u45768 \u45796 . \u54924 \u51032 \u49892 \u51060  \u45796 \u49884  \u51312 \u50857 \u54644 \u51276 \u49845 \u45768 \u45796 . \u54924 \u51032 \u49892  \u44396 \u49437 \u50640  \u49436  \u51080 \u45912  \u49436 \u50980 \u51060  \u44536  \u47568 \u51012  \u46308 \u50632 \u49845 \u45768 \u45796 . \u49436 \u50980 \u51008  \u45576 \u51012  \u46308 \u50612  \u49688 \u51652 \u51012  \u48148 \u46972 \u48372 \u50520 \u49845 \u45768 \u45796 . 7\u45380  \u46041 \u50504  \u48372 \u51648  \u47803 \u54664 \u45912  \u44536  \u50620 \u44404 \u51060  \u51648 \u44552  \u51060  \u51088 \u47532 \u50640 \u49436  \u47924 \u45320 \u51648 \u44256  \u51080 \u50632 \u49845 \u45768 \u45796 . \u48373 \u49688 \u46972 \u45716  \u44048 \u44033 \u51060  \u50724 \u51648  \u50506 \u50520 \u49845 \u45768 \u45796 . \u44536 \u45285  \u44600 \u44256  \u44596  \u47924 \u50616 \u44032 \u44032  \u45149 \u45208 \u45716  \u44163  \u44057 \u50520 \u49845 \u45768 \u45796 . \u49436 \u50980 \u51008  \u49704 \u51012  \u52380 \u52380 \u55176  \u48201 \u50632 \u49845 \u45768 \u45796 .\
\uc0\u51221 \u55148 \u45716  \u48277 \u47924 \u54016  \u51901 \u51012  \u48148 \u46972 \u48372 \u50520 \u49845 \u45768 \u45796 .\
"\uc0\u48277 \u47924 \u54016 \u50640 \u49436  \u51312 \u52824 \u54644 \u51452 \u49464 \u50836 ."\
\uc0\u49688 \u51652 \u51060  \u51088 \u47532 \u50640 \u49436  \u51068 \u50612 \u45208 \u47140  \u54664 \u49845 \u45768 \u45796 . \u46160  \u48156 \u51060  \u51228 \u45824 \u47196  \u50880 \u51649 \u51060 \u51648  \u50506 \u45716  \u44163 \u52376 \u47100  \u48372 \u50688 \u49845 \u45768 \u45796 . \u46020 \u47581 \u52824 \u46319  \u47928  \u51901 \u51004 \u47196  \u54693 \u54664 \u49845 \u45768 \u45796 . \u44536 \u47088 \u45936  \u48277 \u47924 \u54016  \u51649 \u50896  \u46160  \u47749 \u51060  \u51060 \u48120  \u47928  \u50526 \u50640  \u49436  \u51080 \u50632 \u49845 \u45768 \u45796 . \u44048 \u49324 \u54016 \u46020  \u48373 \u46020 \u50640  \u45208 \u50752  \u51080 \u50632 \u49845 \u45768 \u45796 . \u49688 \u51652 \u51008  \u44536  \u51088 \u47532 \u50640  \u49436 \u49436  \u47688 \u52628 \u50632 \u49845 \u45768 \u45796 .\
\uc0\u51221 \u55148 \u45716  \u44536  \u47784 \u49845 \u51012  \u48148 \u46972 \u48372 \u47732 \u49436  \u46385  \u54620 \u47560 \u46356 \u47484  \u54664 \u49845 \u45768 \u45796 .\
"\uc0\u51060  \u50668 \u51088 \u44032  \u45236  \u47728 \u45712 \u47532 \u47484  \u45236 \u51923 \u50520 \u49845 \u45768 \u45796 ."\
\uc0\u54924 \u51032 \u49892  \u50504 \u50640  \u51080 \u45912  \u49324 \u46988 \u46308 \u51060  \u44536  \u47568 \u51032  \u47924 \u44172 \u47484  \u49548 \u54868 \u54616 \u45716  \u45936  \u49884 \u44036 \u51060  \u44152 \u47160 \u49845 \u45768 \u45796 . \u51076 \u50896 \u46308 \u51060  \u49436 \u47196 \u47484  \u48148 \u46972 \u48372 \u50520 \u44256 , \u47751 \u47751 \u51008  \u49688 \u51652 \u51012  \u48372 \u50520 \u49845 \u45768 \u45796 . \u49688 \u51652 \u51008  \u49884 \u49440 \u51012  \u48155 \u51648  \u47803 \u54616 \u44256  \u45576 \u51012  \u45236 \u47160 \u49845 \u45768 \u45796 .\
\uc0\u48124 \u51456 \u51060  \u51088 \u47532 \u50640 \u49436  \u51068 \u50612 \u45228 \u49845 \u45768 \u45796 . \u53580 \u51060 \u48660  \u50948 \u50640  \u50732 \u47140 \u46160 \u50632 \u45912  \u49552 \u51012  \u44144 \u46160 \u44256 , \u54924 \u51032 \u49892 \u51012  \u45208 \u44052 \u49845 \u45768 \u45796 . \u50612 \u47672 \u45768 \u46020 , \u49688 \u51652 \u46020 , \u51076 \u50896 \u46308 \u46020  \u48148 \u46972 \u48372 \u51648  \u50506 \u50520 \u49845 \u45768 \u45796 . \u44536 \u45285  \u45208 \u44052 \u49845 \u45768 \u45796 . \u48736 \u47480  \u44152 \u51020 \u51060 \u50632 \u49845 \u45768 \u45796 . \u48373 \u46020  \u45149 \u50640 \u49436  \u50648 \u47532 \u48288 \u51060 \u53552 \u47484  \u53460 \u49845 \u45768 \u45796 . \u47928 \u51060  \u45803 \u55176 \u47732 \u49436  \u44148 \u47932  \u47196 \u48708 \u44032  \u48372 \u50688 \u49845 \u45768 \u45796 . \u48124 \u51456 \u51008  \u44536  \u50504 \u50640 \u49436  \u54620  \u49552 \u51004 \u47196  \u48317 \u51012  \u51674 \u50632 \u49845 \u45768 \u45796 . \u45433 \u52712 \u50640 \u49436  \u46308 \u47160 \u45912  \u44536  \u47785 \u49548 \u47532 \u44032  \u50500 \u51649 \u46020  \u44480  \u50504 \u50640  \u45224 \u50500  \u51080 \u50632 \u49845 \u45768 \u45796 . \u47728 \u45712 \u47532  \u51923 \u50500 \u45236 \u47140 \u44256  \u47564 \u46304  \u51068 . 7\u45380  \u46041 \u50504  \u44536  \u47568 \u51012  \u50500 \u47924 \u46020  \u47792 \u46992 \u49845 \u45768 \u45796 .\
\uc0\u44536 \u47532 \u44256  \u49436 \u50980 \u51008  \u44536 \u44163 \u51012  \u54844 \u51088  \u44048 \u45817 \u54616 \u47728  \u49332 \u50500 \u50772 \u49845 \u45768 \u45796 .\
\uc0\u50648 \u47532 \u48288 \u51060 \u53552  \u47928 \u51060  \u50676 \u47160 \u49845 \u45768 \u45796 . \u48124 \u51456 \u51008  \u47196 \u48708  \u54620 \u48373 \u54032 \u50640  \u51104 \u49884  \u49456 \u49845 \u45768 \u45796 . \u50612 \u46356 \u47196  \u44032 \u50556  \u54624 \u51648  \u47792 \u46992 \u49845 \u45768 \u45796 . \u48156 \u51060  \u50880 \u51649 \u51060 \u51648  \u50506 \u50520 \u49845 \u45768 \u45796 . \u44536 \u47084 \u45796  \u54648 \u46300 \u54256 \u51012  \u44732 \u45256 \u49845 \u45768 \u45796 . \u49436 \u50980 \u51032  \u48264 \u54840 \u47484  \u52286 \u50520 \u49845 \u45768 \u45796 . \u51204 \u54868 \u47484  \u44152 \u50632 \u49845 \u45768 \u45796 . \u49888 \u54840 \u44032  \u50872 \u47160 \u49845 \u45768 \u45796 . \u50500 \u47924 \u46020  \u48155 \u51648  \u50506 \u50520 \u49845 \u45768 \u45796 . \u48124 \u51456 \u51008  \u54648 \u46300 \u54256 \u51012  \u45236 \u47140 \u45459 \u51004 \u47728  \u52380 \u52380 \u55176  \u44148 \u47932  \u48150 \u51004 \u47196  \u45208 \u50772 \u49845 \u45768 \u45796 . \u48148 \u44645  \u44277 \u44592 \u44032  \u52264 \u44032 \u50912 \u49845 \u45768 \u45796 . \u48124 \u51456 \u51008  \u44536  \u52264 \u44032 \u50880 \u51012  \u47582 \u51004 \u47728  \u54620 \u46041 \u50504  \u49436  \u51080 \u50632 \u49845 \u45768 \u45796 . \u49436 \u50980 \u54620 \u53580  \u44032 \u50556  \u54664 \u49845 \u45768 \u45796 . \u50724 \u45720 \u51008  \u44032 \u50556  \u54664 \u49845 \u45768 \u45796 . \u45796 \u51020 \u51004 \u47196  \u48120 \u47336 \u47732  \u45796 \u49884  7\u45380 \u51060  \u46112  \u49688 \u46020  \u51080 \u50632 \u49845 \u45768 \u45796 .\
