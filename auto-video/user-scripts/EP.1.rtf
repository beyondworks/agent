DNA \uc0\u44208 \u44284 \u47484  \u54869 \u51064 \u54620  \u45796 \u51020  \u45216  \u50500 \u52840 , \u51221 \u55148 \u45716  \u54217 \u49548 \u48372 \u45796  \u54620  \u49884 \u44036  \u51068 \u52237  \u49324 \u47924 \u49892 \u50640  \u45208 \u50772 \u49845 \u45768 \u45796 . \u50500 \u51649  \u51649 \u50896 \u46308 \u51060  \u52636 \u44540 \u54616 \u44592  \u51204 \u51060 \u50632 \u44256 , \u44148 \u47932  \u50504 \u51008  \u51312 \u50857 \u54664 \u49845 \u45768 \u45796 . \u51221 \u55148 \u45716  \u52964 \u54588  \u54620  \u51092 \u51012  \u49552 \u50640  \u46308 \u44256  \u52285 \u44032 \u50640  \u49436 \u49436  \u46020 \u49884 \u51032  \u51060 \u47480  \u50500 \u52840 \u51012  \u48148 \u46972 \u48372 \u50520 \u49845 \u45768 \u45796 . \u44208 \u44284 \u51648 \u47484  \u51069 \u51008  \u49692 \u44036 \u48512 \u53552  \u51648 \u44552 \u44620 \u51648 , \u47672 \u47551 \u49549 \u50640 \u49436  \u54620  \u44032 \u51648  \u49373 \u44033 \u51060  \u44228 \u49549  \u47604 \u46028 \u50520 \u49845 \u45768 \u45796 . \u49436 \u50980 \u51060  \u51221 \u47568 \u47196  \u50500 \u47924 \u44163 \u46020  \u54616 \u51648  \u50506 \u50520 \u45796 \u47732 , \u45572 \u44400 \u44032  \u44536  \u51068 \u51012  \u47564 \u46304  \u44163 \u51077 \u45768 \u45796 . \u44536  \u45572 \u44400 \u44032 \u44032  \u45572 \u44396 \u51064 \u51648 , \u51221 \u55148 \u45716  \u51060 \u48120  \u50508 \u44256  \u51080 \u50632 \u49845 \u45768 \u45796 . \u45796 \u47564  \u45712 \u45196 \u51060 \u45208  \u51032 \u49900 \u47564 \u51004 \u47196 \u45716  \u50500 \u47924 \u44163 \u46020  \u54624  \u49688  \u50630 \u50632 \u49845 \u45768 \u45796 . \u48152 \u48149 \u54624  \u49688  \u50630 \u45716  \u44163 \u51060  \u54596 \u50836 \u54664 \u49845 \u45768 \u45796 . \u49688 \u51652 \u51060  \u46244 \u51665 \u51012  \u49688  \u50630 \u45716  \u44163 \u51060 . \u52964 \u54588 \u44032  \u52380 \u52380 \u55176  \u49885 \u50632 \u51648 \u47564  \u51221 \u55148 \u45716  \u47560 \u49884 \u51648  \u50506 \u50520 \u49845 \u45768 \u45796 . \u52285 \u48150 \u47564  \u48148 \u46972 \u48372 \u50520 \u49845 \u45768 \u45796 .\
\uc0\u51221 \u55148 \u45716  \u54648 \u46300 \u54256 \u51012  \u44732 \u45256 \u49845 \u45768 \u45796 . \u50724 \u47000  \u50508 \u44256  \u51648 \u45240  \u45432 \u47924 \u49324 \u50640 \u44172  \u47928 \u51088 \u47484  \u48372 \u45256 \u49845 \u45768 \u45796 . \u44048 \u49324 \u54016  \u52636 \u49888 \u51060 \u50632 \u44256 , \u44592 \u50629  \u45236 \u48512  \u48708 \u50948  \u49324 \u44148 \u51012  \u50668 \u47084  \u48264  \u45796 \u47364 \u48376  \u49324 \u46988 \u51060 \u50632 \u49845 \u45768 \u45796 . \u44060 \u51064 \u51201 \u51004 \u47196  \u47564 \u45208 \u51088 \u44256 , \u51312 \u50857 \u54620  \u51088 \u47532 \u50668 \u50556  \u54620 \u45796 \u44256 . \u51060 \u50976 \u45716  \u51201 \u51648  \u50506 \u50520 \u49845 \u45768 \u45796 .\
\uc0\u50724 \u51204 \u51060  \u45149 \u45208 \u44592  \u51204 \u50640  \u45432 \u47924 \u49324 \u50640 \u44172 \u49436  \u50672 \u46973 \u51060  \u50772 \u49845 \u45768 \u45796 . \u46160  \u49324 \u46988 \u51008  \u54924 \u49324  \u44540 \u52376  \u51312 \u50857 \u54620  \u49885 \u45817 \u50640 \u49436  \u47560 \u51452  \u50505 \u50520 \u49845 \u45768 \u45796 . \u51221 \u55148 \u45716  7\u45380  \u51204  \u54945 \u47161  \u49324 \u44148 \u51032  \u44060 \u50836 \u47484  \u44036 \u47029 \u55176  \u49444 \u47749 \u54664 \u49845 \u45768 \u45796 . \u44536 \u47532 \u44256  \u45817 \u49884  \u44208 \u51116 \u46972 \u51064 \u44284  \u49436 \u48260  \u44592 \u47197 \u51012  \u48373 \u44396 \u54644 \u49436  \u45796 \u49884  \u46308 \u50668 \u45796 \u48380  \u49688  \u51080 \u45716 \u51648  \u47932 \u50632 \u49845 \u45768 \u45796 . \u45432 \u47924 \u49324 \u45716  \u51221 \u55148 \u51032  \u47568 \u51012  \u45130 \u51648  \u50506 \u44256  \u45149 \u44620 \u51648  \u46308 \u50632 \u49845 \u45768 \u45796 . \u51104 \u49884  \u49373 \u44033 \u54616 \u45796 \u44032  \u51077 \u51012  \u50676 \u50632 \u49845 \u45768 \u45796 .\
"\uc0\u49436 \u48260  \u48373 \u44396 \u45716  \u51204 \u49328 \u54016 \u50640 \u49436  \u54644 \u50556  \u54616 \u45716  \u51068 \u51060 \u44256 , \u44536  \u44208 \u44284 \u47932 \u51012  \u50612 \u46523 \u44172  \u54644 \u49437 \u54616 \u45712 \u45264 \u44032  \u44288 \u44148 \u51077 \u45768 \u45796 . \u48373 \u44396  \u51088 \u52404 \u45716  \u44592 \u49696 \u51201 \u51004 \u47196  \u44032 \u45733 \u54633 \u45768 \u45796 . \u45796 \u47564  \u51060 \u48120  \u50756 \u51204 \u55176  \u49325 \u51228 \u46108  \u54028 \u51068 \u51008  \u49332 \u50500 \u45208 \u51648  \u50506 \u51012  \u49688 \u46020  \u51080 \u50612 \u50836 ."\
"\uc0\u51068 \u48512 \u46972 \u46020  \u49332 \u50500 \u45208 \u47732  \u46076 \u50836 ."\
\uc0\u51221 \u55148 \u51032  \u47785 \u49548 \u47532 \u44032  \u45800 \u45800 \u54664 \u49845 \u45768 \u45796 . \u45432 \u47924 \u49324 \u45716  \u44256 \u44060 \u47484  \u45124 \u45909 \u50688 \u49845 \u45768 \u45796 .\
"\uc0\u51228 \u44032  \u50500 \u45716  \u54252 \u47116 \u49885  \u51204 \u47928 \u44032 \u47484  \u48537 \u51060 \u44192 \u49845 \u45768 \u45796 . \u45824 \u49888  \u51060  \u51068 \u51008  \u51648 \u44552  \u45817 \u51109  \u49688 \u51652 \u50472 \u54620 \u53580  \u50508 \u47532 \u51648  \u50506 \u45716  \u44172  \u51339 \u51012  \u44163  \u44057 \u49845 \u45768 \u45796 ."\
"\uc0\u45817 \u50672 \u54616 \u51424 ."\
\uc0\u44536 \u45216  \u50724 \u54980  \u45734 \u44172 , \u49436 \u48260  \u48373 \u44396  \u51089 \u50629 \u51060  \u49884 \u51089 \u46096 \u49845 \u45768 \u45796 . \u51221 \u55148 \u45716  \u51204 \u49328 \u54016 \u50640  \u45432 \u47924 \u49324 \u44032  \u46041 \u54665 \u54620 \u45796 \u45716  \u44163 \u47564  \u50508 \u47160 \u44256 , \u44396 \u52404 \u51201 \u51064  \u51060 \u50976 \u45716  \u47568 \u54616 \u51648  \u50506 \u50520 \u49845 \u45768 \u45796 . \u49688 \u51652 \u50640 \u44172 \u45716  \u51068 \u49345 \u51201 \u51064  \u50629 \u47924  \u51648 \u49884 \u47564  \u51204 \u45804 \u54664 \u49845 \u45768 \u45796 . \u50500 \u47924 \u44163 \u46020  \u45804 \u46972 \u51652  \u44172  \u50630 \u45716  \u44163 \u52376 \u47100 .\
\uc0\u54620 \u54200  \u44057 \u51008  \u45216  \u50724 \u54980 , \u48124 \u51456 \u51008  \u52264 \u47484  \u47792 \u50500  \u50724 \u47000 \u46108  \u46041 \u45348 \u47196  \u54693 \u54664 \u49845 \u45768 \u45796 . \u49436 \u50980 \u44284  \u54632 \u44760  \u49332 \u50520 \u45912  \u49888 \u54844 \u51665 \u51060  \u51080 \u45912  \u44275 \u51060 \u50632 \u49845 \u45768 \u45796 . \u51648 \u44552 \u51008  \u45796 \u47480  \u49324 \u46988 \u51060  \u49332 \u44256  \u51080 \u51012  \u44163 \u51060 \u50632 \u49845 \u45768 \u45796 . \u44148 \u47932  \u51088 \u52404 \u44032  \u48148 \u45068 \u50632 \u51012  \u49688 \u46020  \u51080 \u50632 \u49845 \u45768 \u45796 . \u44536 \u45285  \u44536  \u46041 \u45348 \u47484 , \u44536  \u44264 \u47785 \u51012  \u54620  \u48264  \u44151 \u44256  \u49910 \u50632 \u49845 \u45768 \u45796 . \u50612 \u46356 \u49436  \u47956 \u44032 \u44032  \u51096 \u47803 \u46108  \u44163 \u51064 \u51648  \u50508 \u44256  \u49910 \u50632 \u49845 \u45768 \u45796 . \u50500 \u45768 , \u51096 \u47803 \u46108  \u44172  \u47582 \u45716 \u51648  \u50500 \u45772 \u51648 \u47484  \u51228 \u45824 \u47196  \u48372 \u44256  \u49910 \u50632 \u49845 \u45768 \u45796 .\
\uc0\u44264 \u47785  \u51077 \u44396 \u50640  \u52264 \u47484  \u49464 \u50864 \u44256  \u45236 \u47160 \u49845 \u45768 \u45796 . \u44592 \u50613  \u49549 \u51032  \u47784 \u49845 \u44284  \u53356 \u44172  \u45796 \u47476 \u51648  \u50506 \u50520 \u49845 \u45768 \u45796 . \u45796 \u49464 \u45824  \u51452 \u53469 \u46308 \u51060  \u45208 \u46976 \u55176  \u49436  \u51080 \u50632 \u44256 , \u44264 \u47785  \u45149  \u51089 \u51008  \u49800 \u54140 \u47560 \u53011 \u46020  \u44536 \u45824 \u47196 \u50688 \u49845 \u45768 \u45796 . \u48124 \u51456 \u51008  \u52380 \u52380 \u55176  \u44152 \u50632 \u49845 \u45768 \u45796 . \u50696 \u51204 \u50640  \u49436 \u50980 \u44284  \u51109 \u51012  \u48372 \u47084  \u44032 \u45912  \u44600 \u51060 \u50632 \u49845 \u45768 \u45796 . \u53748 \u44540  \u54980  \u49552 \u51012  \u51105 \u44256  \u44152 \u50632 \u45912  \u44592 \u50613 \u51060  \u51080 \u50632 \u49845 \u45768 \u45796 . \u44536 \u46412  \u49436 \u50980 \u51008  \u44152 \u51004 \u47732 \u49436  \u44536 \u45216  \u51080 \u50632 \u45912  \u51068 \u46308 \u51012  \u51060 \u50556 \u44592 \u54616 \u44260  \u54664 \u49845 \u45768 \u45796 . \u54924 \u49324 \u50640 \u49436  \u51060 \u47088  \u51068 \u51060  \u51080 \u50632 \u45796 , \u51200  \u44032 \u44172  \u49352 \u47196  \u49373 \u44596  \u44163  \u44057 \u45796 , \u50724 \u45720  \u47952  \u47673 \u44256  \u49910 \u45796 . \u49324 \u49548 \u54620  \u51060 \u50556 \u44592 \u46308 \u51060 \u50632 \u49845 \u45768 \u45796 . \u44536  \u49324 \u49548 \u54632 \u51060  \u51648 \u44552 \u51008  \u45320 \u47924  \u44480 \u54616 \u44172  \u45712 \u44788 \u51276 \u49845 \u45768 \u45796 . \u44536 \u46412  \u48124 \u51456 \u51008  \u44536  \u51060 \u50556 \u44592 \u46308 \u51012  \u50620 \u47560 \u45208  \u51228 \u45824 \u47196  \u46308 \u50632 \u51012 \u44620 \u50836 . \u44536 \u45285  \u55128 \u47140 \u46307 \u51652  \u50506 \u50520 \u51012 \u44620 \u50836 . \u44592 \u50613 \u51060  \u51221 \u54869 \u54616 \u51648  \u50506 \u45796 \u45716  \u44163 \u51060 , \u44536  \u51088 \u52404 \u47196  \u51060 \u48120  \u45813 \u51064  \u44163  \u44057 \u50520 \u49845 \u45768 \u45796 .\
\uc0\u49888 \u54844 \u51665  \u50526 \u50640  \u47688 \u52628 \u50632 \u49845 \u45768 \u45796 . \u44148 \u47932 \u51008  \u44536 \u45824 \u47196 \u50688 \u44256  1\u52789  \u50864 \u54200 \u54632  \u50948 \u52824 \u46020  \u44592 \u50613 \u44284  \u44057 \u50520 \u49845 \u45768 \u45796 . \u48124 \u51456 \u51008  \u44536  \u50526 \u50640  \u49436 \u49436  \u54620 \u52280  \u49373 \u44033 \u54664 \u49845 \u45768 \u45796 . \u49436 \u50980 \u51008  \u50780  \u50500 \u47924  \u47568 \u46020  \u54616 \u51648  \u50506 \u44256  \u45208 \u44036  \u44163 \u51068 \u44620 \u50836 . \u50613 \u50872 \u54616 \u47732  \u50613 \u50872 \u54616 \u45796 \u44256  \u54664 \u50612 \u50556  \u54664 \u49845 \u45768 \u45796 . \u50500 \u51060 \u44032  \u51080 \u51004 \u47732  \u51080 \u45796 \u44256  \u54664 \u50612 \u50556  \u54664 \u49845 \u45768 \u45796 . \u44536 \u47088 \u45936  \u49436 \u50980 \u51008  \u50500 \u47924 \u44163 \u46020  \u47568 \u54616 \u51648  \u50506 \u50520 \u49845 \u45768 \u45796 . \u44536  \u52840 \u47925 \u51060  \u45817 \u49884 \u50640 \u45716  \u52404 \u45392 \u52376 \u47100  \u48372 \u50688 \u49845 \u45768 \u45796 . \u51648 \u44552 \u51008  \u45804 \u46992 \u49845 \u45768 \u45796 . \u51648 \u44552 \u51008  \u44536  \u52840 \u47925 \u51060  \u50724 \u55176 \u47140  \u46160 \u47140 \u50880 \u52376 \u47100  \u45712 \u44788 \u51276 \u49845 \u45768 \u45796 . \u47568 \u51012  \u54664 \u45796 \u44032  \u45908  \u53360  \u47924 \u50616 \u44032 \u44032  \u45934 \u52432 \u50732  \u44163 \u51060  \u46160 \u47140 \u50892 \u49436 , \u47568 \u54616 \u51648  \u50506 \u51008  \u44163 \u51008  \u50500 \u45776 \u44620 . \u51060 \u48120  \u45320 \u47924  \u47566 \u51008  \u44163 \u51060  \u51088 \u49888 \u50640 \u44172  \u48520 \u47532 \u54616 \u44172  \u49939 \u50668  \u51080 \u50612 \u49436 , \u47568 \u51012  \u44732 \u45236 \u48420 \u51088  \u50500 \u47924 \u46020  \u46308 \u50612 \u51452 \u51648  \u50506 \u51012  \u44163 \u51060 \u46972 \u44256  \u49373 \u44033 \u54620  \u44163 \u51008  \u50500 \u45776 \u44620 . \u48124 \u51456 \u51008  \u44148 \u47932  \u50526 \u50640 \u49436  \u52380 \u52380 \u55176  \u47800 \u51012  \u46028 \u47160 \u49845 \u45768 \u45796 . \u49552 \u51060  \u51452 \u47672 \u45768  \u50504 \u50640 \u49436  \u51452 \u47673 \u51012  \u51536 \u50632 \u49845 \u45768 \u45796 . \u44536  \u49373 \u44033 \u51060  \u47582 \u45716  \u44163 \u51060 \u46972 \u47732 , \u44032 \u51109  \u47676 \u51200  \u48127 \u50612 \u51500 \u50612 \u50556  \u54624  \u49324 \u46988 \u51008  \u51088 \u49888 \u51060 \u50632 \u49845 \u45768 \u45796 .\
\uc0\u49324 \u55128  \u46244 , \u54252 \u47116 \u49885  \u51204 \u47928 \u44032 \u44032  \u44208 \u44284 \u47932 \u51012  \u44032 \u51256 \u50772 \u49845 \u45768 \u45796 .\
\uc0\u51221 \u55148 \u45716  \u45432 \u47924 \u49324 \u50752  \u54632 \u44760  \u48373 \u44396 \u46108  \u54028 \u51068  \u47785 \u47197 \u51012  \u49332 \u54216 \u49845 \u45768 \u45796 . \u51204 \u48512 \u44032  \u49332 \u50500 \u45212  \u44163 \u51008  \u50500 \u45768 \u50632 \u49845 \u45768 \u45796 . \u50756 \u51204 \u55176  \u45934 \u50612 \u50416 \u51064  \u54028 \u51068 \u46308 \u51008  \u55124 \u51201 \u51312 \u52264  \u50630 \u50632 \u49845 \u45768 \u45796 . \u54616 \u51648 \u47564  \u51068 \u48512 \u44032  \u45224 \u50500  \u51080 \u50632 \u49845 \u45768 \u45796 . \u51221 \u55148 \u45716  \u54028 \u51068 \u51012  \u50676 \u50632 \u49845 \u45768 \u45796 .\
\uc0\u44144 \u47000  \u44592 \u47197  \u51312 \u44033 \u46308 \u51060 \u50632 \u49845 \u45768 \u45796 . \u45216 \u51676 \u50752  \u44552 \u50529 , \u44228 \u51340  \u48264 \u54840 \u51032  \u51068 \u48512 \u44032  \u48373 \u44396 \u46104 \u50612  \u51080 \u50632 \u49845 \u45768 \u45796 . \u44536  \u44592 \u47197 \u46308 \u51008  \u49436 \u50980 \u51032  \u51060 \u47492  \u50500 \u47000  \u50732 \u46972 \u50752  \u51080 \u50632 \u49845 \u45768 \u45796 . \u54616 \u51648 \u47564  \u48373 \u44396 \u46108  \u45936 \u51060 \u53552  \u50504 \u50640 \u45716  \u44536 \u44163 \u47564 \u51060  \u50500 \u45768 \u50632 \u49845 \u45768 \u45796 . \u45817 \u49884  \u44208 \u51116  \u44284 \u51221 \u50640 \u49436  \u49373 \u49457 \u46108  \u49849 \u51064  \u47196 \u44536 \u44032  \u51068 \u48512  \u49332 \u50500  \u51080 \u50632 \u49845 \u45768 \u45796 . \u51221 \u55148 \u45716  \u44536  \u54028 \u51068 \u51012  \u50676 \u47728  \u52380 \u52380 \u55176  \u45236 \u50857 \u51012  \u51069 \u50612  \u45236 \u47140 \u44052 \u49845 \u45768 \u45796 . \u51069 \u51012 \u49688 \u47197  \u49552 \u51060  \u52264 \u44032 \u50892 \u51276 \u49845 \u45768 \u45796 . \u51069 \u51012 \u49688 \u47197  \u49900 \u51109 \u51060  \u45712 \u47532 \u44172 , \u44536 \u47084 \u45208  \u45908  \u53356 \u44172  \u46832 \u45716  \u44163  \u44057 \u50520 \u49845 \u45768 \u45796 .\
\uc0\u51221 \u55148 \u45716  \u44536  \u48512 \u48516 \u51012  \u45432 \u47924 \u49324 \u50640 \u44172  \u48372 \u50668 \u51452 \u50632 \u49845 \u45768 \u45796 .\
"\uc0\u51060 \u44172  \u49436 \u50980 \u50472  \u47749 \u51032 \u47196  \u46108  \u44032 \u51676  \u49569 \u44552  \u45236 \u50669 \u51060 \u44256 , \u51060  \u49849 \u51064  \u47196 \u44536 \u44032  \u45817 \u49884 \u50640  \u44208 \u51116 \u47484  \u50732 \u47536  \u49324 \u46988 \u51032  \u44228 \u51221 \u51060 \u50640 \u50836 ."\
\uc0\u45432 \u47924 \u49324 \u44032  \u54868 \u47732 \u51012  \u46308 \u50668 \u45796 \u48372 \u50520 \u49845 \u45768 \u45796 .\
"\uc0\u44228 \u51221  \u50500 \u51060 \u46356 \u44032  \u46888 \u45348 \u50836 . \u45572 \u44396  \u44228 \u51221 \u51064 \u51648  \u54869 \u51064 \u54624  \u49688  \u51080 \u49845 \u45768 \u44620 ?"\
\uc0\u51221 \u55148 \u45716  \u44536  \u50500 \u51060 \u46356 \u47484  \u48372 \u45716  \u49692 \u44036  \u49704 \u51012  \u54620  \u48264  \u47688 \u52628 \u50632 \u49845 \u45768 \u45796 . \u51060 \u48120  \u50508 \u44256  \u51080 \u45912  \u44163 \u51060 \u50632 \u51648 \u47564 , \u54868 \u47732  \u50948 \u50640 \u49436  \u54876 \u51088 \u47196  \u54869 \u51064 \u46104 \u45716  \u44163 \u51008  \u45804 \u46992 \u49845 \u45768 \u45796 . \u52380 \u52380 \u55176  \u51077 \u51012  \u50676 \u50632 \u49845 \u45768 \u45796 .\
"\uc0\u49688 \u51652 \u50472  \u44228 \u51221 \u51060 \u50640 \u50836 ."\
\uc0\u45432 \u47924 \u49324 \u44032  \u44256 \u44060 \u47484  \u46308 \u50632 \u49845 \u45768 \u45796 . \u46160  \u49324 \u46988 \u51008  \u51104 \u49884  \u47568 \u50630 \u51060  \u49436 \u47196 \u47484  \u48148 \u46972 \u48372 \u50520 \u49845 \u45768 \u45796 . \u51221 \u55148 \u45716  \u49552  \u50504 \u51032  \u47560 \u50864 \u49828 \u47484  \u52380 \u52380 \u55176  \u45236 \u47140 \u45459 \u50520 \u49845 \u45768 \u45796 .\
"\uc0\u45572 \u44400 \u44032  \u49436 \u50980 \u50472 \u54620 \u53580  \u51396 \u47484  \u46244 \u51665 \u50612 \u50444 \u50912 \u49845 \u45768 \u45796 ."\
\uc0\u45432 \u47924 \u49324 \u44032  \u51312 \u50857 \u55176  \u47568 \u54664 \u49845 \u45768 \u45796 . \u51221 \u55148 \u45716  \u45824 \u45813 \u54616 \u51648  \u50506 \u50520 \u49845 \u45768 \u45796 . \u45824 \u45813 \u51060  \u54596 \u50836 \u54616 \u51648  \u50506 \u50520 \u49845 \u45768 \u45796 . \u51060 \u48120  \u54869 \u51064 \u46108  \u44163 \u51060 \u50632 \u51004 \u45768 \u44620 \u50836 . \u45796 \u47564  \u44536 \u44163 \u51012  \u47568 \u47196  \u44732 \u45236 \u45716  \u49692 \u44036 , 15\u45380  \u46041 \u50504  \u50694 \u50640  \u51080 \u50632 \u45912  \u49324 \u46988 \u50640  \u45824 \u54620  \u47560 \u51648 \u47561  \u48127 \u51020 \u51060  \u50756 \u51204 \u55176  \u45130 \u50612 \u51652 \u45796 \u45716  \u44163 \u51012  \u50508 \u44256  \u51080 \u50632 \u49845 \u45768 \u45796 . \u51221 \u55148 \u45716  \u45576 \u51012  \u44048 \u50520 \u45796 \u44032  \u52380 \u52380 \u55176  \u46516 \u49845 \u45768 \u45796 .\
"\uc0\u45908  \u47784 \u50500 \u50556  \u54644 \u50836 . \u51060 \u44163 \u47564 \u51004 \u47196 \u45716  \u48512 \u51313 \u54633 \u45768 \u45796 . \u49688 \u51652 \u50472 \u44032  \u51649 \u51217  \u51064 \u51221 \u54616 \u44172  \u47564 \u46308 \u50612 \u50556  \u54644 \u50836 ."\
\uc0\u45432 \u47924 \u49324 \u44032  \u44256 \u44060 \u47484  \u45124 \u45909 \u50688 \u49845 \u45768 \u45796 .\
"\uc0\u50612 \u46500  \u48169 \u49885 \u51012  \u49373 \u44033 \u54616 \u44256  \u44228 \u49901 \u45768 \u44620 ?"\
\uc0\u51221 \u55148 \u45716  \u51104 \u49884  \u52840 \u47925 \u54664 \u49845 \u45768 \u45796 . \u52285 \u48150 \u51004 \u47196  \u51200 \u45377  \u48731 \u51060  \u44592 \u50872 \u44256  \u51080 \u50632 \u49845 \u45768 \u45796 . \u49324 \u47924 \u49892  \u50504 \u51060  \u51312 \u50857 \u54664 \u49845 \u45768 \u45796 . \u51221 \u55148 \u45716  \u51312 \u50857 \u55176 , \u44536 \u47084 \u45208  \u45800 \u45800 \u54616 \u44172  \u47568 \u54664 \u49845 \u45768 \u45796 .\
"\uc0\u49688 \u51652 \u50472  \u51077 \u51004 \u47196  \u47568 \u54616 \u44172  \u47564 \u46308 \u50612 \u50556  \u54644 \u50836 . \u44536  \u47568 \u51012  \u45236 \u44032  \u51649 \u51217  \u46308 \u50612 \u50556  \u54633 \u45768 \u45796 ."\
\uc0\u45432 \u47924 \u49324 \u45716  \u47924 \u50616 \u44032 \u47484  \u49373 \u44033 \u54616 \u45716  \u54364 \u51221 \u51004 \u47196  \u49436 \u47448 \u52384 \u51012  \u45934 \u50632 \u49845 \u45768 \u45796 . \u51221 \u55148 \u45716  \u51088 \u47532 \u50640 \u49436  \u51068 \u50612 \u45208  \u45796 \u49884  \u52285 \u44032 \u47196  \u44052 \u49845 \u45768 \u45796 . \u49436 \u47448 \u52384 \u51012  \u45934 \u51004 \u47728  \u49549 \u51004 \u47196  \u51473 \u50620 \u44144 \u47160 \u49845 \u45768 \u45796 . \u51060 \u51228  \u45224 \u51008  \u44148  \u45348  \u51077 \u51004 \u47196  \u47568 \u54616 \u44172  \u47564 \u46300 \u45716  \u44163 \u51060 \u50556 . 15\u45380  \u46041 \u50504  \u45236  \u50694 \u50640 \u49436  \u45208 \u47484  \u51060 \u50857 \u54664 \u45912  \u44536  \u51077 \u51004 \u47196 .\
\uc0\u48148 \u44645 \u50640 \u45716  \u46020 \u49884 \u51032  \u48520 \u48731 \u51060  \u54616 \u45208 \u50473  \u53020 \u51648 \u44592  \u49884 \u51089 \u54664 \u49845 \u45768 \u45796 . \u51221 \u55148 \u45716  \u44536 \u44163 \u51012  \u48148 \u46972 \u48372 \u47732 \u49436  \u51060  \u51068 \u51060  \u50612 \u46356 \u44620 \u51648  \u44032 \u50556  \u45149 \u45216 \u51648  \u49373 \u44033 \u54664 \u49845 \u45768 \u45796 . \u49688 \u51652 \u51060  \u44060 \u51077 \u46104 \u50612  \u51080 \u45796 \u45716  \u44163 \u51012  \u50508 \u50520 \u49845 \u45768 \u45796 . \u49688 \u51652 \u51032  \u44228 \u51221 \u51060  \u44536  \u51068 \u50640  \u50672 \u44208 \u46104 \u50612  \u51080 \u45796 \u45716  \u44163 \u51012  \u54869 \u51064 \u54664 \u49845 \u45768 \u45796 . \u54616 \u51648 \u47564  \u44536 \u44163 \u47564 \u51004 \u47196 \u45716  \u50500 \u51649  \u48512 \u51313 \u54664 \u49845 \u45768 \u45796 . \u45908  \u51649 \u51217 \u51201 \u51060 \u44256 , \u45908  \u49440 \u47749 \u54620  \u44163 \u51060  \u54596 \u50836 \u54664 \u49845 \u45768 \u45796 . \u49688 \u51652 \u51060  \u49828 \u49828 \u47196  \u48512 \u51221 \u54624  \u49688  \u50630 \u45716  \u44163 \u51060 . 15\u45380 \u51060 \u50632 \u49845 \u45768 \u45796 . 15\u45380 \u51012  \u47588 \u51068  \u50694 \u50640 \u49436  \u48372 \u50520 \u45716 \u45936 , \u44536  \u50504 \u50640  \u51060 \u47088  \u44163 \u51060  \u51080 \u50632 \u49845 \u45768 \u45796 . \u51221 \u55148 \u45716  \u44032 \u49844  \u50504 \u50640 \u49436  \u47956 \u44032 \u44032  \u49436 \u45720 \u54616 \u44172  \u44403 \u50612 \u51648 \u45716  \u44163 \u51012  \u45712 \u44808 \u49845 \u45768 \u45796 . \u48176 \u49888 \u51060 \u46972 \u45716  \u44048 \u44033 \u51008  \u51060 \u47088  \u44163 \u51060 \u50632 \u49845 \u45768 \u45796 . \u48516 \u45432 \u52376 \u47100  \u46888 \u44161 \u51648  \u50506 \u50520 \u49845 \u45768 \u45796 . \u50724 \u55176 \u47140  \u52380 \u52380 \u55176 , \u50500 \u51452  \u52264 \u44049 \u44172  \u44032 \u46972 \u50505 \u50520 \u49845 \u45768 \u45796 .\
\uc0\u51221 \u55148 \u45716  \u54648 \u46300 \u54256 \u51012  \u44732 \u45256 \u49845 \u45768 \u45796 . \u50724 \u47000  \u50508 \u44256  \u51648 \u45240  \u50808 \u48512  \u51312 \u49324 \u54016  \u48264 \u54840 \u47484  \u52286 \u51004 \u47732 \u49436 , \u51312 \u50857 \u55176  \u44208 \u49900 \u54664 \u49845 \u45768 \u45796 . \u50500 \u51649  \u45149 \u45208 \u51648  \u50506 \u50520 \u49845 \u45768 \u45796 . \u51060 \u51228 \u48512 \u53552 \u44032  \u49884 \u51089 \u51060 \u50632 \u49845 \u45768 \u45796 . \u49688 \u51652 \u51060  \u51088 \u49888 \u51032  \u51077 \u51004 \u47196  \u47568 \u54616 \u44172  \u47564 \u46308  \u44163 \u51060 \u50632 \u49845 \u45768 \u45796 . \u44536 \u47532 \u44256  \u44536  \u47568 \u51012  \u51649 \u51217  \u46308 \u51012  \u44163 \u51060 \u50632 \u49845 \u45768 \u45796 . \u44536 \u47000 \u50556 \u47564  7\u45380  \u51204 \u51032  \u51068 \u51060 , \u44536 \u47532 \u44256  \u51648 \u44552 \u44620 \u51648  \u51060 \u50612 \u50728  \u44536  \u44596  \u51096 \u47803 \u51060  \u51228 \u45824 \u47196  \u46108  \u51088 \u47532 \u47484  \u52286 \u51012  \u49688  \u51080 \u50632 \u49845 \u45768 \u45796 .\
