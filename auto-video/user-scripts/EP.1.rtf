\uc0\u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473  [\u52309 \u53552 3] \u46028 \u51060 \u53420  \u49688  \u50630 \u45716  \u54620  \u49688  \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \
\uc0\u49688 \u51652 \u51060  \u49436 \u50872 \u47196  \u46028 \u50500 \u50724 \u45716  \u45236 \u45236  \u54648 \u46300 \u54256 \u51012  \u49552 \u50640 \u49436  \u45459 \u51648  \u50506 \u50520 \u49845 \u45768 \u45796 . \u51312 \u49688 \u49437 \u50640  \u50505 \u50500  \u52285 \u48150 \u51012  \u48148 \u46972 \u48372 \u45716  \u52377 \u54616 \u47732 \u49436 , \u49892 \u51008  \u54868 \u47732  \u50504 \u50640 \u49436  \u49552 \u44032 \u46973 \u51012  \u51312 \u50857 \u55176  \u50880 \u51649 \u51060 \u44256  \u51080 \u50632 \u49845 \u45768 \u45796 . \u49884 \u51109  \u49345 \u51064 \u54924  \u50672 \u46973 \u52376 , \u51064 \u44540  \u51452 \u48124 \u49468 \u53552  \u45812 \u45817 \u51088 , \u50724 \u47000 \u51204  \u50508 \u50500 \u46164  \u49324 \u49444  \u51312 \u49324 \u47581  \u50672 \u46973 \u52376 . \u51221 \u55148 \u50640 \u44172  \u48372 \u44256 \u54644 \u50556  \u54624  \u44592 \u52488  \u51221 \u48372 \u47484  \u45132 \u50612 \u47784 \u51004 \u45716  \u51089 \u50629 \u51060 \u50632 \u49845 \u45768 \u45796 . \u44169 \u51004 \u47196 \u45716  \u52840 \u52265 \u54664 \u49845 \u45768 \u45796 . \u50868 \u51204  \u51473 \u51064  \u44592 \u49324  \u50526 \u50640 \u49436 , \u44536 \u47532 \u44256  \u46263 \u51088 \u47532 \u50640  \u50505 \u51008  \u51221 \u55148  \u50526 \u50640 \u49436  \u55124 \u46308 \u47532 \u45716  \u47784 \u49845 \u51012  \u48372 \u51068  \u49688  \u50630 \u50632 \u49845 \u45768 \u45796 .\
\uc0\u54616 \u51648 \u47564  \u52264 \u44032  \u44256 \u49549 \u46020 \u47196 \u50640  \u51652 \u51077 \u54616 \u44256  \u51221 \u55148 \u44032  \u52285 \u48150 \u51004 \u47196  \u49884 \u49440 \u51012  \u44256 \u51221 \u54616 \u51088 , \u49688 \u51652 \u51008  \u47924 \u47502  \u50948 \u50640  \u45236 \u47140 \u45459 \u51008  \u49552 \u51012  \u51312 \u50857 \u55176  \u51536 \u50632 \u49845 \u45768 \u45796 . \u49552 \u53681 \u51060  \u49552 \u48148 \u45797 \u51012  \u54028 \u44256 \u46300 \u45716  \u44172  \u45712 \u44788 \u51276 \u51648 \u47564  \u54400 \u51648  \u50506 \u50520 \u49845 \u45768 \u45796 . \u49552 \u53681  \u45149 \u51060  \u48521 \u50612 \u51656  \u46412 \u44620 \u51648  \u45572 \u47476 \u45796 \u44032 , \u51221 \u55148 \u44032  \u49332 \u51677  \u50880 \u51649 \u51060 \u45716  \u44592 \u52377 \u50640  \u49552 \u51012  \u51116 \u48744 \u47532  \u54216 \u49845 \u45768 \u45796 . 7\u45380 \u51060 \u50632 \u49845 \u45768 \u45796 . 7\u45380  \u46041 \u50504  \u50500 \u47924  \u51068 \u46020  \u50630 \u50632 \u49845 \u45768 \u45796 . \u44536 \u47088 \u45936  \u50724 \u45720 , \u51060  \u51089 \u51008  \u49884 \u51109  \u44264 \u47785  \u54616 \u45208 \u50640 \u49436  \u47784 \u46304  \u44163 \u51060  \u45796 \u49884  \u49884 \u51089 \u46104 \u47140  \u54616 \u44256  \u51080 \u50632 \u49845 \u45768 \u45796 .\
\uc0\u49436 \u50872  \u46020 \u52265  \u54980  \u49688 \u51652 \u51008  \u51221 \u55148 \u47484  \u48176 \u50885 \u54616 \u44256  \u48148 \u47196  \u50808 \u48512  \u50672 \u46973 \u52376 \u50640  \u51204 \u54868 \u47484  \u46028 \u47160 \u49845 \u45768 \u45796 . \u49884 \u51109  \u49345 \u51064 \u46308  \u49324 \u51060 \u50640 \u49436  \u49688 \u49548 \u47928 \u54620  \u44208 \u44284 \u44032  \u44536 \u45216  \u48164  \u45734 \u44172  \u46308 \u50612 \u50772 \u49845 \u45768 \u45796 . \u54620 \u49436 \u50980 , 42\u49332 , \u49884 \u51109  \u48152 \u52268 \u44032 \u44172  3\u45380 \u51704  \u50868 \u50689  \u51473 . \u50500 \u51060 \u45716  \u50500 \u46308 , 7\u49332 . \u49688 \u51652 \u51008  \u44536  \u49707 \u51088 \u47484  \u54868 \u47732 \u50640 \u49436  \u54620 \u52280  \u48148 \u46972 \u48372 \u45796 \u44032  \u54648 \u46300 \u54256 \u51012  \u46244 \u51665 \u50612  \u45459 \u50520 \u49845 \u45768 \u45796 . 7\u49332 . 7\u45380  \u51204  \u49324 \u44148  \u51649 \u54980  \u53468 \u50612 \u45212  \u50500 \u51060 \u50688 \u49845 \u45768 \u45796 . \u44228 \u49328 \u51060  \u45320 \u47924  \u51221 \u54869 \u54616 \u44172  \u47582 \u50500 \u46504 \u50612 \u51256 \u49436 , \u50724 \u55176 \u47140  \u44032 \u49844 \u51060  \u49436 \u45720 \u54664 \u49845 \u45768 \u45796 . \u49688 \u51652 \u51008  \u51088 \u47532 \u50640 \u49436  \u51068 \u50612 \u45208  \u52285 \u44032 \u47196  \u44052 \u49845 \u45768 \u45796 . \u48164 \u51060  \u46108  \u49436 \u50872  \u44144 \u47532 \u44032  \u50500 \u47000 \u50640  \u54204 \u52432 \u51256  \u51080 \u50632 \u49845 \u45768 \u45796 . \u51200  \u50500 \u51060 \u44032  \u49464 \u49345 \u50640  \u51080 \u45796 \u45716  \u44163 \u51012  \u49688 \u51652 \u51008  \u50508 \u44256  \u51080 \u50632 \u49845 \u45768 \u45796 . \u50724 \u47000 \u51204 \u48512 \u53552  \u50508 \u44256  \u51080 \u50632 \u49845 \u45768 \u45796 . \u45796 \u47564  \u51221 \u55148 \u51032  \u45576 \u50640  \u45823 \u51648  \u50506 \u45716  \u54620 , \u50500 \u47924  \u51068 \u46020  \u51068 \u50612 \u45208 \u51648  \u50506 \u51012  \u44144 \u46972 \u44256  \u49373 \u44033 \u54664 \u49845 \u45768 \u45796 . \u44536  \u44228 \u49328 \u51060  \u50724 \u45720  \u47924 \u45320 \u51276 \u49845 \u45768 \u45796 .\
\uc0\u51221 \u55148 \u50640 \u44172  \u48372 \u44256 \u54624  \u45236 \u50857 \u51012  \u51221 \u47532 \u54616 \u47732 \u49436  \u49688 \u51652 \u51008  \u49552 \u44032 \u46973  \u45149 \u51060  \u52264 \u44032 \u50892 \u51648 \u45716  \u44163 \u51012  \u45712 \u44808 \u49845 \u45768 \u45796 . \u48372 \u44256 \u45716  \u54644 \u50556  \u54664 \u49845 \u45768 \u45796 . \u45796 \u49884  \u54868 \u47732 \u51012  \u50676 \u50632 \u49845 \u45768 \u45796 .\
\uc0\u44536 \u45216  \u51200 \u45377 , \u51221 \u55148 \u45716  \u50500 \u46308 \u51012  \u48520 \u47104 \u49845 \u45768 \u45796 .\
\uc0\u48124 \u51456 \u51008  \u47560 \u55124 \u45796 \u49455  \u49332 \u51060 \u50632 \u44256 , \u51060 \u54844  \u54980  \u49436 \u50872  \u46020 \u49900  \u50500 \u54028 \u53944 \u50640  \u54844 \u51088  \u49332 \u44256  \u51080 \u50632 \u49845 \u45768 \u45796 . \u50612 \u47672 \u45768 \u51032  \u51200 \u45377  \u54840 \u52636 \u51060  \u45231 \u49444 \u51648 \u45716  \u50506 \u50520 \u51648 \u47564 , \u50724 \u45720 \u51008  \u47956 \u44032  \u45804 \u46992 \u49845 \u45768 \u45796 . \u51204 \u54868  \u47785 \u49548 \u47532 \u44032  \u51687 \u50520 \u44256 , \u51060 \u50976 \u47484  \u47931 \u44592 \u46020  \u51204 \u50640  \u45130 \u50612 \u51276 \u49845 \u45768 \u45796 . \u48124 \u51456 \u51008  \u52264 \u47484  \u47792 \u50500  \u51221 \u55148 \u51032  \u51665 \u51004 \u47196  \u44052 \u49845 \u45768 \u45796 . \u54788 \u44288 \u47928 \u51012  \u50676 \u50632 \u51012  \u46412  \u50612 \u47672 \u45768 \u45716  \u51452 \u48169 \u51060  \u50500 \u45772  \u44144 \u49892  \u49548 \u54028 \u50640  \u50505 \u50500  \u51080 \u50632 \u49845 \u45768 \u45796 . \u52264  \u46160  \u51092 \u51060  \u53441 \u51088  \u50948 \u50640  \u45459 \u50668  \u51080 \u50632 \u49845 \u45768 \u45796 . \u48124 \u51456 \u51060  \u49888 \u48156 \u51012  \u48279 \u51004 \u47732 \u49436  \u50612 \u47672 \u45768 \u51032  \u50620 \u44404 \u51012  \u49332 \u54216 \u49845 \u45768 \u45796 . \u51200 \u45377 \u51012  \u54632 \u44760  \u47673 \u51088 \u45716  \u51088 \u47532 \u44032  \u50500 \u45768 \u50632 \u49845 \u45768 \u45796 .\
\uc0\u44144 \u49892  \u49548 \u54028 \u50640  \u47560 \u51452  \u50505 \u51008  \u46160  \u49324 \u46988  \u49324 \u51060 \u47196  \u51104 \u49884  \u52840 \u47925 \u51060  \u55128 \u47104 \u49845 \u45768 \u45796 . \u51221 \u55148 \u44032  \u47676 \u51200  \u52264  \u54620  \u51092 \u51012  \u48124 \u51456  \u51901 \u51004 \u47196  \u48128 \u50632 \u49845 \u45768 \u45796 . \u48124 \u51456 \u51008  \u44536 \u44163 \u51012  \u48155 \u51004 \u47732 \u49436  \u50612 \u47672 \u45768 \u51032  \u50620 \u44404 \u51012  \u49332 \u54216 \u49845 \u45768 \u45796 . \u47956 \u44032 \u47484  \u50724 \u47000  \u49373 \u44033 \u54616 \u45796  \u44732 \u45236 \u45716  \u50620 \u44404 \u51060 \u50632 \u49845 \u45768 \u45796 .\
\'93\uc0\u50724 \u45720  \u49436 \u50980 \u51060 \u47484  \u47564 \u45228 \u45796 . \u49884 \u51109 \u50640 \u49436  \u48152 \u52268 \u44032 \u44172 \u47484  \u54616 \u44256  \u51080 \u45908 \u44396 \u45208 \'94\
\uc0\u51221 \u55148 \u44032  \u52380 \u52380 \u55176  \u50868 \u51012  \u46544 \u49845 \u45768 \u45796 . \u48124 \u51456 \u51008  \u52283 \u51092 \u51012  \u45236 \u47140 \u45459 \u51004 \u47728  \u50612 \u47672 \u45768 \u47484  \u48148 \u46972 \u48372 \u50520 \u49845 \u45768 \u45796 .\
\'93\uc0\u44536 \u47088 \u45936  \u49436 \u50980 \u51060  \u50694 \u50640  \u50784  \u45224 \u51088  \u50500 \u51060 \u44032  \u51080 \u45912 \u45936 ..\'94\
\uc0\u48124 \u51456 \u51032  \u49552 \u51060  \u47688 \u52628 \u50632 \u49845 \u45768 \u45796 . \u47924 \u47502  \u50948 \u50640  \u46160 \u50632 \u45912  \u49552 \u51060  \u44536 \u45824 \u47196  \u44403 \u50612 \u48260 \u47160 \u49845 \u45768 \u45796 . \u49436 \u50980 \u51060 \u46972 \u45716  \u51060 \u47492 \u51060  \u47676 \u51200  \u44480 \u50640  \u48149 \u54804 \u44256 , \u44536 \u45796 \u51020  \u50500 \u51060 \u46972 \u45716  \u45800 \u50612 \u44032  \u46384 \u46972 \u50772 \u49845 \u45768 \u45796 . \u46160  \u45800 \u50612 \u44032  \u54632 \u44760  \u50724 \u45716  \u44163 \u51012  \u48124 \u51456 \u51008  \u54620  \u48264 \u46020  \u49345 \u49345 \u54644 \u48376  \u51201 \u51060  \u50630 \u50632 \u49845 \u45768 \u45796 .\
"\uc0\u50500 \u51060 \u50836 ?"\
\uc0\u47785 \u49548 \u47532 \u44032  \u51088 \u44592 \u46020  \u47784 \u47476 \u44172  \u45208 \u50772 \u49845 \u45768 \u45796 . \u45817 \u54889 \u54664 \u45796 \u44592 \u48372 \u45796  \u47568  \u51088 \u52404 \u44032  \u47672 \u47551 \u49549 \u50640 \u49436  \u51221 \u47532 \u46104 \u51648  \u50506 \u45716  \u45712 \u45196 \u51060 \u50632 \u49845 \u45768 \u45796 . \u51221 \u55148 \u45716  \u48124 \u51456 \u51032  \u44536  \u54364 \u51221 \u51012  \u51069 \u51004 \u47728  \u52380 \u52380 \u55176  \u47568 \u51012  \u51060 \u50632 \u49845 \u45768 \u45796 .\
"\uc0\u51068 \u44273  \u49332 \u52196  \u46108  \u45224 \u51088 \u50500 \u51060 \u50556 . \u50620 \u44404 \u51012  \u48372 \u45716 \u45936 , \u46020 \u51200 \u55176  \u44536 \u45285  \u51648 \u45208 \u52832  \u49688 \u44032  \u50630 \u50632 \u50612 ."\
\uc0\u48124 \u51456 \u51008  \u54620 \u46041 \u50504  \u47568 \u51060  \u50630 \u50632 \u49845 \u45768 \u45796 . \u54756 \u50612 \u51656  \u45817 \u49884 \u47484  \u46496 \u50732 \u47160 \u49845 \u45768 \u45796 . \u49436 \u50980 \u51060  \u51664 \u51012  \u49912 \u45912  \u45216 , \u44536  \u51060 \u54980 . \u50672 \u46973 \u51060  \u50630 \u50632 \u49845 \u45768 \u45796 . \u54620  \u48264 \u46020 . \u51076 \u49888 \u51060 \u46972 \u45716  \u47568 \u51008  \u47932 \u47200 \u51060 \u44256 , \u50500 \u51060 \u46972 \u45716  \u47568 \u51008  \u44732 \u45240  \u51201 \u51312 \u52264  \u50630 \u50632 \u49845 \u45768 \u45796 . \u49436 \u50980 \u51060  \u44536 \u47088  \u51060 \u50556 \u44592 \u47484  \u54664 \u45796 \u47732  \u48124 \u51456 \u51008  \u44592 \u50613 \u54616 \u44256  \u51080 \u51012  \u44163 \u51060 \u50632 \u49845 \u45768 \u45796 . \u51208 \u45824 \u47196  \u55128 \u47140 \u46308 \u51012  \u49688  \u51080 \u45716  \u47568 \u51060  \u50500 \u45768 \u50632 \u49845 \u45768 \u45796 .\
\'93\uc0\u50612 \u47672 \u45768  \u44049 \u51088 \u44592  \u47924 \u49832  \u47568 \u50432 \u51060 \u49888 \u44144 \u50640 \u50836 .\'94\
\uc0\u44536  \u47568 \u51060  \u45208 \u50724 \u45716  \u46041 \u50504  \u48124 \u51456 \u51032  \u47785 \u49548 \u47532 \u44032  \u49332 \u51677  \u51104 \u44220 \u49845 \u45768 \u45796 . \u51221 \u55148 \u45716  \u44536 \u44163 \u51012  \u46308 \u51004 \u47732 \u49436  \u50500 \u46308 \u51032  \u50620 \u44404 \u51012  \u48148 \u46972 \u48372 \u50520 \u49845 \u45768 \u45796 . \u45440 \u46976  \u44163 \u51064 \u51648 , \u50500 \u45768 \u47732  \u52649 \u44201 \u51012  \u48155 \u51008  \u44163 \u51064 \u51648 . \u50500 \u47560  \u46168  \u45796 \u51068  \u44163 \u51060 \u50632 \u49845 \u45768 \u45796 .\
"\uc0\u54756 \u50612 \u51656  \u46412  \u49436 \u50980 \u51060  \u50500 \u47924  \u47568 \u46020  \u50630 \u50632 \u50612 ?"\
"\uc0\u50630 \u50632 \u49845 \u45768 \u45796 . \u51076 \u49888 \u51060 \u46972 \u45716  \u47568 \u51008 , \u54620  \u48264 \u46020  \u50630 \u50632 \u50612 \u50836 ."\
\uc0\u44144 \u49892 \u50640  \u45796 \u49884  \u52840 \u47925 \u51060  \u45236 \u47140 \u50505 \u50520 \u49845 \u45768 \u45796 . \u48124 \u51456 \u51008  \u50612 \u47672 \u45768 \u44032  \u44732 \u45240  \u47568 \u51012  \u50504 \u50640 \u49436  \u52380 \u52380 \u55176  \u46104 \u50489 \u50632 \u49845 \u45768 \u45796 . \u51068 \u44273  \u49332  \u45224 \u51088 \u50500 \u51060 . \u49436 \u50980  \u44225 \u50640  \u51080 \u45912  \u50500 \u51060 . 7\u45380  \u51204  \u44536 \u54644 \u50640  \u53468 \u50612 \u45228 \u51012  \u50500 \u51060 . \u47568 \u51060  \u50672 \u44208 \u46104 \u45716 \u45936 \u46020  \u49440 \u46907  \u48155 \u50500 \u46308 \u51060 \u44592 \u44032  \u50612 \u47140 \u50912 \u49845 \u45768 \u45796 . \u45320 \u47924  \u53356 \u44256 , \u45320 \u47924  \u47924 \u44144 \u50912 \u49845 \u45768 \u45796 . \u48124 \u51456 \u51008  \u52283 \u51092 \u51012  \u45796 \u49884  \u46308 \u50632 \u45796 \u44032 , \u54620  \u47784 \u44552 \u46020  \u47560 \u49884 \u51648  \u47803 \u54616 \u44256  \u45236 \u47140 \u45459 \u50520 \u49845 \u45768 \u45796 .\
"\uc0\u51068 \u45800  \u54869 \u51064 \u48512 \u53552  \u54644 \u48372 \u51088 .\'94\
\uc0\u51221 \u55148 \u51032  \u47785 \u49548 \u47532 \u45716  \u52264 \u48516 \u54664 \u49845 \u45768 \u45796 . \u54616 \u51648 \u47564  \u44536  \u52264 \u48516 \u54632  \u50504 \u50640  \u47924 \u50616 \u44032  \u45800 \u45800 \u54620  \u44208 \u49900 \u51060  \u46308 \u50612 \u51080 \u45796 \u45716  \u44163 \u51012  \u48124 \u51456 \u51008  \u50724 \u47000 \u51204 \u48512 \u53552  \u50508 \u44256  \u51080 \u50632 \u49845 \u45768 \u45796 . \u50612 \u47672 \u45768 \u44032  \u51060 \u47111 \u44172  \u47568 \u54624  \u46412 \u45716 , \u51060 \u48120  \u45796 \u51020  \u49688 \u49692 \u51012  \u49373 \u44033 \u54616 \u44256  \u51080 \u45796 \u45716  \u46907 \u51060 \u50632 \u49845 \u45768 \u45796 . \u48124 \u51456 \u51008  \u44256 \u44060 \u47484  \u45124 \u45909 \u50688 \u49845 \u45768 \u45796 . \u44536 \u44163  \u47568 \u44256 \u45716  \u51648 \u44552  \u54624  \u49688  \u51080 \u45716  \u44163 \u51060  \u50630 \u50632 \u49845 \u45768 \u45796 .\
\uc0\u48124 \u51456 \u51060  \u46028 \u50500 \u44036  \u46244 , \u51221 \u55148 \u45716  \u54620 \u46041 \u50504  \u49548 \u54028 \u50640  \u44536 \u45824 \u47196  \u50505 \u50500  \u51080 \u50632 \u49845 \u45768 \u45796 . \u44144 \u49892 \u51032  \u48520 \u48731 \u51060  \u44256 \u50836 \u54616 \u44172  \u45236 \u47140 \u50505 \u51008  \u44032 \u50868 \u45936 , \u49552  \u50504 \u50640  \u52283 \u51092 \u47564  \u49885 \u50612 \u44032 \u44256  \u51080 \u50632 \u49845 \u45768 \u45796 . \u49436 \u50980 \u51060  \u54788 \u44288 \u51012  \u45208 \u49436 \u45912  \u44536 \u45216 , \u51221 \u55148 \u45716  \u46321  \u46244 \u50640 \u49436  \u44536  \u46263 \u47784 \u49845 \u51012  \u48148 \u46972 \u48420 \u49845 \u45768 \u45796 . \u46244 \u46028 \u50500 \u48372 \u51648 \u46020  \u50506 \u44256  \u45208 \u44052 \u49845 \u45768 \u45796 . \u44536 \u46412  \u51221 \u55148 \u45716  \u44536 \u44172  \u51396 \u51064 \u51032  \u47784 \u49845 \u51060 \u46972 \u44256  \u49373 \u44033 \u54664 \u49845 \u45768 \u45796 . \u51648 \u44552 \u51008  \u45804 \u46992 \u49845 \u45768 \u45796 . \u51648 \u44552 \u51008  \u44536 \u44172  \u45796 \u47476 \u44172  \u48372 \u51060 \u44592  \u49884 \u51089 \u54664 \u49845 \u45768 \u45796 .\
\uc0\u54648 \u46300 \u54256 \u51060  \u51652 \u46041 \u54664 \u49845 \u45768 \u45796 . \u49688 \u51652 \u51060 \u50632 \u49845 \u45768 \u45796 . \u50500 \u51060  \u45208 \u51060  \u54869 \u51064 \u46096 \u49845 \u45768 \u45796 . 7\u49332 \u51077 \u45768 \u45796 . \u51687 \u51008  \u47928 \u51088 \u50688 \u49845 \u45768 \u45796 . \u51221 \u55148 \u45716  \u44536 \u44163 \u51012  \u51069 \u44256  \u54868 \u47732 \u51012  \u45236 \u47140 \u45459 \u50520 \u49845 \u45768 \u45796 . \u54364 \u51221 \u51060  \u51312 \u50857 \u55176  \u44403 \u50612 \u51276 \u49845 \u45768 \u45796 . \u51032 \u49900 \u51060  \u54869 \u47456 \u51060  \u46104 \u45716  \u49692 \u44036 \u51060 \u50632 \u49845 \u45768 \u45796 .\
\uc0\u54620 \u54200  \u44536  \u49884 \u44033 , \u49688 \u51652 \u51008  \u54924 \u49324  \u51204 \u49328 \u49892 \u50640  \u54844 \u51088  \u45224 \u50500  \u51080 \u50632 \u49845 \u45768 \u45796 . \u51649 \u50896 \u46308 \u51060  \u53748 \u44540 \u54620  \u46244  \u51312 \u50857 \u54644 \u51652  \u49324 \u47924 \u49892 \u50640 \u49436 , \u49688 \u51652 \u51008  \u45217 \u51008  \u49436 \u48260  \u51217 \u49549  \u44592 \u47197  \u54868 \u47732 \u51012  \u52380 \u52380 \u55176  \u46308 \u50668 \u45796 \u48372 \u44256  \u51080 \u50632 \u49845 \u45768 \u45796 . 7\u45380  \u51204  \u54945 \u47161  \u49324 \u44148  \u45817 \u49884  \u45236 \u48512 \u50640 \u49436  \u50724 \u44036  \u44208 \u51116  \u47928 \u49436 \u46308 . \u44536  \u50504 \u50640 \u45716  \u51648 \u50892 \u50556  \u54624  \u44163 \u46308 \u51060  \u51080 \u50632 \u49845 \u45768 \u45796 . \u49688 \u51652 \u51060  \u51649 \u51217  \u47564 \u46304  \u44163 \u46308 \u51060 \u50632 \u49845 \u45768 \u45796 . \u45817 \u49884 \u50640 \u45716  \u50756 \u48317 \u54616 \u44172  \u52376 \u47532 \u46096 \u45796 \u44256  \u49373 \u44033 \u54664 \u49845 \u45768 \u45796 . \u54616 \u51648 \u47564  \u51221 \u55148 \u44032  \u45796 \u49884  \u51060 \u51901 \u51012  \u46308 \u50668 \u45796 \u48372 \u44592  \u49884 \u51089 \u54616 \u47732 , \u55124 \u51201 \u51060  \u49332 \u50500 \u45216  \u49688 \u46020  \u51080 \u50632 \u49845 \u45768 \u45796 . \u49688 \u51652 \u51032  \u49552 \u44032 \u46973 \u51060  \u53412 \u48372 \u46300  \u50948 \u50640 \u49436  \u47688 \u52628 \u50632 \u45796 \u44032 , \u45796 \u49884  \u52380 \u52380 \u55176  \u50880 \u51649 \u50688 \u49845 \u45768 \u45796 . \u49325 \u51228 . \u54644 \u45817  \u47196 \u44536  \u49325 \u51228 . \u49552 \u51060  \u46504 \u47160 \u49845 \u45768 \u45796 . \u44536 \u47084 \u45208  \u47688 \u52628 \u51648  \u50506 \u50520 \u49845 \u45768 \u45796 .\
\uc0\u51060 \u48120  \u49884 \u51089 \u54620  \u51068 \u51060 \u50632 \u49845 \u45768 \u45796 . \u51648 \u44552  \u47688 \u52628 \u47732 , \u45224 \u44200 \u51652  \u44163 \u46308 \u51060  \u45208 \u51473 \u50640  \u51204 \u48512  \u46300 \u47084 \u45225 \u45768 \u45796 . \u49688 \u51652 \u51008  \u44536 \u47111 \u44172  \u49828 \u49828 \u47196 \u47484  \u49444 \u46301 \u54616 \u47728  \u54868 \u47732 \u51012  \u45803 \u50520 \u49845 \u45768 \u45796 . \u49324 \u47924 \u49892  \u48520 \u51012  \u45124 \u44256  \u45208 \u50724 \u47732 \u49436 , \u48373 \u46020  \u45149 \u50640 \u49436  \u51104 \u44624  \u47688 \u52628 \u50632 \u49845 \u45768 \u45796 . \u50612 \u46161 \u54620  \u48373 \u46020  \u52380 \u51109 \u51012  \u50732 \u47140 \u45796 \u48372 \u45796 \u44032 , \u45796 \u49884  \u44152 \u51020 \u51012  \u50734 \u44220 \u49845 \u45768 \u45796 .\
\uc0\u50724 \u45720  \u48164  \u48124 \u51456 \u51008  \u51104 \u51012  \u51060 \u47336 \u51648  \u47803 \u54624  \u44163 \u51060 \u50632 \u49845 \u45768 \u45796 . \u50612 \u47672 \u45768 \u50640 \u44172 \u49436  \u46308 \u51008  \u51060 \u50556 \u44592 \u44032  \u47672 \u47551 \u49549 \u51012  \u46496 \u45208 \u51648  \u50506 \u51012  \u53552 \u50688 \u49845 \u45768 \u45796 . \u45208 \u45716  \u51221 \u47568  \u47792 \u46992 \u45796 . \u44536  \u49373 \u44033 \u51060  \u51088 \u44984  \u51228  \u51088 \u47532 \u47484  \u47604 \u46028  \u44163 \u51060 \u50632 \u49845 \u45768 \u45796 . \u44536 \u47532 \u44256  \u44536  \u50694 \u50640 \u49436 , \u46608  \u45796 \u47480  \u51656 \u47928  \u54616 \u45208 \u44032  \u51312 \u50857 \u55176  \u44256 \u44060 \u47484  \u46308 \u44592  \u49884 \u51089 \u54624  \u44163 \u51060 \u50632 \u49845 \u45768 \u45796 . \u45236 \u44032  \u47784 \u47476 \u45716  \u51068 \u51060 , \u51652 \u51676 \u47196  \u51080 \u50632 \u45912  \u44152 \u44620 . \u44536  \u51656 \u47928 \u51060  \u50472 \u50519 \u52376 \u47100  \u48149 \u55176 \u45716  \u49692 \u44036 \u48512 \u53552 , \u48124 \u51456 \u51032  7\u45380 \u51060  \u45796 \u49884  \u55124 \u46308 \u47532 \u44592  \u49884 \u51089 \u54624  \u44163 \u51060 \u50632 \u49845 \u45768 \u45796 .\
