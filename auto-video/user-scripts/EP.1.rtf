\uc0\u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473  [\u52309 \u53552 5] \u50501 \u45817 \u51032  \u51204 \u49457 \u44592  \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \
\uc0\u44264 \u47785 \u50640 \u49436  \u49688 \u51652 \u44284  \u47560 \u51452 \u52828  \u44536 \u45216  \u48164 , \u49436 \u50980 \u51008  \u50500 \u46308 \u51012  \u51116 \u50868  \u46244  \u48512 \u50636  \u49885 \u53441  \u50526 \u50640  \u54844 \u51088  \u50505 \u50520 \u49845 \u45768 \u45796 . \u52264 \u47484  \u54620  \u51092  \u45139 \u50688 \u51648 \u47564  \u47560 \u49884 \u51648  \u50506 \u50520 \u49845 \u45768 \u45796 . \u44536 \u45285  \u46160  \u49552 \u51004 \u47196  \u52981 \u51012  \u44048 \u49912 \u51540  \u52292 , 7\u45380  \u51204  \u44592 \u50613 \u46308 \u51012  \u54616 \u45208 \u50473  \u44732 \u45256 \u49845 \u45768 \u45796 .\
\uc0\u52376 \u51020  \u54924 \u49324 \u50640  \u51077 \u49324 \u54664 \u51012  \u46412 \u50688 \u49845 \u45768 \u45796 . \u49436 \u50980 \u51008  \u44221 \u50689 \u44592 \u54925 \u54016  \u49548 \u49549 \u51004 \u47196  \u46308 \u50612 \u44052 \u44256 , \u49688 \u51652 \u51008  \u45824 \u54364  \u49688 \u54665 \u48708 \u49436  \u51088 \u47532 \u50640 \u49436  \u51060 \u48120  \u50724 \u47000  \u51068 \u54616 \u44256  \u51080 \u50632 \u49845 \u45768 \u45796 . \u46160  \u49324 \u46988 \u51060  \u51088 \u51452  \u47560 \u51452 \u52824 \u45716  \u44396 \u51312 \u45716  \u50500 \u45768 \u50632 \u49845 \u45768 \u45796 . \u44536 \u47088 \u45936  \u51060 \u49345 \u54616 \u44172  \u49688 \u51652 \u44284  \u47560 \u51452 \u52832  \u46412 \u47560 \u45796  \u47956 \u44032  \u51060 \u49345 \u54620  \u44048 \u44033 \u51060  \u46308 \u50632 \u49845 \u45768 \u45796 . \u49884 \u49440 \u51060  \u51312 \u44552  \u45804 \u46992 \u49845 \u45768 \u45796 . \u48372 \u53685  \u49324 \u46988 \u51060  \u45796 \u47480  \u49324 \u46988 \u51012  \u48372 \u45716  \u45576 \u51060  \u50500 \u45768 \u50632 \u49845 \u45768 \u45796 . \u47956 \u44032 \u47484  \u51116 \u45716  \u44163  \u44057 \u44592 \u46020  \u54664 \u44256 , \u47924 \u50616 \u44032 \u47484  \u52280 \u45716  \u44163  \u44057 \u44592 \u46020  \u54664 \u49845 \u45768 \u45796 . \u52376 \u51020 \u50644  \u51088 \u49888 \u51032  \u52265 \u44033 \u51060 \u44192 \u44144 \u45768  \u49373 \u44033 \u54664 \u49845 \u45768 \u45796 .\
\uc0\u44208 \u51116  \u49436 \u47448  \u47928 \u51228 \u44032  \u52376 \u51020  \u49373 \u44596  \u44148  \u49436 \u50980 \u51060  \u51077 \u49324 \u54620  \u51648  \u49324 \u44060 \u50900 \u52196  \u46096 \u51012  \u46412 \u50688 \u49845 \u45768 \u45796 . \u49436 \u50980 \u51060  \u44592 \u54925 \u50504 \u51012  \u50732 \u47532 \u47732 , \u44160 \u53664  \u44284 \u51221 \u50640 \u49436  \u49688 \u51652 \u51012  \u44144 \u52432 \u50556  \u54616 \u45716  \u44221 \u50864 \u44032  \u51333 \u51333  \u51080 \u50632 \u49845 \u45768 \u45796 . \u44536 \u47088 \u45936  \u49688 \u51652 \u51012  \u53685 \u44284 \u54620  \u49436 \u47448 \u44032  \u45236 \u50857 \u51060  \u51068 \u48512  \u48148 \u45068 \u50612  \u51080 \u44144 \u45208 , \u51473 \u50836 \u54620  \u52392 \u48512  \u51088 \u47308 \u44032  \u48736 \u51652  \u52292 \u47196  \u50732 \u46972 \u44032 \u45716  \u51068 \u51060  \u46160  \u48264 , \u49464  \u48264  \u48152 \u48373 \u46096 \u49845 \u45768 \u45796 . \u49436 \u50980 \u51060  \u51649 \u51217  \u54869 \u51064 \u51012  \u48512 \u53441 \u54664 \u51012  \u46412  \u49688 \u51652 \u51008  \u45812 \u45812 \u54616 \u44172  \u47568 \u54664 \u49845 \u45768 \u45796 . \u50896 \u48376  \u44536 \u45824 \u47196  \u51204 \u45804 \u54664 \u45796 \u44256 . \u44536  \u47568 \u53804 \u50640 \u45716  \u50612 \u46500  \u44048 \u51221 \u46020  \u49892 \u47140  \u51080 \u51648  \u50506 \u50500 \u49436 , \u50724 \u55176 \u47140  \u45908  \u50612 \u49353 \u54664 \u49845 \u45768 \u45796 . \u51096 \u47803 \u54664 \u51004 \u47732  \u48120 \u50504 \u54616 \u45796 \u44256  \u54616 \u44144 \u45208 , \u51088 \u49888 \u51060  \u54620  \u51068 \u51060  \u50500 \u45768 \u46972 \u44256  \u54637 \u48320 \u54624  \u47564 \u46020  \u54664 \u49845 \u45768 \u45796 . \u44536 \u47088 \u45936  \u49688 \u51652 \u51008  \u44536 \u45285  \u50896 \u48376  \u44536 \u45824 \u47196  \u51204 \u45804 \u54664 \u45796 \u44256 \u47564  \u54664 \u49845 \u45768 \u45796 . \u45320 \u47924  \u44628 \u45140 \u54664 \u49845 \u45768 \u45796 . \u48320 \u47749 \u46020  \u50630 \u44256  \u44048 \u51221 \u46020  \u50630 \u45716  \u44536  \u45824 \u45813 \u51060 , \u51648 \u44552  \u49373 \u44033 \u54644 \u48372 \u47732  \u44032 \u51109  \u51060 \u49345 \u54620  \u48512 \u48516 \u51060 \u50632 \u49845 \u45768 \u45796 .\
\uc0\u48124 \u51456 \u44284 \u51032  \u44208 \u54844  \u48156 \u54364  \u51060 \u54980 \u47196 \u45716  \u45804 \u46992 \u49845 \u45768 \u45796 . \u44536  \u51204 \u44620 \u51648 \u45716  \u44536 \u45208 \u47560  \u54364 \u47732 \u51201 \u51004 \u47196 \u46972 \u46020  \u49440 \u51012  \u51648 \u53040 \u49845 \u45768 \u45796 . \u44536 \u47088 \u45936  \u49324 \u45236  \u44277 \u51648 \u44032  \u45208 \u44036  \u44536 \u45216  \u50724 \u54980 \u48512 \u53552 , \u49688 \u51652 \u51032  \u53468 \u46020 \u50640 \u49436  \u47924 \u50616 \u44032 \u44032  \u48148 \u45068 \u50632 \u49845 \u45768 \u45796 . \u48373 \u46020 \u50640 \u49436  \u47560 \u51452 \u52832  \u46412  \u47676 \u51200  \u45576 \u51012  \u54588 \u54664 \u44256 , \u54924 \u51032  \u51088 \u47532 \u50640 \u49436  \u49436 \u50980 \u51060  \u47568 \u51012  \u44732 \u45236 \u47732  \u50500 \u51452  \u51104 \u44624  \u48120 \u47896 \u54616 \u44172  \u44403 \u50612 \u51648 \u45716  \u54364 \u51221 \u51060  \u48372 \u50688 \u49845 \u45768 \u45796 . \u44536 \u44163 \u51060  \u47924 \u50631 \u51064 \u51648  \u49436 \u50980 \u51008  \u51060 \u47492 \u51012  \u48537 \u51060 \u51648  \u47803 \u54664 \u49845 \u45768 \u45796 . \u45796 \u47564  \u51060 \u49345 \u54616 \u45796 \u44256  \u45712 \u44808 \u49845 \u45768 \u45796 . \u44536 \u47532 \u44256  \u44536 \u47196 \u48512 \u53552  \u51060  \u45380  \u46244 , \u54945 \u47161  \u49324 \u44148 \u51060  \u53552 \u51276 \u49845 \u45768 \u45796 .\
\uc0\u52981  \u50504 \u50640  \u52264 \u44032  \u49885 \u50612 \u44032 \u44256  \u51080 \u50632 \u49845 \u45768 \u45796 . \u49436 \u50980 \u51008  \u44596  \u49704 \u51012  \u45236 \u49772 \u50632 \u49845 \u45768 \u45796 . \u44536 \u46412  \u49688 \u51652 \u51060  \u44536  \u51068 \u44284  \u50672 \u44208 \u46104 \u50612  \u51080 \u51012  \u44144 \u46972 \u44256 \u45716  \u49373 \u44033 \u54616 \u51648  \u47803 \u54664 \u49845 \u45768 \u45796 . \u44208 \u51116  \u49436 \u47448 \u47484  \u46028 \u47140 \u48372 \u45236 \u45716  \u44148  \u49324 \u49548 \u54620  \u48169 \u54644 \u50688 \u44256 , \u54924 \u49324  \u51088 \u44552 \u51012  \u51312 \u51089 \u54616 \u45716  \u44148  \u51204 \u54784  \u45796 \u47480  \u52264 \u50896 \u51032  \u51068 \u51060 \u50632 \u51004 \u45768 \u44620 \u50836 . \u54616 \u51648 \u47564  \u50724 \u45720  \u44264 \u47785 \u50640 \u49436  \u47560 \u51452 \u52828  \u44536  \u45576 \u48731 \u51060  \u51088 \u44984  \u47672 \u47551 \u49549 \u50640  \u44152 \u47160 \u49845 \u45768 \u45796 . \u47676 \u51200  \u49884 \u49440 \u51012  \u54588 \u54620  \u44163 . \u50500 \u47924  \u51068 \u46020  \u50630 \u45716  \u49324 \u46988 \u52376 \u47100  \u44152 \u50612 \u44032 \u48260 \u47536  \u44163 . \u51396 \u44032  \u50630 \u45716  \u49324 \u46988 \u51008  \u51200 \u47111 \u44172  \u54616 \u51648  \u50506 \u49845 \u45768 \u45796 .\
\uc0\u45796 \u51020  \u45216  \u51200 \u45377 \u51060 \u50632 \u49845 \u45768 \u45796 . \u44032 \u44172  \u47928 \u51012  \u45803 \u51012  \u49884 \u44036 \u51060  \u44032 \u44620 \u50892 \u51648 \u47732 \u49436  \u49552 \u45784 \u51060  \u46904 \u54644 \u51276 \u44256 , \u49436 \u50980 \u51008  \u48152 \u52268 \u53685 \u51012  \u54616 \u45208 \u50473  \u51221 \u47532 \u54616 \u44592  \u49884 \u51089 \u54664 \u49845 \u45768 \u45796 . \u50500 \u46308 \u51008  \u50724 \u45720  \u54617 \u44368  \u52828 \u44396  \u51665 \u50640 \u49436  \u51200 \u45377 \u51012  \u47673 \u44592 \u47196  \u54664 \u49845 \u45768 \u45796 . \u54844 \u51088  \u47560 \u44048 \u54616 \u45716  \u51200 \u45377 \u51060 \u50632 \u49845 \u45768 \u45796 .\
\uc0\u44536 \u46412  \u44032 \u44172  \u50526 \u50640  \u49324 \u46988 \u51060  \u46308 \u50612 \u49456 \u49845 \u45768 \u45796 .\
\uc0\u49552 \u45784 \u51064 \u44032  \u49910 \u50612  \u44256 \u44060 \u47484  \u46308 \u50632 \u45796 \u44032 , \u49436 \u50980 \u51008  \u49552 \u50640  \u46308 \u44256  \u51080 \u45912  \u48152 \u52268 \u53685 \u51012  \u49440 \u48152  \u50948 \u50640  \u51312 \u50857 \u55176  \u45236 \u47140 \u45459 \u50520 \u49845 \u45768 \u45796 . \u49688 \u51652 \u51060 \u50632 \u49845 \u45768 \u45796 . \u45230 \u50640  \u51077 \u50632 \u45912  \u45800 \u51221 \u54620  \u51116 \u53431  \u45824 \u49888  \u50612 \u46160 \u50868  \u49353  \u53076 \u53944 \u47484  \u44152 \u52824 \u44256  \u51080 \u50632 \u49845 \u45768 \u45796 . \u53748 \u44540  \u54980 \u50640  \u51068 \u48512 \u47084  \u45236 \u47140 \u50728  \u44163 \u51060 \u50632 \u49845 \u45768 \u45796 .\
\uc0\u49688 \u51652 \u51060  \u44032 \u44172  \u50504 \u51004 \u47196  \u46308 \u50612 \u50724 \u47732 \u49436  \u51452 \u48320 \u51012  \u54620 \u48264  \u46168 \u47084 \u48372 \u50520 \u49845 \u45768 \u45796 . \u49552 \u45784 \u51060  \u50630 \u45796 \u45716  \u44163 \u51012  \u54869 \u51064 \u54620  \u46244 , \u52380 \u52380 \u55176  \u49436 \u50980  \u51901 \u51004 \u47196  \u44152 \u50612 \u50772 \u49845 \u45768 \u45796 .\
\uc0\u49436 \u50980 \u51008  \u47932 \u47084 \u49436 \u51648  \u50506 \u50520 \u49845 \u45768 \u45796 . \u49440 \u48152 \u50640  \u46321 \u51012  \u44592 \u45828  \u52292  \u49688 \u51652 \u51012  \u48148 \u46972 \u48372 \u50520 \u49845 \u45768 \u45796 . \u47676 \u51200  \u47568 \u54616 \u51648  \u50506 \u50520 \u49845 \u45768 \u45796 .\
\uc0\u49688 \u51652 \u51060  \u47688 \u52628 \u50632 \u49845 \u45768 \u45796 . \u46160  \u49324 \u46988  \u49324 \u51060 \u47196  \u51329 \u51008  \u44032 \u44172  \u50504 \u51032  \u44277 \u44592 \u44032  \u47924 \u44161 \u44172  \u44032 \u46972 \u50505 \u50520 \u49845 \u45768 \u45796 . \u49688 \u51652 \u51060  \u51077 \u51012  \u50676 \u50632 \u49845 \u45768 \u45796 . \u47785 \u49548 \u47532 \u45716  \u45230 \u44256  \u52264 \u48516 \u54664 \u51648 \u47564 , \u44536  \u50504 \u50640  \u47956 \u44032  \u45800 \u45800 \u54620  \u44163 \u51060  \u46308 \u50612  \u51080 \u50632 \u49845 \u45768 \u45796 .\
"\uc0\u50500 \u51649 \u46020  \u50504  \u44732 \u51276 \u45264 ."\
\uc0\u49436 \u50980 \u51032  \u45576 \u51060  \u44032 \u45720 \u50612 \u51276 \u49845 \u45768 \u45796 . 7\u45380  \u47564 \u50640  \u46307 \u45716  \u47568 \u51060 \u50632 \u49845 \u45768 \u45796 . \u44536 \u47532 \u44256  \u52376 \u51020  \u46307 \u45716  \u47568 \u51060 \u44592 \u46020  \u54664 \u49845 \u45768 \u45796 . 7\u45380  \u51204 \u50640 \u45716  \u49688 \u51652 \u51060  \u51060 \u47111 \u44172  \u51649 \u51217 \u51201 \u51004 \u47196  \u47568 \u54620  \u51201 \u51060  \u50630 \u50632 \u49845 \u45768 \u45796 . \u54637 \u49345  \u54364 \u51221  \u46244 \u50640  \u49704 \u50612  \u51080 \u50632 \u44256 , \u49436 \u47448  \u46244 \u50640  \u49704 \u50612  \u51080 \u50632 \u49845 \u45768 \u45796 . \u44536 \u47088 \u45936  \u51648 \u44552 \u51008  \u45804 \u46992 \u49845 \u45768 \u45796 .\
\uc0\u49436 \u50980 \u51008  \u45824 \u45813 \u54616 \u51648  \u50506 \u50520 \u49845 \u45768 \u45796 .\
\uc0\u49688 \u51652 \u51060  \u54620  \u48156  \u50526 \u51004 \u47196  \u45208 \u49456 \u49845 \u45768 \u45796 .\
"\uc0\u54924 \u49324  \u44540 \u52376 \u50640  \u45796 \u49884  \u50620 \u50476 \u46020  \u54616 \u51648  \u47560 . \u51060 \u48264 \u50644  \u51652 \u51676  \u45149 \u51109 \u45212 \u45796 ."\
\uc0\u49436 \u50980 \u51008  \u45576 \u51012  \u54588 \u54616 \u51648  \u50506 \u50520 \u49845 \u45768 \u45796 . \u49688 \u51652 \u51032  \u50620 \u44404 \u51012  \u46609 \u48148 \u47196  \u48148 \u46972 \u48372 \u47728  \u50500 \u47924  \u47568 \u46020  \u54616 \u51648  \u50506 \u50520 \u49845 \u45768 \u45796 . \u49688 \u51652 \u51060  \u44032 \u44172  \u50504 \u51012  \u45796 \u49884  \u54620 \u48264  \u54993 \u45796 \u44032  \u49884 \u49440 \u51012  \u47928  \u51901 \u51004 \u47196  \u46028 \u47160 \u49845 \u45768 \u45796 . \u50500 \u51060 \u44032  \u50630 \u45796 \u45716  \u44152  \u54869 \u51064 \u54620  \u44163  \u44057 \u50520 \u49845 \u45768 \u45796 . \u49688 \u51652 \u51032  \u51077 \u49696 \u51060  \u48708 \u53952 \u47160 \u49845 \u45768 \u45796 .\
"\uc0\u44316 \u54620  \u50837 \u49900  \u48512 \u47532 \u51648  \u47560 . \u50500 \u51060 \u44032  \u51080 \u45796 \u44256  \u45804 \u46972 \u51648 \u45716  \u44148  \u50630 \u50612 ."\
\uc0\u44536  \u47568 \u51060  \u49436 \u50980 \u51032  \u44032 \u49844  \u50504 \u51901 \u51004 \u47196  \u54028 \u44256 \u46308 \u50632 \u49845 \u45768 \u45796 . \u49552 \u45149 \u51060  \u52264 \u44032 \u50892 \u51276 \u49845 \u45768 \u45796 . \u54616 \u51648 \u47564  \u50620 \u44404 \u50640 \u45716  \u45236 \u48372 \u51060 \u51648  \u50506 \u50520 \u49845 \u45768 \u45796 . \u51077 \u49696 \u51012  \u44985  \u45796 \u47932 \u44256  \u49688 \u51652 \u51012  \u48148 \u46972 \u48372 \u50520 \u49845 \u45768 \u45796 .\
\uc0\u49688 \u51652 \u51060  \u52380 \u52380 \u55176  \u47800 \u51012  \u46028 \u47160 \u49845 \u45768 \u45796 . \u47928  \u51901 \u51004 \u47196  \u44152 \u50612 \u44032 \u45796 \u44032 , \u44032 \u44172  \u47928 \u49552 \u51105 \u51060 \u50640  \u49552 \u51012  \u50617 \u51004 \u47732 \u49436  \u47688 \u52628 \u50632 \u49845 \u45768 \u45796 . \u46244 \u47484  \u46028 \u50500 \u48372 \u51648  \u50506 \u51008  \u52292  \u51473 \u50620 \u44144 \u47160 \u49845 \u45768 \u45796 .\
"7\uc0\u45380  \u51204 \u50640  \u45328  \u45236 \u51923 \u51008  \u44148  \u49884 \u51089 \u50640  \u48520 \u44284 \u54664 \u50612 ."\
\uc0\u47928 \u51060  \u50676 \u47532 \u44256  \u45803 \u54804 \u49845 \u45768 \u45796 .\
\uc0\u49436 \u50980 \u51008  \u44536  \u51088 \u47532 \u50640 \u49436  \u54620 \u46041 \u50504  \u50880 \u51649 \u51060 \u51648  \u50506 \u50520 \u49845 \u45768 \u45796 . \u48712  \u44032 \u44172  \u50504 \u50640  \u54844 \u51088  \u49436 \u49436 , \u49688 \u51652 \u51060  \u49324 \u46972 \u51652  \u47928 \u51012  \u48148 \u46972 \u48372 \u50520 \u49845 \u45768 \u45796 . \u49552 \u51060  \u48120 \u49464 \u54616 \u44172  \u46504 \u47160 \u49845 \u45768 \u45796 . \u48516 \u45432 \u51064 \u51648 , \u46160 \u47140 \u50880 \u51064 \u51648 . \u50500 \u45768 \u47732  \u50724 \u47019 \u46041 \u50504  \u55148 \u48120 \u54616 \u44172 \u47564  \u54408 \u50612 \u50772 \u45912  \u51032 \u49900 \u51060  \u51060 \u51228  \u47561  \u54869 \u49888 \u51004 \u47196  \u44403 \u50612 \u51648 \u45716  \u44536  \u49692 \u44036 \u51032  \u44048 \u44033 \u51064 \u51648 . \u49436 \u50980 \u51008  \u49828 \u49828 \u47196 \u46020  \u51221 \u54869 \u55176  \u50508  \u49688  \u50630 \u50632 \u49845 \u45768 \u45796 . \u45257 \u51109 \u44256  \u50694  \u54805 \u44305 \u46321 \u51060  \u50969  \u54616 \u45716  \u49548 \u47532 \u47484  \u45256 \u49845 \u45768 \u45796 . \u44032 \u44172  \u48150 \u50640 \u49436  \u49884 \u51109  \u49345 \u51064 \u51060  \u51664 \u51012  \u45208 \u47476 \u45716  \u49548 \u47532 \u44032  \u46308 \u47160 \u49845 \u45768 \u45796 . \u49464 \u49345 \u51008  \u50500 \u47924 \u44163 \u46020  \u48148 \u45072  \u44172  \u50630 \u45716  \u44163 \u52376 \u47100  \u54217 \u48276 \u54616 \u44172  \u46028 \u50500 \u44032 \u44256  \u51080 \u50632 \u51648 \u47564 , \u49436 \u50980 \u51032  \u50504 \u50640 \u49436 \u45716  \u47924 \u50616 \u44032 \u44032  \u47924 \u45320 \u51648 \u44256  \u45796 \u49884  \u49939 \u51060 \u45716  \u51473 \u51060 \u50632 \u49845 \u45768 \u45796 .\
\uc0\u45796 \u47564  \u54620  \u44032 \u51648 \u45716  \u48516 \u47749 \u54644 \u51276 \u49845 \u45768 \u45796 .\
7\uc0\u45380  \u51204 \u50640  \u45328  \u45236 \u51923 \u51008  \u44148  \u49884 \u51089 \u50640  \u48520 \u44284 \u54664 \u50612 . \u51060  \u47568 \u51008 , \u51088 \u49888 \u51060  \u49892 \u51228 \u47196  \u47956 \u44032 \u47484  \u54664 \u45796 \u45716  \u46907 \u51060 \u50632 \u49845 \u45768 \u45796 . \u49688 \u51652 \u51060  \u44536  \u49324 \u44148 \u50640  \u44060 \u51077 \u46104 \u50612  \u51080 \u45796 \u45716  \u44163 \u51012 . \u50864 \u50672 \u51060  \u50500 \u45768 \u50632 \u45796 \u45716  \u44163 \u51012 . 7\u45380  \u46041 \u50504  \u49436 \u50980 \u51060  \u50612 \u47156 \u54411 \u54616 \u44172 \u47564  \u45712 \u44808 \u45912  \u44163 \u51060  \u50724 \u45720  \u51060  \u54620  \u47928 \u51109 \u51004 \u47196  \u54805 \u53468 \u47484  \u44054 \u52628 \u50632 \u49845 \u45768 \u45796 . \u44536  \u47568 \u51060  \u54620 \u54200 \u51004 \u47196 \u45716  \u46160 \u47140 \u50912 \u44256 , \u54620 \u54200 \u51004 \u47196 \u45716  \u51060 \u49345 \u54616 \u44172 \u46020  \u49704 \u53685 \u51060  \u53944 \u51060 \u45716  \u44163  \u44057 \u50520 \u49845 \u45768 \u45796 . \u45236 \u44032  \u51096 \u47803 \u54620  \u44172  \u50500 \u45768 \u50632 \u45796 \u45716  \u54869 \u51064 \u51060  \u51060 \u47111 \u44172  \u46244 \u45734 \u44172  \u50724 \u45796 \u45768 . \u49436 \u50980 \u51008  \u45576 \u51012  \u44985  \u44048 \u50520 \u49845 \u45768 \u45796 . \u46888 \u44144 \u50868  \u44163 \u51060  \u45576  \u50504 \u50640 \u49436  \u48128 \u47140 \u50724 \u47140 \u45796  \u47688 \u52628 \u50632 \u49845 \u45768 \u45796 .\
\uc0\u49436 \u50980 \u51008  \u52380 \u52380 \u55176  \u50526 \u52824 \u47560 \u47484  \u48279 \u50632 \u49845 \u45768 \u45796 . \u51032 \u51088 \u47484  \u45132 \u50612 \u45817 \u44200  \u50505 \u50520 \u49845 \u45768 \u45796 . \u54648 \u46300 \u54256 \u51012  \u49552 \u50640  \u51536 \u50632 \u49845 \u45768 \u45796 . \u49888 \u44256 \u54616 \u44144 \u45208 , \u45572 \u44400 \u44032 \u50640 \u44172  \u50508 \u47532 \u44144 \u45208 , \u45817 \u51109  \u47924 \u50616 \u44032 \u47484  \u54644 \u50556  \u54624  \u44163  \u44057 \u51008  \u52649 \u46041 \u51060  \u51068 \u50632 \u51648 \u47564  \u44985  \u45580 \u47104 \u49845 \u45768 \u45796 . \u51648 \u44552  \u45817 \u51109  \u50880 \u51649 \u51060 \u45716  \u44148  \u50500 \u47924  \u55192 \u51060  \u50630 \u50632 \u49845 \u45768 \u45796 . 7\u45380 \u51060 \u45208  \u51648 \u45212  \u51068 \u51060 \u44256 , \u51613 \u44144 \u46972 \u44256  \u54624  \u47564 \u54620  \u44163 \u51060  \u49436 \u50980  \u49552 \u50504 \u50640 \u45716  \u50500 \u47924 \u44163 \u46020  \u50630 \u50632 \u49845 \u45768 \u45796 .\
\uc0\u44536 \u46412  \u44032 \u44172  \u50976 \u47532 \u47928  \u45320 \u47672 \u47196  \u51221 \u55148 \u44032  \u48372 \u50688 \u49845 \u45768 \u45796 .\
\uc0\u51221 \u55148 \u45716  \u44032 \u44172  \u50526 \u50640 \u49436  \u51104 \u44624  \u47688 \u52628 \u50632 \u45796 \u44032 , \u50504 \u51004 \u47196  \u46308 \u50612 \u50724 \u51648  \u50506 \u44256  \u47928 \u48150 \u50640  \u49440  \u52292 \u47196  \u49436 \u50980 \u51012  \u48148 \u46972 \u48372 \u50520 \u49845 \u45768 \u45796 . \u49436 \u50980 \u46020  \u44536  \u49884 \u49440 \u51012  \u48155 \u50520 \u49845 \u45768 \u45796 . \u46160  \u49324 \u46988 \u51008  \u50976 \u47532  \u54620  \u51109 \u51012  \u49324 \u51060 \u50640  \u46160 \u44256  \u51104 \u49884  \u47560 \u51452  \u48372 \u50520 \u49845 \u45768 \u45796 . \u51221 \u55148 \u45716  \u47568 \u51012  \u44152 \u51648  \u50506 \u50520 \u49845 \u45768 \u45796 . \u44536 \u45285  \u48148 \u46972 \u48372 \u50520 \u49845 \u45768 \u45796 . \u49436 \u50980 \u51032  \u50620 \u44404 \u51012 , \u44032 \u44172  \u50504 \u51032  \u48712  \u51032 \u51088 \u47484 , \u44536 \u47532 \u44256  \u50500 \u51060 \u44032  \u50630 \u45796 \u45716  \u44163 \u51012  \u54869 \u51064 \u54616 \u46319  \u44032 \u44172  \u50504 \u51012  \u54620  \u48264  \u54993 \u50632 \u49845 \u45768 \u45796 . \u44536  \u45576  \u50504 \u50640  \u47924 \u50616 \u44032 \u44032  \u46308 \u50612  \u51080 \u50632 \u49845 \u45768 \u45796 . \u49436 \u50980 \u51008  \u44536 \u44163 \u51060  \u47924 \u50631 \u51064 \u51648  \u51060 \u47492 \u51012  \u48537 \u51068  \u49688  \u50630 \u50632 \u51648 \u47564 , 7\u45380  \u51204 \u50640  \u48372 \u45912  \u51221 \u55148 \u51032  \u45576 \u44284 \u45716  \u45804 \u46992 \u49845 \u45768 \u45796 . 7\u45380  \u51204  \u51221 \u55148 \u51032  \u45576 \u50640 \u45716  \u45800 \u54840 \u54632 \u44284  \u45257 \u51221 \u54632 \u51060  \u51080 \u50632 \u49845 \u45768 \u45796 . \u50724 \u45720 \u51032  \u45576 \u50640 \u45716  \u47956 \u44032  \u45796 \u47480  \u44163 \u51060  \u49438 \u50668  \u51080 \u50632 \u49845 \u45768 \u45796 . \u44536 \u44163 \u51060  \u47924 \u50631 \u51064 \u51648  \u49436 \u50980 \u51008  \u50500 \u51649  \u51069 \u50612 \u45244  \u49688  \u50630 \u50632 \u49845 \u45768 \u45796 .\
\uc0\u51221 \u55148 \u45716  \u44536 \u45824 \u47196  \u47800 \u51012  \u46028 \u47140  \u44264 \u47785 \u51012  \u44152 \u50612 \u44052 \u49845 \u45768 \u45796 . \u49436 \u50980 \u51008  \u44536  \u46263 \u47784 \u49845 \u51060  \u49324 \u46972 \u51656  \u46412 \u44620 \u51648  \u48148 \u46972 \u48372 \u50520 \u49845 \u45768 \u45796 . \u50724 \u45720  \u51060  \u44264 \u47785 \u50640 \u49436  \u46160  \u49324 \u46988 \u51060  \u52264 \u47168 \u47196  \u45208 \u53440 \u45228 \u49845 \u45768 \u45796 . \u49688 \u51652 \u44284  \u51221 \u55148 . \u49436 \u47196  \u51204 \u54784  \u45796 \u47480  \u45576 \u48731 \u51012  \u44032 \u51652  \u46160  \u49324 \u46988 \u51060 . \u49436 \u50980 \u51008  \u54648 \u46300 \u54256 \u51012  \u53441 \u51088  \u50948 \u50640  \u45236 \u47140 \u45459 \u51004 \u47732 \u49436  \u49373 \u44033 \u54664 \u49845 \u45768 \u45796 . \u51060 \u51228  \u47956 \u44032 \u44032  \u50880 \u51649 \u51060 \u44592  \u49884 \u51089 \u54616 \u44256  \u51080 \u50632 \u49845 \u45768 \u45796 . \u44536  \u55120 \u47492 \u51060  \u50612 \u46356 \u47196  \u54693 \u54624 \u51648  \u50500 \u51649  \u50508  \u49688  \u50630 \u50632 \u49845 \u45768 \u45796 . \u54616 \u51648 \u47564  \u49436 \u50980 \u51008  \u50508 \u44256  \u51080 \u50632 \u49845 \u45768 \u45796 . \u51060 \u48264 \u50640 \u45716  \u54844 \u51088  \u44048 \u45817 \u54616 \u51648  \u50506 \u50500 \u46020  \u46112 \u51648  \u47784 \u47480 \u45796 \u45716  \u44163 \u51012 .\
