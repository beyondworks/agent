\f0\fs24 \cf0 [\uc0\u52309 \u53552 1] \u49884 \u51109  \u44264 \u47785 \u50640 \u49436  \u47560 \u51452 \u52828  \u50620 \u44404  \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \u9473 \
\uc0\u50612 \u46500  \u50620 \u44404 \u51008  \u50500 \u47924 \u47532  \u51082 \u51004 \u47140  \u54644 \u46020  \u51648 \u50892 \u51648 \u51648  \u50506 \u49845 \u45768 \u45796 . \u53945 \u55176  \u44536  \u50620 \u44404 \u51060  \u44618 \u51008  \u49345 \u52376 \u50752  \u54632 \u44760  \u44032 \u49844  \u44618 \u51060  \u49352 \u44200 \u51652  \u44163 \u51060 \u46972 \u47732  \u45908 \u50865  \u44536 \u47111 \u49845 \u45768 \u45796 . \u51221 \u55148 \u44032  \u44536  \u50620 \u44404 \u51012  \u45796 \u49884  \u48372 \u44172  \u46108  \u44163 \u51008 , \u50500 \u47924 \u44163 \u46020  \u44592 \u45824 \u54616 \u51648  \u50506 \u50520 \u45912  \u54217 \u48276 \u54620  \u50724 \u54980 \u51032  \u51068 \u51060 \u50632 \u49845 \u45768 \u45796 .\
2024\uc0\u45380  10\u50900 \u51032  \u50612 \u45712  \u54217 \u51068  \u50724 \u54980 , \u47928 \u51221 \u55148 \u45716  \u51648 \u48169 \u51032  \u54620  \u51204 \u53685 \u49884 \u51109  \u54665 \u49324 \u51109  \u54620 \u48373 \u54032 \u50640  \u49436  \u51080 \u50632 \u49845 \u45768 \u45796 . 65\u49332 \u51032  \u45208 \u51060 \u50640 \u46020  \u44400 \u45908 \u45908 \u44592  \u54616 \u45208  \u50630 \u51060  \u45800 \u51221 \u54616 \u44172  \u52264 \u47140 \u51077 \u51008  \u47784 \u49845 \u51008  \u51452 \u48320  \u49324 \u46988 \u46308 \u51032  \u49884 \u49440 \u51012  \u51088 \u50672 \u49828 \u47101 \u44172  \u45132 \u50612 \u45817 \u44220 \u49845 \u45768 \u45796 . \u44536 \u45376 \u45716  \u51473 \u44204 \u44592 \u50629 \u51032  \u45824 \u54364 \u50688 \u44256 , \u51060 \u48264  \u54665 \u49324 \u45716  \u51648 \u50669  \u49345 \u44428 \u51012  \u49332 \u47532 \u44592  \u50948 \u54620  \u51088 \u47532 \u50688 \u49845 \u45768 \u45796 . \u54924 \u49324  \u51060 \u47492 \u51004 \u47196  \u54980 \u50896 \u50640  \u52280 \u50668 \u54620  \u53552 \u46972  \u51649 \u51217  \u51088 \u47532 \u47484  \u51648 \u53412 \u44256  \u51080 \u50632 \u45716 \u45936 , \u53580 \u51060 \u54532  \u52964 \u54021 \u51060  \u45149 \u45208 \u44256  \u44288 \u44228 \u51088 \u46308 \u44284  \u51064 \u49324 \u47484  \u45208 \u45576  \u46244  \u51221 \u55148 \u45716  \u51104 \u49884  \u54844 \u51088  \u49884 \u51109  \u44264 \u47785 \u51012  \u44144 \u45776 \u44592 \u47196  \u54664 \u49845 \u45768 \u45796 .\
\uc0\u50612 \u47540  \u46412 \u48512 \u53552  \u51204 \u53685 \u49884 \u51109 \u51032  \u45252 \u49352 \u47484  \u51339 \u50500 \u54664 \u44144 \u46304 \u50836 . \u49373 \u49440  \u44413 \u45716  \u45252 \u49352 , \u44592 \u47492  \u46160 \u47480  \u51204  \u45252 \u49352 , \u50728 \u44054  \u44400 \u44163 \u51656 \u44144 \u47532  \u45252 \u49352 \u44032  \u48373 \u51105 \u54616 \u44172  \u46244 \u49438 \u51064  \u44536  \u44264 \u47785 \u51060  \u50784 \u51648  \u47560 \u51020 \u51012  \u54200 \u50504 \u54616 \u44172  \u54644 \u51452 \u50632 \u49845 \u45768 \u45796 . \u50724 \u49901  \u45380 \u51060  \u45336 \u45716  \u49464 \u50900 \u51012  \u52824 \u50676 \u54616 \u44172  \u49332 \u50500 \u50724 \u47732 \u49436  \u47566 \u51008  \u44163 \u51060  \u48320 \u54664 \u51648 \u47564 , \u44536  \u45252 \u49352 \u47564 \u53372 \u51008  \u50612 \u47540  \u46412  \u44592 \u50613  \u44536 \u45824 \u47196 \u50668 \u49436  \u51088 \u44984 \u47564  \u44536 \u47532 \u50892 \u51276 \u49845 \u45768 \u45796 . \u49688 \u54665 \u48708 \u49436  \u51060 \u49688 \u51652 \u51060  \u46244 \u46384 \u46972 \u50724 \u47140  \u54664 \u51648 \u47564 , \u51221 \u55148 \u45716  \u49552 \u51012  \u49332 \u51677  \u46308 \u50612  \u54844 \u51088  \u51080 \u44256  \u49910 \u45796 \u45716  \u46907 \u51012  \u51204 \u54664 \u49845 \u45768 \u45796 . \u49688 \u51652 \u51008  \u51104 \u49884  \u47672 \u47943 \u44144 \u47532 \u45796 \u44032  \u44256 \u44060 \u47484  \u49689 \u51060 \u44256  \u51077 \u44396  \u51901 \u50640  \u45224 \u50520 \u49845 \u45768 \u45796 . 15\u45380  \u45336 \u44172  \u54632 \u44760 \u54644 \u50728  \u49884 \u44036 \u51060  \u47564 \u46308 \u50612 \u45240  \u54840 \u55137 \u51060 \u50632 \u49845 \u45768 \u45796 .\
\uc0\u49884 \u51109  \u50504 \u51901  \u44264 \u47785 \u51004 \u47196  \u46308 \u50612 \u49436 \u51088  \u53356 \u44256  \u51089 \u51008  \u44032 \u44172 \u46308 \u51060  \u45796 \u45797 \u45796 \u45797  \u48537 \u50612  \u51080 \u50632 \u44256 , \u54217 \u51068  \u45230 \u51060 \u46972  \u54620 \u49328 \u54620  \u54200 \u51060 \u50632 \u49845 \u45768 \u45796 . \u51221 \u55148 \u45716  \u52380 \u52380 \u55176  \u48156 \u44152 \u51020 \u51012  \u50734 \u44592 \u45796 \u44032  \u54620 \u51901  \u44396 \u49437 \u50640  \u51312 \u44536 \u47587 \u44172  \u51088 \u47532 \u47484  \u51105 \u51008  \u48152 \u52268 \u44032 \u44172  \u50526 \u50640 \u49436  \u51200 \u46020  \u47784 \u47476 \u44172  \u47688 \u52628 \u50632 \u49845 \u45768 \u45796 . \u44032 \u44172  \u50526 \u51901 \u50640  \u45459 \u51064  \u51089 \u51008  \u54540 \u46972 \u49828 \u54001  \u51032 \u51088  \u50948 \u50640  \u45224 \u51088 \u50500 \u51060  \u54616 \u45208 \u44032  \u54844 \u51088  \u50505 \u50500  \u51080 \u50632 \u49845 \u45768 \u45796 . \u50500 \u51060 \u45716  \u47924 \u47502  \u50948 \u50640  \u44536 \u47495 \u51012  \u50732 \u47140 \u45459 \u44256  \u51219 \u44032 \u46973 \u51656 \u51012  \u54616 \u47732 \u49436  \u47956 \u44032 \u47484  \u50724 \u47932 \u50724 \u47932  \u47673 \u44256  \u51080 \u50632 \u45716 \u45936 , \u44536  \u50694 \u47784 \u49845 \u51060  \u51060 \u49345 \u54616 \u44172 \u46020  \u45231 \u49444 \u51648  \u50506 \u50520 \u49845 \u45768 \u45796 .\
\uc0\u51221 \u55148 \u45716  \u44152 \u51020 \u51012  \u47688 \u52628 \u44256  \u50500 \u51060 \u51032  \u50620 \u44404 \u51012  \u44032 \u47564 \u55176  \u48148 \u46972 \u48372 \u50520 \u49845 \u45768 \u45796 . \u46020 \u53680 \u54620  \u45576 \u44732 \u54400 . \u50976 \u45212 \u55176  \u51652 \u54616 \u44256  \u44256 \u47480  \u45576 \u50041 . \u51077 \u51012  \u50724 \u47932 \u44144 \u47540  \u46412 \u47560 \u45796  \u50724 \u47480 \u51901  \u48808 \u50640  \u49332 \u51677  \u54028 \u51060 \u45716  \u48372 \u51312 \u44060 . \u51221 \u55148 \u51032  \u44032 \u49844 \u51060  \u53237  \u45236 \u47140 \u50505 \u50520 \u49845 \u45768 \u45796 . \u51200  \u50500 \u51060 \u45716 . \u44845  \u50500 \u46308  \u48124 \u51456 \u51012  \u45806 \u50520 \u49845 \u45768 \u45796 . \u51665 \u50640  \u51080 \u45716  \u45217 \u51008  \u50536 \u48276  \u49549 \u50640 \u49436  \u49688 \u48177  \u48264  \u46308 \u50668 \u45796 \u48420 \u45912 , \u48124 \u51456 \u51060  \u50612 \u47540  \u46412  \u52237 \u51008  \u49324 \u51652 \u44284  \u45320 \u47924 \u46020  \u45806 \u50500  \u51080 \u50632 \u49845 \u45768 \u45796 . \u51219 \u44032 \u46973 \u51012  \u51540  \u49552 \u51032  \u47784 \u50577 \u49352 , \u44256 \u44060 \u47484  \u49332 \u51677  \u44592 \u50872 \u51060 \u45716  \u48260 \u47495 , \u47956 \u44032 \u47484  \u50489 \u51012  \u46412  \u45576 \u51012  \u44032 \u45720 \u44172  \u46888 \u45716  \u54364 \u51221 \u44620 \u51648 . \u51221 \u55148 \u45716  \u49704 \u51060  \u47561 \u55176 \u45716  \u44163 \u51012  \u45712 \u45180 \u47732 \u49436 \u46020  \u45576 \u51012  \u46524 \u51648  \u47803 \u54664 \u49845 \u45768 \u45796 . \u52376 \u51020 \u50644  \u52265 \u44033 \u51060 \u44192 \u44144 \u45768  \u49910 \u50632 \u49845 \u45768 \u45796 . \u45806 \u51008  \u50500 \u51060 \u45716  \u49464 \u49345 \u50640  \u50620 \u47560 \u46304 \u51648  \u51080 \u51012  \u49688  \u51080 \u45796 \u44256  \u49828 \u49828 \u47196 \u47484  \u45804 \u47020 \u49845 \u45768 \u45796 . \u54616 \u51648 \u47564  \u48380 \u49688 \u47197 , \u48148 \u46972 \u48380 \u49688 \u47197  \u44536  \u49373 \u44033 \u51060  \u55124 \u46308 \u47160 \u49845 \u45768 \u45796 . \u51088 \u44592 \u46020  \u47784 \u47476 \u44172  \u54620  \u48156 \u51677  \u50526 \u51004 \u47196  \u45236 \u46363 \u50632 \u49845 \u45768 \u45796 .\
\uc0\u48148 \u47196  \u44536 \u46412 , \u44032 \u44172  \u50504 \u51901 \u50640 \u49436  \u50668 \u51088  \u54620  \u47749 \u51060  \u45208 \u50772 \u49845 \u45768 \u45796 . \u50526 \u52824 \u47560 \u47484  \u46160 \u47476 \u44256  \u48152 \u52268  \u44536 \u47495 \u51012  \u50577 \u49552 \u50640  \u46308 \u44256  \u45208 \u50724 \u45716  \u44536  \u50668 \u51088 \u51032  \u50620 \u44404 \u51012  \u48372 \u45716  \u49692 \u44036 , \u51221 \u55148 \u51032  \u46160  \u48156 \u51060  \u48148 \u45797 \u50640  \u48537 \u50612 \u48260 \u47160 \u49845 \u45768 \u45796 . 7\u45380 \u51060 \u46972 \u45716  \u49884 \u44036 \u51060  \u55128 \u47104 \u50612 \u46020  \u44536  \u50620 \u44404 \u47564 \u51008  \u51082 \u55176 \u51648  \u50506 \u50520 \u49845 \u45768 \u45796 .\
\uc0\u54620 \u49436 \u50980 \u51060 \u50632 \u49845 \u45768 \u45796 .\
7\uc0\u45380  \u51204 , \u54924 \u49324  \u44277 \u44552 \u51012  \u54945 \u47161 \u54620  \u54800 \u51032 \u47196  \u51923 \u44200 \u45212  \u47728 \u45712 \u47532 . \u48277 \u51201  \u51312 \u52824 \u44620 \u51648  \u47560 \u47924 \u47532 \u46104 \u50632 \u44256 , \u50500 \u46308 \u44284 \u51032  \u51060 \u54844 \u46020  \u51221 \u47532 \u46104 \u50632 \u44256 , \u44536 \u47111 \u44172  \u45796 \u49884 \u45716  \u48380  \u51068 \u51060  \u50630 \u51012  \u44144 \u46972 \u44256  \u49373 \u44033 \u54664 \u45912  \u44536  \u49324 \u46988 \u51060 \u50632 \u49845 \u45768 \u45796 . \u44536 \u47088 \u45936  \u51648 \u44552  \u51200 \u44592 \u50640  \u51080 \u50632 \u49845 \u45768 \u45796 . \u48152 \u52268 \u44032 \u44172  \u50526 \u52824 \u47560 \u47484  \u46160 \u47476 \u44256 , \u49884 \u51109  \u44264 \u47785 \u50640 \u49436 , \u50500 \u51060 \u51032  \u44536 \u47495 \u50640  \u51219 \u44032 \u46973 \u51004 \u47196  \u48152 \u52268 \u51012  \u50732 \u47140 \u51452 \u47728  \u50500 \u47924 \u47111 \u51648 \u46020  \u50506 \u44172  \u49332 \u50500 \u44032 \u44256  \u51080 \u50632 \u49845 \u45768 \u45796 . \u49464 \u50900 \u51060  \u55128 \u47084  \u47672 \u47532 \u52852 \u46973 \u51060  \u51687 \u50500 \u51648 \u44256  \u50620 \u44404 \u50640  \u54588 \u47196 \u51032  \u55124 \u51201 \u51060  \u49373 \u44220 \u51648 \u47564 , \u45576 \u47588 \u50752  \u51077 \u47588 \u45716  \u44536 \u45824 \u47196 \u50688 \u49845 \u45768 \u45796 . \u51221 \u55148 \u45716  \u50500 \u47924  \u47568 \u46020  \u54624  \u49688  \u50630 \u50632 \u49845 \u45768 \u45796 . \u47785 \u51060  \u47561 \u54784 \u48260 \u47536  \u44163  \u44057 \u50520 \u44256 , \u51088 \u49888 \u51060  \u49704 \u51012  \u49772 \u44256  \u51080 \u45716 \u51648 \u51312 \u52264  \u51032 \u49885 \u54616 \u51648  \u47803 \u54664 \u49845 \u45768 \u45796 .\
\uc0\u51200  \u50500 \u51060 \u44032  \u48124 \u51456 \u51012  \u45806 \u50520 \u45796 \u47732 . \u44536 \u47532 \u44256  \u51200  \u50500 \u51060 \u51032  \u50628 \u47560 \u44032  \u49436 \u50980 \u51060 \u46972 \u47732 . \u50500 \u51060 \u45716  \u51648 \u44552  \u47751  \u49332 \u52196  \u46104 \u50612  \u48372 \u50688 \u49845 \u45768 \u45796 . \u51068 \u44273  \u49332 , \u47566 \u50500 \u50556  \u50668 \u45919  \u49332 . \u49436 \u50980 \u51060  \u54924 \u49324 \u50640 \u49436  \u51923 \u44200 \u45212  \u44172  7\u45380  \u51204 \u51060 \u50632 \u51004 \u45768 , \u44536  \u51649 \u54980 \u50640  \u51076 \u49888 \u51012  \u54664 \u45796 \u45716  \u44228 \u49328 \u51060  \u47582 \u50500 \u46504 \u50612 \u51276 \u49845 \u45768 \u45796 . \u44536  \u49373 \u44033 \u51060  \u47672 \u47551 \u49549 \u50640 \u49436  \u46385  \u47582 \u50500  \u46308 \u50612 \u50724 \u45716  \u49692 \u44036 , \u51221 \u55148 \u51032  \u49552 \u45149 \u51060  \u52264 \u44049 \u44172  \u44403 \u50612 \u48260 \u47160 \u49845 \u45768 \u45796 . \u49552 \u50640  \u46308 \u44256  \u51080 \u45912  \u54648 \u46300 \u48177  \u45128 \u51060  \u49552 \u44032 \u46973 \u51012  \u54028 \u44256 \u46300 \u45716  \u44172  \u45712 \u44788 \u51276 \u51648 \u47564 , \u44536 \u44163 \u51312 \u52264  \u51228 \u45824 \u47196  \u51064 \u49885 \u54616 \u44592  \u50612 \u47140 \u50912 \u49845 \u45768 \u45796 . \u50728  \u49888 \u44221 \u51060  \u51200  \u50500 \u51060  \u54620  \u47749 \u50640 \u44172 \u47196  \u50144 \u47140  \u51080 \u50632 \u49845 \u45768 \u45796 .\
\uc0\u49436 \u50980 \u51008  \u44536 \u46412 \u44620 \u51648 \u46020  \u51221 \u55148 \u47484  \u48156 \u44204 \u54616 \u51648  \u47803 \u54620  \u44163  \u44057 \u50520 \u49845 \u45768 \u45796 . \u50500 \u51060  \u50526 \u50640  \u51900 \u44536 \u47140  \u50505 \u50500  \u47956 \u44032 \u47484  \u45208 \u51649 \u54616 \u44172  \u49549 \u49325 \u51060 \u44256  \u51080 \u50632 \u44144 \u46304 \u50836 . \u50500 \u51060 \u44032  \u50473  \u50883 \u51004 \u47728  \u44256 \u44060 \u47484  \u45124 \u45909 \u51060 \u51088 , \u49436 \u50980 \u46020  \u46384 \u46972  \u50883 \u50632 \u49845 \u45768 \u45796 . \u50724 \u47004 \u47564 \u50640  \u48372 \u45716  \u44536  \u50883 \u51020 \u51060  \u51221 \u55148 \u51032  \u45576 \u50640 \u45716  \u51060 \u49345 \u54616 \u47532 \u47564 \u53372  \u49440 \u47749 \u54616 \u44172  \u46308 \u50612 \u50772 \u49845 \u45768 \u45796 . \u50696 \u51204 \u50640  \u50500 \u46308  \u44225 \u50640 \u49436  \u48372 \u45912  \u44536  \u54364 \u51221 \u44284  \u45796 \u47476 \u51648  \u50506 \u50520 \u49845 \u45768 \u45796 . \u50500 \u45768 , \u50724 \u55176 \u47140  \u45908  \u54200 \u50504 \u54644  \u48372 \u50688 \u49845 \u45768 \u45796 .\
\uc0\u44536 \u47088 \u45936  \u48148 \u47196  \u44536 \u46412  \u49436 \u50980 \u51060  \u44256 \u44060 \u47484  \u46308 \u50632 \u49845 \u45768 \u45796 . \u44536 \u47532 \u44256  \u44536  \u49884 \u49440  \u45149 \u50640  \u51221 \u55148 \u44032  \u51080 \u50632 \u49845 \u45768 \u45796 .\
\uc0\u49692 \u44036 , \u46160  \u49324 \u46988 \u51032  \u45576 \u51060  \u47560 \u51452 \u52452 \u49845 \u45768 \u45796 .\
\uc0\u49436 \u50980 \u51032  \u50620 \u44404 \u50640 \u49436  \u50883 \u51020 \u44592 \u44032  \u49324 \u46972 \u51276 \u49845 \u45768 \u45796 . \u48380 \u50640  \u54607 \u44592 \u44032  \u44032 \u49884 \u47732 \u49436  \u54364 \u51221 \u51060  \u46385 \u46385 \u54616 \u44172  \u44403 \u50612 \u51276 \u44256 , \u50500 \u51060 \u51032  \u50612 \u44648  \u50948 \u50640  \u50732 \u47140 \u46164  \u49552 \u51060  \u45576 \u50640  \u46916 \u44172  \u46504 \u47160 \u49845 \u45768 \u45796 . \u54616 \u51648 \u47564  \u49436 \u50980 \u51008  \u48708 \u47749 \u51012  \u51648 \u47476 \u51648 \u46020 , \u46244 \u46028 \u50500  \u45804 \u50500 \u45208 \u51648 \u46020  \u50506 \u50520 \u49845 \u45768 \u45796 . \u44596  \u52840 \u47925 \u51060  \u55128 \u47104 \u49845 \u45768 \u45796 . \u44536 \u47532 \u44256  \u49436 \u50980 \u51008  \u47560 \u52824  \u52376 \u51020 \u48512 \u53552  \u50500 \u47924 \u44163 \u46020  \u48372 \u51648  \u47803 \u54620  \u49324 \u46988 \u52376 \u47100 , \u52380 \u52380 \u55176  \u45576 \u44600 \u51012  \u44144 \u46160 \u50632 \u49845 \u45768 \u45796 . \u51312 \u50857 \u55176  \u50500 \u51060 \u51032  \u49552 \u51012  \u51105 \u50520 \u49845 \u45768 \u45796 . \u44536 \u47532 \u44256  \u44032 \u44172  \u50504 \u51901 \u51004 \u47196  \u46308 \u50612 \u44032  \u48260 \u47160 \u49845 \u45768 \u45796 .\
\uc0\u47928 \u51060  \u45803 \u54804 \u49845 \u45768 \u45796 .\
\uc0\u51221 \u55148 \u45716  \u44536  \u51088 \u47532 \u50640  \u54844 \u51088  \u45224 \u44200 \u51276 \u49845 \u45768 \u45796 . \u49884 \u51109  \u44264 \u47785 \u50640 \u45716  \u50668 \u51204 \u55176  \u49324 \u46988 \u46308 \u51060  \u50724 \u44032 \u44256  \u51080 \u50632 \u44256 , \u50612 \u46356 \u49440 \u44032  \u49345 \u51064 \u51032  \u47785 \u49548 \u47532 \u44032  \u46308 \u47140 \u50724 \u44256  \u51080 \u50632 \u49845 \u45768 \u45796 . \u54616 \u51648 \u47564  \u51221 \u55148 \u51032  \u44480 \u50640 \u45716  \u50500 \u47924 \u44163 \u46020  \u46308 \u47532 \u51648  \u50506 \u50520 \u49845 \u45768 \u45796 . \u44536 \u45376 \u45716  \u49436 \u50980 \u51060  \u49324 \u46972 \u51652  \u44032 \u44172  \u47928 \u51012  \u54620 \u52280  \u48148 \u46972 \u48372 \u45796 \u44032 , \u51077 \u49696 \u51012  \u44985  \u45796 \u47932 \u50632 \u49845 \u45768 \u45796 . \u47784 \u47480  \u52377 . \u44536  \u49324 \u46988 \u51008  \u48169 \u44552  \u51088 \u49888 \u51012  \u48372 \u44256 \u46020  \u47784 \u47480  \u52377 \u54664 \u49845 \u45768 \u45796 .\
\uc0\u47956 \u44032 \u47484  \u49704 \u44592 \u44256  \u51080 \u45796 \u45716  \u49373 \u44033 \u51060  \u48923 \u49549  \u44618 \u51060  \u48128 \u47140 \u50772 \u49845 \u45768 \u45796 . \u50500 \u45768 , \u54869 \u49888 \u50640  \u44032 \u44620 \u50912 \u49845 \u45768 \u45796 . 7\u45380  \u51204  \u44536 \u45216 \u48512 \u53552  \u51648 \u44552  \u51060  \u49692 \u44036 \u44620 \u51648 , \u51088 \u49888 \u51060  \u50508 \u51648  \u47803 \u54616 \u45716  \u47924 \u50616 \u44032 \u44032  \u51080 \u50632 \u45796 \u45716  \u49324 \u49892 \u51012 . \u44536 \u47532 \u44256  \u44536  \u47924 \u50616 \u44032 \u51032  \u54620 \u44032 \u50868 \u45936 \u50640  \u51200  \u50500 \u51060 \u44032  \u51080 \u45796 \u45716  \u44163 \u51012 .\
\uc0\u51221 \u55148 \u45716  \u52380 \u52380 \u55176  \u54648 \u46300 \u54256 \u51012  \u44732 \u45256 \u49845 \u45768 \u45796 . \u49688 \u54665 \u48708 \u49436  \u49688 \u51652 \u51032  \u48264 \u54840 \u47484  \u45572 \u47476 \u51088  \u49888 \u54840 \u44032  \u46160  \u48264  \u52292  \u50872 \u47532 \u44592 \u46020  \u51204 \u50640  \u51204 \u54868 \u44032  \u50672 \u44208 \u46104 \u50632 \u49845 \u45768 \u45796 . \u51221 \u55148 \u45716  \u45230 \u44256  \u51312 \u50857 \u54620  \u47785 \u49548 \u47532 \u47196  \u47568 \u54664 \u49845 \u45768 \u45796 .\
\uc0\u49688 \u51652 \u50472 , \u45208 \u50556 . \u51312 \u49324 \u54644 \u51480 . \u54620 \u49436 \u50980 . \u51648 \u44552  \u50612 \u46356 \u49436  \u47960  \u54616 \u44256  \u51080 \u45716 \u51648 , \u44536 \u47532 \u44256  \u50694 \u50640  \u51080 \u45716  \u50500 \u51060 \u44032  \u45572 \u44396  \u50500 \u51060 \u51064 \u51648 .\
\uc0\u51204 \u54868 \u47484  \u45130 \u44256  \u45208 \u49436 \u46020  \u51221 \u55148 \u45716  \u48156 \u44152 \u51020 \u51012  \u46524 \u51648  \u47803 \u54664 \u49845 \u45768 \u45796 . \u49552  \u50504 \u50640  \u51540  \u54648 \u46300 \u54256 \u51060  \u52264 \u44049 \u44172  \u45712 \u44788 \u51276 \u44256 , \u49884 \u51109  \u44264 \u47785  \u50612 \u46360 \u44032 \u50640 \u49436  \u54413 \u44200 \u50724 \u45716  \u46108 \u51109 \u44397  \u45252 \u49352 \u44032  \u53076 \u45149 \u51012  \u49828 \u52432  \u51648 \u45208 \u44052 \u49845 \u45768 \u45796 . \u51060 \u49345 \u54616 \u44172 \u46020  \u44536  \u45252 \u49352 \u44032  \u50724 \u47000 \u46108  \u44592 \u50613 \u51012  \u48520 \u47084 \u51068 \u51004 \u53040 \u49845 \u45768 \u45796 . \u49436 \u50980 \u51060  \u52376 \u51020  \u51665 \u50640  \u50772 \u51012  \u46412 , \u51452 \u48169 \u50640  \u54844 \u51088  \u49436 \u49436  \u44397 \u51012  \u45139 \u51060 \u45912  \u47784 \u49845 . \u50500 \u46308 \u51060  \u54872 \u54616 \u44172  \u50883 \u51004 \u47728  \u51064 \u49324 \u47484  \u49884 \u53412 \u45912  \u44536 \u45216  \u50500 \u52840 . \u44536 \u46412  \u51221 \u55148 \u45716  \u49549 \u51004 \u47196  \u50504 \u46020 \u54664 \u49845 \u45768 \u45796 . \u48124 \u51456 \u51060  \u44256 \u47480  \u49324 \u46988 \u51060 \u45768 \u44620 , \u48516 \u47749  \u44316 \u52270 \u51008  \u49324 \u46988 \u51068  \u44144 \u46972 \u44256 . \u51312 \u49900 \u49828 \u47101 \u51648 \u47564  \u44592 \u45824 \u54664 \u49845 \u45768 \u45796 . \u51060  \u49324 \u46988 \u51060  \u50500 \u46308  \u44225 \u50640 \u49436  \u50724 \u47000  \u54632 \u44760 \u54644 \u51460  \u44144 \u46972 \u44256 . \u52376 \u51020 \u50640 \u45716  \u44536 \u47020 \u49845 \u45768 \u45796 .\
\uc0\u44536 \u47088 \u45936  \u48520 \u44284  \u51060  \u45380  \u47564 \u50640  \u47784 \u46304  \u44163 \u51060  \u47924 \u45320 \u51276 \u49845 \u45768 \u45796 . \u49436 \u50980 \u51060  \u54924 \u49324  \u46024 \u50640  \u49552 \u51012  \u45844 \u45796 \u45716  \u51613 \u44144 \u44032  \u45208 \u50772 \u44256 , \u51221 \u55148 \u45716  \u51649 \u51217  \u47728 \u45712 \u47532 \u50640 \u44172  \u51664 \u51012  \u49912 \u46972 \u44256  \u54664 \u49845 \u45768 \u45796 . \u44536 \u44172  \u47582 \u45716  \u51068 \u51060 \u46972 \u44256  \u54869 \u49888 \u54664 \u49845 \u45768 \u45796 . \u44536 \u46412 \u45716 .\
\uc0\u51221 \u55148 \u45716  \u45576 \u51012  \u44985  \u44048 \u50520 \u45796 \u44032  \u52380 \u52380 \u55176  \u46516 \u49845 \u45768 \u45796 . \u51648 \u44552 \u51008  \u44536 \u47088  \u44592 \u50613 \u51012  \u44732 \u45244  \u46412 \u44032  \u50500 \u45768 \u50632 \u49845 \u45768 \u45796 . \u54869 \u51064 \u54644 \u50556  \u54624  \u44163 \u51060  \u51080 \u50632 \u49845 \u45768 \u45796 . \u44536 \u47532 \u44256  \u47564 \u50557  \u51088 \u49888 \u51032  \u51032 \u49900 \u51060  \u49324 \u49892 \u47196  \u46300 \u47084 \u45212 \u45796 \u47732 , 7\u45380  \u51204  \u44536  \u49324 \u44148 \u51012  \u52376 \u51020 \u48512 \u53552  \u45796 \u49884  \u46308 \u50668 \u45796 \u48400 \u50556  \u54624 \u51648 \u46020  \u47784 \u47480 \u45796 \u45716  \u49373 \u44033 \u51060  \u44032 \u49844  \u54620 \u53024 \u50640 \u49436  \u49436 \u49436 \u55176  \u44256 \u44060 \u47484  \u46308 \u50632 \u49845 \u45768 \u45796 . \u51221 \u55148 \u45716  \u52380 \u52380 \u55176  \u48156 \u44152 \u51020 \u51012  \u46028 \u47160 \u49845 \u45768 \u45796 . \u49884 \u51109  \u51077 \u44396  \u51901 \u50640 \u49436  \u49688 \u51652 \u51060  \u44592 \u45796 \u47532 \u44256  \u51080 \u51012  \u53552 \u50688 \u49845 \u45768 \u45796 . \u54616 \u51648 \u47564  \u49688 \u51652 \u50640 \u44172  \u51204 \u54868 \u47484  \u45336 \u44596  \u44536  \u49692 \u44036 \u48512 \u53552 , \u51221 \u55148 \u51032  \u44032 \u49844  \u54620 \u51901 \u50640 \u45716  \u47956 \u44032  \u51060 \u49345 \u54620  \u44048 \u44033 \u51060  \u51088 \u47532 \u47484  \u51105 \u44256  \u51080 \u50632 \u49845 \u45768 \u45796 . \u49552  \u50504 \u51032  \u54648 \u46300 \u54256 \u51060  \u47924 \u44161 \u44172  \u45712 \u44788 \u51276 \u49845 \u45768 \u45796 . \u51060 \u46412 \u44620 \u51648 \u47564  \u54644 \u46020  \u51221 \u55148 \u45716  \u47792 \u46992 \u49845 \u45768 \u45796 . \u50724 \u45720  \u51060  \u49884 \u51109  \u44264 \u47785 \u50640 \u49436 \u51032  \u51687 \u51008  \u47560 \u51452 \u52840 \u51060 , 7\u45380  \u46041 \u50504  \u44403 \u44172  \u45803 \u54784  \u51080 \u45912  \u51652 \u49892 \u51032  \u47928 \u51012  \u50668 \u45716  \u49884 \u51089 \u51060  \u46112  \u51460 \u51008 .\
