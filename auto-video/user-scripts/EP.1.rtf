\uc0\u51204 \u54868 \u44032  \u50872 \u47536  \u44163 \u51008  \u49688 \u51652 \u51060  \u54665 \u49324 \u51109  \u51077 \u44396  \u44540 \u52376 \u50640 \u49436  \u51221 \u55148 \u47484  \u44592 \u45796 \u47532 \u45912  \u52280 \u51060 \u50632 \u49845 \u45768 \u45796 . \u46160  \u48264 \u51704  \u49888 \u54840 \u44032  \u52292  \u45149 \u45208 \u44592  \u51204 \u50640  \u48155 \u50520 \u44256 , \u51687 \u51008  \u51648 \u49884 \u47484  \u46307 \u45716  \u46041 \u50504  \u49688 \u51652 \u51032  \u54364 \u51221 \u51008  \u51312 \u44552 \u46020  \u55124 \u46308 \u47532 \u51648  \u50506 \u50520 \u49845 \u45768 \u45796 . \
