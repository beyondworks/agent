\uc0\u51221 \u55148 \u45716  \u50883 \u50632 \u49845 \u45768 \u45796 .\
"\uc0\u51025 , \u46608  \u50732 \u44172 ."\
\uc0\u44032 \u44172  \u47928 \u51060  \u45803 \u54804 \u49845 \u45768 \u45796 . \u51221 \u55148 \u45716  \u44264 \u47785  \u45149  \u51901 \u51004 \u47196  \u52380 \u52380 \u55176  \u44152 \u50612 \u44032 \u44592  \u49884 \u51089 \u54664 \u49845 \u45768 \u45796 . \u48156 \u44152 \u51020 \u51060  \u50732  \u46412 \u48372 \u45796  \u44032 \u48316 \u50912 \u49845 \u45768 \u45796 . \u50500 \u51649  \u45149 \u45212  \u44172  \u50500 \u45768 \u50632 \u49845 \u45768 \u45796 . \u49436 \u50980 \u44284 \u51032  \u44288 \u44228 \u46020 , \u50500 \u51060 \u50752 \u51032  \u44288 \u44228 \u46020 , \u48124 \u51456 \u44284  \u49436 \u50980  \u49324 \u51060 \u46020 . \u47784 \u46304  \u44163 \u51060  \u51060 \u51228  \u44200 \u50864  \u49884 \u51089 \u51060 \u50632 \u49845 \u45768 \u45796 . 7\u45380 \u51060 \u46972 \u45716  \u49884 \u44036 \u51060  \u54616 \u47336 \u50500 \u52840 \u50640  \u47700 \u50892 \u51648 \u51648 \u45716  \u50506 \u51012  \u44163 \u51060 \u50632 \u49845 \u45768 \u45796 .\
\uc0\u44536 \u47000 \u46020  \u50724 \u45720 \u51008  \u44264 \u47785 \u50640  \u46308 \u50612 \u44052 \u44256 , \u50500 \u51060 \u47484  \u50504 \u50520 \u44256 , \u49436 \u50980 \u44284  \u45576 \u51012  \u47560 \u51452 \u52452 \u49845 \u45768 \u45796 .\
\uc0\u44536 \u44163 \u51004 \u47196  \u52649 \u48516 \u54620  \u49884 \u51089 \u51060 \u50632 \u49845 \u45768 \u45796 .\
\uc0\u44264 \u47785  \u50504 \u51901 \u50640 \u49436  \u49436 \u50980 \u51060  \u50500 \u46308 \u51032  \u49552 \u51012  \u51105 \u44256  \u48152 \u52268 \u51012  \u51221 \u47532 \u54616 \u44592  \u49884 \u51089 \u54664 \u49845 \u45768 \u45796 . \u44032 \u49828 \u48520 \u51012  \u53020 \u44256 , \u45252 \u48708 \u47484  \u50732 \u47532 \u44256 , \u50500 \u51060 \u44032  \u50694 \u50640 \u49436  \u49689 \u51228 \u47484  \u54204 \u52452 \u49845 \u45768 \u45796 . \u49436 \u50980 \u51008  \u44536  \u47784 \u49845 \u51012  \u45236 \u47140 \u45796 \u48372 \u47732 \u49436  \u49549 \u51004 \u47196  \u47568 \u54664 \u49845 \u45768 \u45796 .\
\uc0\u51060 \u51228 \u45716  \u45572 \u44396 \u50640 \u44172 \u46020  \u51923 \u44200 \u45208 \u51648  \u50506 \u44192 \u45796 .\
\uc0\u47568 \u51012  \u44732 \u45236 \u51648 \u45716  \u50506 \u50520 \u49845 \u45768 \u45796 . \u50500 \u51060 \u45716  \u47792 \u46992 \u49845 \u45768 \u45796 . \u54616 \u51648 \u47564  \u44536  \u47568 \u51060  \u50724 \u45720 \u48512 \u53552 \u45716  \u45796 \u47480  \u47924 \u44172 \u47484  \u44032 \u51648 \u44172  \u46104 \u50632 \u49845 \u45768 \u45796 . \u45908  \u51060 \u49345  \u54844 \u51088  \u48260 \u54000 \u45716  \u44033 \u50724 \u44032  \u50500 \u45768 \u50632 \u49845 \u45768 \u45796 . \u51060 \u51228 \u45716  \u44536 \u45285 , \u51080 \u50612 \u46020  \u46108 \u45796 \u45716  \u44163 \u51060 \u50632 \u49845 \u45768 \u45796 . \u51080 \u51012  \u51088 \u47532 \u44032  \u49373 \u44220 \u45796 \u45716  \u44163 \u51060 \u50632 \u49845 \u45768 \u45796 . \u49436 \u50980 \u51008  \u50500 \u51649  \u47784 \u46304  \u44163 \u51012  \u45236 \u47140 \u45459 \u51648  \u50506 \u50520 \u49845 \u45768 \u45796 . 7\u45380 \u51060  \u54616 \u47336  \u47564 \u50640  \u51648 \u50892 \u51656  \u49688 \u45716  \u50630 \u50632 \u49845 \u45768 \u45796 . \u54616 \u51648 \u47564  \u50724 \u45720  \u51221 \u55148 \u51032  \u45576 \u50640 \u49436  \u48376  \u44163 \u51060 , \u48124 \u51456 \u51060  \u44264 \u47785  \u48148 \u45797 \u50640  \u47924 \u47502 \u51012  \u44999 \u51008  \u44163 \u51060 , \u44536 \u47532 \u44256  \u49688 \u51652 \u51060  \u45908  \u51060 \u49345  \u51060  \u44264 \u47785  \u44540 \u52376 \u50640  \u50630 \u45796 \u45716  \u44163 \u51060 . \u44536 \u44163 \u46308 \u51060  \u51312 \u44552 \u50473 , \u50500 \u51452  \u52380 \u52380 \u55176  \u49939 \u51060 \u44592  \u49884 \u51089 \u54624  \u53552 \u50688 \u49845 \u45768 \u45796 .\
\uc0\u48152 \u52268 \u44032 \u44172  \u44036 \u54032  \u48520 \u48731 \u51060  \u53020 \u51648 \u47732 \u49436  \u44264 \u47785  \u50504 \u50640  \u51452 \u54889 \u48731 \u51060  \u48264 \u51276 \u49845 \u45768 \u45796 . \u51200 \u45377 \u51060  \u50724 \u44256  \u51080 \u50632 \u49845 \u45768 \u45796 . \u49436 \u50980 \u51008  \u45252 \u48708  \u50504 \u51012  \u46308 \u50668 \u45796 \u48372 \u47728  \u50500 \u51060 \u50640 \u44172  \u47568 \u54664 \u49845 \u45768 \u45796 .\
"\uc0\u50864 \u51652 \u50500 , \u50724 \u45720  \u51200 \u45377  \u47952  \u47673 \u44256  \u49910 \u50612 ."\
\uc0\u50500 \u51060 \u44032  \u50672 \u54596 \u51012  \u46308 \u44256  \u49373 \u44033 \u54664 \u49845 \u45768 \u45796 .\
"\uc0\u44228 \u46976 \u47568 \u51060 \u50836 ."\
"\uc0\u44536 \u47000 , \u54644 \u51460 \u44172 ."\
\uc0\u44536  \u45824 \u54868 \u44032  \u44264 \u47785  \u50504 \u50640  \u51312 \u50857 \u55176  \u48264 \u51276 \u49845 \u45768 \u45796 . \u49884 \u51109  \u44264 \u47785 \u51032  \u51200 \u45377 \u51060  \u45236 \u47140 \u50505 \u45716  \u49548 \u47532 \u52376 \u47100 . \u50500 \u51452  \u54217 \u48276 \u54616 \u44256 , \u50500 \u51452  \u46384 \u46907 \u54616 \u44172 .\
