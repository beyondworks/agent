\uc0\u44169 \u51004 \u47196 \u45716  \u44536 \u47020 \u49845 \u45768 \u45796 .\
\uc0\u54616 \u51648 \u47564  \u54620 \u49436 \u50980 \u51060 \u46972 \u45716  \u51060 \u47492 \u51060  \u44480 \u50640  \u45823 \u45716  \u49692 \u44036 , \u44032 \u49844  \u50504 \u51901  \u50612 \u46360 \u44032 \u50640 \u49436  \u47925 \u51649 \u54620  \u44163 \u51060  \u53805  \u46504 \u50612 \u51648 \u45716  \u45712 \u45196 \u51060  \u46308 \u50632 \u49845 \u45768 \u45796 . \u49688 \u51652 \u51008  \u54665 \u49324 \u51109  \u51901 \u51004 \u47196  \u52380 \u52380 \u55176  \u44152 \u50612 \u44032 \u47732 \u49436  \u54620  \u48264 , \u49704 \u51012  \u44256 \u47476 \u44172  \u48201 \u50632 \u49845 \u45768 \u45796 . \u51104 \u49884  \u54980  \u51221 \u55148 \u44032  \u44264 \u47785 \u50640 \u49436  \u45208 \u50732  \u53552 \u50688 \u44256 , \u44536  \u45576 \u51008  \u50616 \u51228 \u45208  \u45216 \u52852 \u47196 \u50912 \u49845 \u45768 \u45796 . 15\u45380 \u51012  \u54632 \u44760 \u54616 \u47732 \u49436  \u49688 \u51652 \u51008  \u44536  \u45576 \u51012  \u54620  \u48264 \u46020  \u50756 \u51204 \u55176  \u54588 \u54644 \u48376  \u51201 \u51060  \u50630 \u50632 \u49845 \u45768 \u45796 . \u44536 \u47111 \u44592  \u46412 \u47928 \u50640  \u45908  \u51312 \u49900 \u54644 \u50556  \u54664 \u49845 \u45768 \u45796 .\
\
\uc0\u51221 \u55148 \u44032  \u44264 \u47785 \u50640 \u49436  \u45208 \u50772 \u51012  \u46412 , \u49688 \u51652 \u51008  \u54665 \u49324 \u51109  \u51077 \u44396  \u44592 \u46181  \u50694 \u50640  \u49436 \u49436  \u48372 \u44256 \u49436 \u47484  \u46308 \u50668 \u45796 \u48372 \u45716  \u52377 \u54616 \u44256  \u51080 \u50632 \u49845 \u45768 \u45796 . \
\
\uc0\u45824 \u54364 \u45784 , \u52629 \u49324  \u49884 \u44036  \u50724  \u48516  \u51204 \u51077 \u45768 \u45796 . \
\
\uc0\u51221 \u55148 \u45716  \u44256 \u44060 \u47484  \u54620  \u48264  \u45124 \u45909 \u51060 \u44256  \u50526 \u51109 \u49456 \u49845 \u45768 \u45796 . \u49688 \u51652 \u51008  \u44536  \u46244 \u47484  \u46384 \u46972  \u44152 \u51004 \u47732 \u49436  \u51221 \u55148 \u51032  \u50694 \u50620 \u44404 \u51012  \u49332 \u54216 \u49845 \u45768 \u45796 . \u54364 \u51221 \u51060  \u44403 \u50612  \u51080 \u50632 \u49845 \u45768 \u45796 . \u54217 \u49548 \u48372 \u45796  \u51077 \u49696 \u51060  \u45908  \u44873  \u45796 \u47932 \u47140  \u51080 \u50632 \u44256 , \u45576 \u51060  \u50612 \u46360 \u44032  \u47676  \u44275 \u51012  \u48372 \u44256  \u51080 \u50632 \u49845 \u45768 \u45796 . \u49688 \u51652 \u51008  \u44536  \u54364 \u51221 \u51012  \u50508 \u44256  \u51080 \u50632 \u49845 \u45768 \u45796 . \u47924 \u50616 \u44032 \u47484  \u50504 \u50640 \u49436  \u51221 \u47532 \u54616 \u44256  \u51080 \u51012  \u46412 \u51032  \u51221 \u55148 \u51032  \u50620 \u44404 \u51060 \u50632 \u49845 \u45768 \u45796 .\
\uc0\u54665 \u49324  \u47560 \u47924 \u47532  \u49692 \u49436 \u44032  \u51060 \u50612 \u51648 \u45716  \u46041 \u50504 , \u51221 \u55148 \u45716  \u45800 \u49345 \u50640  \u50732 \u46972  \u51687 \u51008  \u52629 \u49324 \u47484  \u51069 \u50612  \u45236 \u47140 \u44052 \u49845 \u45768 \u45796 . \u47560 \u51060 \u53356  \u50526 \u50640  \u49440  \u47784 \u49845 \u51008  \u55136  \u51105 \u51012  \u44275  \u50630 \u51060  \u45800 \u51221 \u54664 \u49845 \u45768 \u45796 . \u47785 \u49548 \u47532 \u46020  \u50504 \u51221 \u46104 \u50612  \u51080 \u50632 \u49845 \u45768 \u45796 . \u44536 \u47084 \u45208  \u49688 \u51652 \u51008  \u50508  \u49688  \u51080 \u50632 \u49845 \u45768 \u45796 . \u51221 \u55148 \u51032  \u49884 \u49440 \u51060  \u50896 \u44256  \u50948 \u50640  \u47672 \u47932 \u51648  \u50506 \u44256  \u51080 \u45796 \u45716  \u44163 \u51012 . \u47568  \u51473 \u44036 \u51473 \u44036 \u50640  \u45576 \u51060  \u50500 \u51452  \u51104 \u44624 \u50473  \u49884 \u51109  \u44264 \u47785  \u50504 \u51901 \u51012  \u54693 \u54620 \u45796 \u45716  \u44163 \u51012 . \u49436 \u50980 \u51032  \u44032 \u44172 \u44032  \u51080 \u45716  \u48169 \u54693 \u51060 \u50632 \u49845 \u45768 \u45796 .\
\uc0\u51221 \u55148 \u46020  \u50508 \u44256  \u51080 \u50632 \u49845 \u45768 \u45796 . \u51088 \u49888 \u51060  \u50896 \u44256 \u50640  \u51665 \u51473 \u54616 \u51648  \u47803 \u54616 \u44256  \u51080 \u45796 \u45716  \u44163 \u51012 . \u51648 \u50669  \u44221 \u51228 \u50752  \u49345 \u51064 \u46308 \u51032  \u45432 \u47141 , \u54924 \u49324 \u51032  \u54980 \u50896  \u52712 \u51648 . \u49688 \u49901  \u48264  \u45796 \u46316 \u51008  \u47928 \u51109 \u46308 \u51060  \u51077  \u48150 \u51004 \u47196 \u45716  \u55128 \u47084 \u45208 \u50724 \u45716 \u45936 , \u47672 \u47551 \u49549 \u50640 \u49436 \u45716  \u51088 \u44984  \u44536  \u50500 \u51060 \u51032  \u50620 \u44404 \u51060  \u44217 \u52432 \u50772 \u49845 \u45768 \u45796 . \u46020 \u53680 \u54620  \u45576 \u44732 \u54400 , \u50724 \u47480 \u51901  \u48808 \u51032  \u48372 \u51312 \u44060 . \u51060  \u51088 \u47532 \u50640 \u49436  \u47960  \u54616 \u44256  \u51080 \u45716  \u44148 \u51648 . \u48744 \u47532  \u45149 \u45236 \u50556  \u54620 \u45796 \u45716  \u49373 \u44033 \u47564  \u44036 \u51208 \u54664 \u49845 \u45768 \u45796 .\
\uc0\u52629 \u49324 \u44032  \u45149 \u45208 \u44256  \u48149 \u49688  \u49548 \u47532 \u44032  \u51110 \u50500 \u46308 \u50632 \u49845 \u45768 \u45796 . \u51452 \u52572  \u52769  \u44288 \u44228 \u51088 \u46308 \u51060  \u51221 \u55148 \u50640 \u44172  \u45796 \u44032 \u50752  \u51064 \u49324 \u47484  \u44148 \u45368 \u44256 , \u51221 \u55148 \u45716  \u51088 \u50672 \u49828 \u47101 \u44172  \u50501 \u49688 \u47484  \u54616 \u44256  \u47751  \u47560 \u46356 \u47484  \u45208 \u45572 \u50632 \u49845 \u45768 \u45796 . \u54616 \u51648 \u47564  \u44536  \u51687 \u51008  \u49884 \u44036  \u46041 \u50504  \u51221 \u55148 \u51032  \u45576 \u51008  \u46160  \u48264 , \u49464  \u48264  \u49884 \u51109  \u44264 \u47785  \u51077 \u44396  \u51901 \u51012  \u54693 \u54664 \u49845 \u45768 \u45796 . \u49688 \u51652 \u51008  \u44536 \u44163 \u51012  \u45459 \u52824 \u51648  \u50506 \u50520 \u49845 \u45768 \u45796 . \u44032 \u49844  \u50504 \u51901 \u51060  \u45796 \u49884  \u49436 \u45720 \u54644 \u51276 \u49845 \u45768 \u45796 .\
\uc0\u51064 \u49324 \u44032  \u47784 \u46160  \u45149 \u45208 \u51088 \u47560 \u51088 , \u51221 \u55148 \u44032  \u49688 \u54665 \u50896 \u46308 \u50640 \u44172  \u47676 \u51200  \u52264 \u47196  \u44032 \u46972 \u44256  \u54664 \u49845 \u45768 \u45796 . \u49688 \u51652 \u51060  \u46384 \u46972 \u48537 \u51004 \u47140  \u54616 \u51088  \u51221 \u55148 \u44032  \u49552 \u51012  \u46308 \u50612  \u47561 \u50520 \u49845 \u45768 \u45796 .\
\
\uc0\u45208  \u54844 \u51088  \u51104 \u44624  \u45908  \u46168 \u47084 \u48380 \u44172 \u50836 .\
\
\uc0\u49688 \u51652 \u51008  \u51104 \u49884  \u47688 \u52628 \u50632 \u45796 \u44032  \u44256 \u44060 \u47484  \u49689 \u50688 \u49845 \u45768 \u45796 . \
\
\uc0\u50508 \u44192 \u49845 \u45768 \u45796 . \
\
\uc0\u54616 \u51648 \u47564  \u48156 \u44152 \u51020 \u51060  \u49789 \u44172  \u46504 \u50612 \u51648 \u51648  \u50506 \u50520 \u49845 \u45768 \u45796 . \u51221 \u55148 \u44032  \u54844 \u51088  \u44264 \u47785  \u50504 \u51004 \u47196  \u46308 \u50612 \u44032 \u45716  \u46263 \u47784 \u49845 \u51012  \u48148 \u46972 \u48372 \u45796 \u44032 , \u49688 \u51652 \u51008  \u52380 \u52380 \u55176  \u52264  \u51901 \u51004 \u47196  \u44152 \u50612 \u44052 \u49845 \u45768 \u45796 . \u54648 \u46300 \u54256 \u51012  \u44732 \u45236  \u49436 \u50980 \u51032  \u51060 \u47492 \u51012  \u44160 \u49353 \u54616 \u44592  \u49884 \u51089 \u54664 \u49845 \u45768 \u45796 . \u51312 \u49324 \u45716  \u54644 \u50556  \u54664 \u49845 \u45768 \u45796 . \u45824 \u54364 \u45784 \u51032  \u51648 \u49884 \u50688 \u44256 , \u54616 \u51648  \u50506 \u51004 \u47732  \u45908  \u51060 \u49345 \u54616 \u44172  \u48372 \u51068  \u53552 \u50688 \u49845 \u45768 \u45796 . \u45796 \u47564  \u44536  \u44208 \u44284 \u47484  \u50612 \u46523 \u44172  \u48372 \u44256 \u54616 \u45712 \u45264 \u45716  \u51088 \u49888 \u51060  \u44208 \u51221 \u54616 \u47732  \u46104 \u45716  \u51068 \u51060 \u50632 \u49845 \u45768 \u45796 . \u49688 \u51652 \u51008  \u44536 \u47111 \u44172  \u49373 \u44033 \u54616 \u47728  \u54648 \u46300 \u54256  \u54868 \u47732 \u51012  \u49552 \u44032 \u46973 \u51004 \u47196  \u45336 \u44220 \u49845 \u45768 \u45796 . \u49552 \u45149 \u51060  \u52264 \u44032 \u50912 \u49845 \u45768 \u45796 .\
\uc0\u51221 \u55148 \u45716  \u44264 \u47785  \u50504 \u51004 \u47196  \u45796 \u49884  \u46308 \u50612 \u49456 \u49845 \u45768 \u45796 . \u50500 \u44620 \u48372 \u45796  \u50612 \u46160 \u50892 \u51652  \u50724 \u54980  \u48731 \u51060  \u51329 \u51008  \u44264 \u47785 \u51012  \u48708 \u49828 \u46316 \u55176  \u44032 \u47196 \u51656 \u47104 \u49845 \u45768 \u45796 . \u48152 \u52268 \u44032 \u44172  \u51901 \u51004 \u47196  \u44152 \u50612 \u44032 \u47732 \u49436  \u51221 \u55148 \u45716  \u47560 \u51020 \u51012  \u45796 \u51105 \u50520 \u49845 \u45768 \u45796 . \u44536 \u45285  \u51648 \u45208 \u52832  \u49688  \u50630 \u50632 \u49845 \u45768 \u45796 . \u45576 \u51060  \u47560 \u51452 \u52452 \u49845 \u45768 \u45796 . \u50500 \u51060 \u51032  \u50620 \u44404 \u51012  \u48420 \u49845 \u45768 \u45796 . \u51060 \u51228  \u50752 \u49436  \u47803  \u48376  \u52377 \u54616 \u45716  \u44163 \u51008  \u51221 \u55148 \u51032  \u48169 \u49885 \u51060  \u50500 \u45768 \u50632 \u49845 \u45768 \u45796 .\
\uc0\u54616 \u51648 \u47564  \u44032 \u44172  \u50526 \u50640  \u46020 \u52265 \u54664 \u51012  \u46412 , \u49492 \u53552 \u44032  \u51208 \u48152 \u52196  \u45236 \u47140 \u50752  \u51080 \u50632 \u49845 \u45768 \u45796 .\
\uc0\u44536  \u49324 \u51060  \u50620 \u47560 \u45208  \u49884 \u44036 \u51060  \u55128 \u47104 \u45796 \u44256 . \u51221 \u55148 \u45716  \u44403 \u51008  \u50620 \u44404 \u47196  \u44032 \u44172  \u50504 \u51012  \u46308 \u50668 \u45796 \u48372 \u50520 \u49845 \u45768 \u45796 . \u48520 \u51060  \u44732 \u51256  \u51080 \u50632 \u44256 , \u48152 \u52268  \u51652 \u50676 \u45824 \u45716  \u53573  \u48708 \u50612  \u51080 \u50632 \u49845 \u45768 \u45796 . \u49436 \u46168 \u47084  \u47928 \u51012  \u45803 \u51008  \u44163 \u51060 \u50632 \u49845 \u45768 \u45796 . \u51221 \u55148 \u45716  \u52380 \u52380 \u55176  \u44256 \u44060 \u47484  \u46028 \u47160 \u49845 \u45768 \u45796 . \u44264 \u47785  \u45149  \u51901 \u51012  \u48148 \u46972 \u48372 \u50520 \u49845 \u45768 \u45796 .\
\uc0\u51200 \u51901 \u51060 \u50632 \u49845 \u45768 \u45796 .\
\uc0\u49436 \u50980 \u51060  \u50500 \u51060 \u51032  \u49552 \u51012  \u44845  \u51105 \u44256  \u44264 \u47785  \u45149  \u51901 \u51004 \u47196  \u48736 \u47476 \u44172  \u44152 \u50612 \u44032 \u44256  \u51080 \u50632 \u49845 \u45768 \u45796 . \u45796 \u47480  \u49552 \u50640 \u45716  \u51089 \u51008  \u44032 \u48169 \u51060  \u46308 \u47140  \u51080 \u50632 \u44256 , \u50500 \u51060 \u51032  \u50612 \u44648 \u47484  \u44048 \u49912 \u46319  \u47800 \u51012  \u44592 \u50872 \u51060 \u47728  \u44152 \u51020 \u51012  \u51116 \u52489 \u54664 \u49845 \u45768 \u45796 . \u50500 \u51060 \u44032  \u51089 \u51008  \u48156 \u51012  \u46832 \u46319 \u51060  \u50880 \u51649 \u51060 \u44256  \u51080 \u50632 \u49845 \u45768 \u45796 .\
\uc0\u51221 \u55148 \u45716  \u54620  \u48156 \u51677  \u50526 \u51004 \u47196  \u45208 \u49436 \u47728  \u51077 \u51012  \u50676 \u50632 \u49845 \u45768 \u45796 .\
\
\uc0\u49436 \u50980 \u50500 .\
\
\uc0\u47785 \u49548 \u47532 \u44032  \u44264 \u47785  \u50504 \u50640  \u54140 \u51276 \u49845 \u45768 \u45796 . \u49436 \u50980 \u51032  \u44152 \u51020 \u51060  \u50500 \u51452  \u51104 \u44624 , \u45576 \u50640  \u46916 \u51648  \u50506 \u51012  \u47564 \u53372  \u51687 \u44172  \u47688 \u52843 \u54664 \u49845 \u45768 \u45796 . \u54616 \u51648 \u47564  \u46028 \u50500 \u48372 \u51648  \u50506 \u50520 \u49845 \u45768 \u45796 . \u50724 \u55176 \u47140  \u50500 \u51060 \u47484  \u45908  \u48148 \u51677  \u45817 \u44200  \u50504 \u46319 \u51060  \u54616 \u47728  \u44152 \u51020 \u51012  \u45908  \u48736 \u47476 \u44172  \u45236 \u46363 \u50632 \u49845 \u45768 \u45796 .\
\
\uc0\u49436 \u50980 \u50500 \
\
\uc0\u51221 \u55148 \u44032  \u45796 \u49884  \u48520 \u47104 \u49845 \u45768 \u45796 . \u51060 \u48264 \u50640 \u45716  \u51312 \u44552  \u45908  \u53356 \u44172 . \u44536 \u47000 \u46020  \u49436 \u50980 \u51008  \u46028 \u50500 \u48372 \u51648  \u50506 \u50520 \u49845 \u45768 \u45796 . \u49324 \u46988 \u46308  \u53960 \u51004 \u47196  \u54028 \u44256 \u46308 \u46319 \u51060  \u44152 \u51020 \u51012  \u45908  \u48736 \u47476 \u44172  \u50734 \u44220 \u49845 \u45768 \u45796 . \u44264 \u47785  \u45149 \u50640 \u49436  \u50724 \u47480 \u51901  \u48169 \u54693 \u51004 \u47196  \u44734 \u50612 \u51648 \u47732 \u49436 , \u44536  \u46263 \u47784 \u49845 \u51060  \u49324 \u46988 \u46308  \u49324 \u51060 \u47196  \u49324 \u46972 \u51276 \u49845 \u45768 \u45796 .\
\uc0\u51221 \u55148 \u45716  \u44536  \u51088 \u47532 \u50640  \u47688 \u52628 \u50612  \u49456 \u49845 \u45768 \u45796 . \u46244 \u46384 \u46972 \u44032 \u47140 \u45796 \u44032  \u48156 \u51060  \u44403 \u50612 \u48260 \u47160 \u49845 \u45768 \u45796 . \u49324 \u46988 \u46308 \u51060  \u50724 \u44032 \u45716  \u49884 \u51109  \u54620 \u48373 \u54032 \u50640 \u49436  \u53360  \u49548 \u47532 \u47196  \u51060 \u47492 \u51012  \u48512 \u47484  \u49688  \u50630 \u50632 \u49845 \u45768 \u45796 . \u51221 \u55148 \u45716  \u48152 \u52196  \u45236 \u47140 \u51652  \u49492 \u53552 \u47484  \u48148 \u46972 \u48372 \u45796 \u44032 , \u44536  \u45796 \u51020  \u49436 \u50980 \u51060  \u49324 \u46972 \u51652  \u44264 \u47785  \u45149 \u51012  \u48148 \u46972 \u48372 \u50520 \u49845 \u45768 \u45796 . \u51077 \u49696 \u51060  \u44403 \u44172  \u45796 \u47932 \u47160 \u49845 \u45768 \u45796 .\
\uc0\u47803  \u46308 \u50632 \u51012  \u47532  \u50630 \u50632 \u49845 \u45768 \u45796 .\
\uc0\u48852 \u55176  \u46308 \u50632 \u51004 \u47732 \u49436 \u46020  \u46028 \u50500 \u48372 \u51648  \u50506 \u51008  \u44163 \u51060 \u50632 \u49845 \u45768 \u45796 . \u50500 \u51060  \u49552 \u51012  \u45908  \u44873  \u51536 \u44256 , \u45908  \u48736 \u47476 \u44172  \u44152 \u50612 \u44052 \u49845 \u45768 \u45796 . \u44536  \u49440 \u47749 \u54620  \u54924 \u54588 \u44032  \u51221 \u55148 \u51032  \u44032 \u49844  \u50504 \u51901 \u50640 \u49436  \u47956 \u44032 \u47484  \u49464 \u44172  \u44148 \u46300 \u47160 \u49845 \u45768 \u45796 . \u48516 \u45432 \u51064 \u51648 , \u50500 \u45768 \u47732  \u44536 \u48372 \u45796  \u45908  \u44618 \u51008  \u47924 \u50616 \u44032 \u51064 \u51648 \u45716  \u48148 \u47196  \u50508  \u49688  \u50630 \u50632 \u49845 \u45768 \u45796 . \u51221 \u55148 \u45716  7\u45380  \u51204  \u44536 \u45216  \u47728 \u45712 \u47532 \u47484  \u45236 \u48372 \u45244  \u46412 , \u49436 \u50980 \u51060  \u54664 \u45912  \u54665 \u46041 \u51012  \u46496 \u50732 \u47160 \u49845 \u45768 \u45796 . \u44536 \u46412 \u46020  \u49436 \u50980 \u51008  \u48320 \u47749  \u54620 \u47560 \u46356  \u54616 \u51648  \u50506 \u50520 \u49845 \u45768 \u45796 . \u50500 \u47924  \u47568  \u50630 \u51060  \u44032 \u48169 \u51012  \u46308 \u44256  \u54788 \u44288 \u51012  \u45208 \u49456 \u49845 \u45768 \u45796 . \u44536 \u47532 \u44256  \u51648 \u44552 \u46020  \u47560 \u52268 \u44032 \u51648 \u50688 \u49845 \u45768 \u45796 . \u50500 \u47924  \u47568  \u50630 \u51060 , \u46244 \u46028 \u50500 \u48372 \u51648  \u50506 \u44256 , \u49324 \u46972 \u51276 \u49845 \u45768 \u45796 . \u44536  \u51068 \u44288 \u46108  \u52840 \u47925 \u51060  \u51060 \u49345 \u54616 \u44172 \u46020  \u45908  \u47560 \u51020 \u50640  \u44152 \u47160 \u49845 \u45768 \u45796 . \u45796 \u47564  \u51060 \u44163 \u47564 \u53372 \u51008  \u48516 \u47749 \u54664 \u49845 \u45768 \u45796 . \u51060  \u49324 \u46988 \u51008  \u47924 \u50616 \u44032 \u47484  \u49704 \u44592 \u44256  \u51080 \u49845 \u45768 \u45796 . \u44536 \u47532 \u44256  \u51200  \u50500 \u51060 \u45716  \u44536  \u54620 \u44032 \u50868 \u45936 \u50640  \u51080 \u49845 \u45768 \u45796 .\
\uc0\u51221 \u55148 \u45716  \u54648 \u46300 \u54256 \u51012  \u44732 \u45256 \u49845 \u45768 \u45796 . \u49688 \u51652 \u50640 \u44172  \u51204 \u54868 \u54616 \u45716  \u45824 \u49888 , \u51649 \u51217  \u47928 \u51088 \u47484  \u48372 \u45256 \u49845 \u45768 \u45796 . \
\
\uc0\u49688 \u51652 \u50472  \u45236 \u44032  \u50500 \u44620  \u48512 \u53441 \u54620 \u44144  \u52572 \u45824 \u54620  \u48744 \u47532  \u50508 \u50500 \u48400 \u51480 . \
\
\uc0\u47928 \u51088 \u47484  \u48372 \u45236 \u44256  \u54648 \u46300 \u54256 \u51012  \u51116 \u53431  \u50504 \u51452 \u47672 \u45768 \u50640  \u45347 \u51004 \u47732 \u49436  \u51221 \u55148 \u45716  \u45796 \u49884  \u54620 \u48264  \u49436 \u50980 \u51060  \u49324 \u46972 \u51652  \u44264 \u47785  \u45149 \u51012  \u48148 \u46972 \u48372 \u50520 \u49845 \u45768 \u45796 . \u51200 \u45377  \u54644 \u44032  \u44592 \u50872 \u47732 \u49436  \u44264 \u47785  \u50948 \u47196  \u44596  \u44536 \u45720 \u51060  \u45236 \u47140 \u50724 \u44256  \u51080 \u50632 \u49845 \u45768 \u45796 .\
\uc0\u44536 \u45285  \u51648 \u45208 \u52832  \u49688  \u50630 \u50632 \u49845 \u45768 \u45796 . \u51060 \u48120  \u44536 \u47084 \u44592 \u50640 \u45716  \u45320 \u47924  \u47566 \u51008  \u44163 \u51060  \u45576 \u50640  \u44152 \u47160 \u49845 \u45768 \u45796 .\
\uc0\u54620 \u54200  \u52264  \u50504 \u50640 \u49436  \u47928 \u51088 \u47484  \u48155 \u51008  \u49688 \u51652 \u51008  \u44536 \u44163 \u51012  \u54868 \u47732 \u50640  \u46916 \u50892 \u46160 \u44256  \u54620 \u46041 \u50504  \u48148 \u46972 \u48372 \u50520 \u49845 \u45768 \u45796 . \u49688 \u51652 \u51008  \u54648 \u46300 \u54256  \u54868 \u47732 \u51012  \u45124 \u44256  \u52285 \u48150 \u51012  \u48148 \u46972 \u48372 \u50520 \u49845 \u45768 \u45796 . \u49884 \u51109  \u51077 \u44396  \u51901 \u50640 \u49436  \u51221 \u55148 \u44032  \u44152 \u50612 \u50724 \u45716  \u47784 \u49845 \u51060  \u48372 \u50688 \u49845 \u45768 \u45796 . \u49688 \u51652 \u51008  \u51088 \u49464 \u47484  \u48148 \u47196 \u51105 \u50520 \u49845 \u45768 \u45796 . \u54364 \u51221 \u51012  \u51221 \u47532 \u54664 \u49845 \u45768 \u45796 . \u54217 \u49548 \u52376 \u47100 . \u50500 \u47924 \u44163 \u46020  \u47784 \u47476 \u45716  \u49324 \u46988 \u52376 \u47100 . \u44536 \u47111 \u44172  \u54644 \u50556  \u54664 \u49845 \u45768 \u45796 .\
\uc0\u51221 \u55148 \u44032  \u52264  \u47928 \u51012  \u50676 \u44256  \u46308 \u50612 \u49436 \u45716  \u49692 \u44036 , \u49688 \u51652 \u51008  \u51088 \u50672 \u49828 \u47101 \u44172  \u44256 \u44060 \u47484  \u46028 \u47160 \u49845 \u45768 \u45796 .\
\
\uc0\u45824 \u54364 \u45784 , \u49436 \u50872 \u47196  \u52636 \u48156 \u54624 \u44620 \u50836 .\
