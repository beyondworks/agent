\uc0\u44208 \u44284 \u45716  \u45815 \u49352  \u46244 \u50640  \u50772 \u49845 \u45768 \u45796 .\
\uc0\u51221 \u55148 \u44032  \u54844 \u51088  \u49324 \u47924 \u49892 \u50640  \u51080 \u51012  \u46412  \u48393 \u53804 \u44032  \u46020 \u52265 \u54664 \u49845 \u45768 \u45796 . \u51221 \u55148 \u45716  \u48393 \u53804 \u47484  \u52293 \u49345  \u50948 \u50640  \u50732 \u47140 \u46160 \u44256  \u54620 \u52280  \u48148 \u46972 \u48372 \u50520 \u49845 \u45768 \u45796 . \u50676 \u44592 \u44032  \u46160 \u47140 \u50868  \u44172  \u50500 \u45768 \u50632 \u49845 \u45768 \u45796 . \u50676 \u47732  \u46028 \u51060 \u53420  \u49688  \u50630 \u45796 \u45716  \u44163 \u51012  \u50508 \u44592  \u46412 \u47928 \u50640 , \u47560 \u51648 \u47561 \u51004 \u47196  \u54620  \u48264 \u47564  \u45908  \u49704 \u51012  \u44264 \u46992 \u49845 \u45768 \u45796 . \u48393 \u53804 \u47484  \u50676 \u50632 \u49845 \u45768 \u45796 .\
\uc0\u44208 \u44284 \u51648 \u47484  \u44732 \u45256 \u49845 \u45768 \u45796 . \u52395  \u48264 \u51704  \u51460 \u51012  \u51069 \u50632 \u49845 \u45768 \u45796 .\
\uc0\u48512 \u44228  \u54792 \u50672  \u44288 \u44228  \u54869 \u51064 \u46120 . \u51068 \u52824 \u50984  99.97\u54140 \u49468 \u53944 .\
\uc0\u51221 \u55148 \u45716  \u44536  \u51088 \u47532 \u50640 \u49436  \u47568 \u51012  \u51079 \u51648  \u47803 \u54664 \u49845 \u45768 \u45796 . \u44208 \u44284 \u51648 \u47484  \u49552 \u50640  \u46304  \u52292 \u47196  \u51032 \u51088 \u50640  \u46321 \u51012  \u44592 \u45844 \u49845 \u45768 \u45796 . \u49704 \u51060  \u44256 \u47476 \u44172  \u49772 \u50612 \u51648 \u51648  \u50506 \u50520 \u49845 \u45768 \u45796 . \u50508 \u44256  \u51080 \u50632 \u49845 \u45768 \u45796 . \u48372 \u51088 \u47560 \u51088  \u50508  \u44144 \u46972 \u44256  \u49373 \u44033 \u54664 \u49845 \u45768 \u45796 . \u44536 \u47088 \u45936  \u47561 \u49345  \u49707 \u51088 \u47196  \u54869 \u51064 \u46104 \u45716  \u49692 \u44036 , \u44032 \u49844  \u50504 \u50640 \u49436  \u47956 \u44032 \u44032  \u54620 \u44732 \u48264 \u50640  \u50143 \u50500 \u51256  \u45236 \u47532 \u45716  \u44163  \u44057 \u50520 \u49845 \u45768 \u45796 . 7\u45380 \u51060 \u50632 \u49845 \u45768 \u45796 . \u44536  \u50500 \u51060 \u44032  \u49464 \u49345 \u50640  \u45208 \u50728  \u51648  7\u45380 \u51060  \u46096 \u49845 \u45768 \u45796 . \u44536  7\u45380  \u46041 \u50504  \u51088 \u49888 \u51008  \u50500 \u47924 \u44163 \u46020  \u47792 \u46992 \u49845 \u45768 \u45796 . \u50500 \u45768 , \u47792 \u46992 \u45796 \u45716  \u47568 \u46020  \u51221 \u54869 \u54616 \u51648  \u50506 \u50520 \u49845 \u45768 \u45796 . \u50508  \u44592 \u54924 \u44032  \u51080 \u50632 \u45716 \u45936 , \u50508 \u47140 \u45716  \u49884 \u46020 \u51312 \u52264  \u54616 \u51648  \u50506 \u50520 \u49845 \u45768 \u45796 . \u47728 \u45712 \u47532 \u47484  \u45236 \u48372 \u45244  \u46412 , \u51221 \u55148 \u45716  \u54869 \u49888 \u54664 \u49845 \u45768 \u45796 . \u50739 \u51008  \u44208 \u51221 \u51060 \u46972 \u44256 . \u44536 \u47088 \u45936  \u44536  \u54869 \u49888 \u51060  \u51648 \u44552  \u51060  \u54620  \u51109 \u51032  \u51333 \u51060  \u50526 \u50640 \u49436  \u51204 \u48512  \u47924 \u45320 \u51276 \u49845 \u45768 \u45796 . \u51221 \u55148 \u45716  \u45576 \u51012  \u44048 \u50520 \u49845 \u45768 \u45796 . \u45576 \u44732 \u54400  \u50504 \u51901 \u51060  \u46888 \u44144 \u50912 \u49845 \u45768 \u45796 .\
\uc0\u44536 \u45216  \u51200 \u45377 , \u51221 \u55148 \u45716  \u48124 \u51456 \u51012  \u48520 \u47104 \u49845 \u45768 \u45796 .\
\uc0\u48124 \u51456 \u51060  \u46020 \u52265 \u54664 \u51012  \u46412  \u51221 \u55148 \u45716  \u44144 \u49892  \u49548 \u54028 \u50640  \u50505 \u50500  \u48393 \u53804 \u47484  \u47924 \u47502  \u50948 \u50640  \u50732 \u47140 \u46160 \u44256  \u51080 \u50632 \u49845 \u45768 \u45796 . \u48124 \u51456 \u51008  \u44536  \u48393 \u53804 \u47484  \u48372 \u51088 \u47560 \u51088  \u47924 \u50616 \u44032 \u47484  \u51649 \u44048 \u54664 \u49845 \u45768 \u45796 . \u51088 \u47532 \u50640  \u50505 \u51004 \u47732 \u49436  \u50612 \u47672 \u45768 \u51032  \u50620 \u44404 \u51012  \u49332 \u54216 \u49845 \u45768 \u45796 . \u51221 \u55148 \u44032  \u47568 \u50630 \u51060  \u48393 \u53804 \u47484  \u48124 \u51456  \u51901 \u51004 \u47196  \u45236 \u48128 \u50632 \u49845 \u45768 \u45796 .\
\uc0\u48124 \u51456 \u51060  \u48393 \u53804 \u47484  \u50676 \u50632 \u49845 \u45768 \u45796 . \u44208 \u44284 \u51648 \u47484  \u44732 \u45256 \u49845 \u45768 \u45796 . \u52395  \u48264 \u51704  \u51460 \u50640  \u49884 \u49440 \u51060  \u45823 \u50520 \u49845 \u45768 \u45796 .\
\uc0\u48512 \u44228  \u54792 \u50672  \u44288 \u44228  \u54869 \u51064 \u46120 .\
\uc0\u48124 \u51456 \u51008  \u44536  \u51088 \u47532 \u50640 \u49436  \u51452 \u51200 \u50505 \u50520 \u49845 \u45768 \u45796 . \u49548 \u54028  \u50948 \u50688 \u51648 \u47564  \u46321 \u51060  \u46321 \u48155 \u51060 \u50640 \u49436  \u46504 \u50612 \u51648 \u47732 \u49436  \u47800 \u51060  \u50526 \u51004 \u47196  \u44734 \u50688 \u49845 \u45768 \u45796 . \u49552 \u50640  \u51540  \u44208 \u44284 \u51648 \u44032  \u44396 \u44200 \u51276 \u49845 \u45768 \u45796 . \u50612 \u47672 \u45768 \u44032  \u47956 \u44032 \u47484  \u47568 \u54616 \u45716  \u44163  \u44057 \u50520 \u51648 \u47564  \u44480 \u50640  \u46308 \u50612 \u50724 \u51648  \u50506 \u50520 \u49845 \u45768 \u45796 . 7\u45380  \u51204  \u49436 \u50980 \u51060  \u51665 \u51012  \u45208 \u44032 \u45912  \u51109 \u47732 \u51060  \u46496 \u50732 \u46992 \u49845 \u45768 \u45796 . \u44032 \u48169 \u51012  \u46308 \u44256  \u54788 \u44288 \u51012  \u45208 \u49436 \u45912  \u46263 \u47784 \u49845 . \u44536 \u46412  \u49436 \u50980 \u51032  \u48176  \u49549 \u50640  \u50500 \u51060 \u44032  \u51080 \u50632 \u49845 \u45768 \u45796 . \u48124 \u51456 \u51008  \u44536 \u44163 \u51012  \u47792 \u46992 \u49845 \u45768 \u45796 . \u50500 \u45768 , \u54869 \u51064 \u54616 \u51648  \u50506 \u50520 \u49845 \u45768 \u45796 . \u44536  \u52264 \u51060 \u44032  \u51648 \u44552  \u51060  \u49692 \u44036  \u45320 \u47924  \u49440 \u47749 \u54616 \u44172  \u45712 \u44788 \u51276 \u49845 \u45768 \u45796 . \
\uc0\u51221 \u55148 \u45716  \u50500 \u47924  \u47568 \u46020  \u54616 \u51648  \u50506 \u50520 \u49845 \u45768 \u45796 . \u50500 \u46308 \u51032  \u50612 \u44648 \u50640  \u49552 \u51012  \u50617 \u51004 \u47140 \u45796 \u44032  \u47688 \u52628 \u50632 \u49845 \u45768 \u45796 . \u51648 \u44552  \u51060  \u49692 \u44036  \u44148 \u45356  \u49688  \u51080 \u45716  \u50948 \u47196 \u44032  \u50630 \u50632 \u49845 \u45768 \u45796 . \u51221 \u55148  \u51088 \u49888 \u46020  \u47560 \u52268 \u44032 \u51648 \u50688 \u49845 \u45768 \u45796 . \u46160  \u49324 \u46988 \u51008  \u54620 \u46041 \u50504  \u44536 \u47111 \u44172 , \u44057 \u51008  \u44277 \u44036  \u50504 \u50640 \u49436  \u44033 \u51088 \u51032  \u47924 \u44172 \u47484  \u50504 \u44256  \u51080 \u50632 \u49845 \u45768 \u45796 .\
\uc0\u52285 \u48150 \u50640  \u50612 \u46176 \u51060  \u45236 \u47140 \u50505 \u44256  \u51080 \u50632 \u49845 \u45768 \u45796 . \u51221 \u55148 \u45716  \u44536  \u50612 \u46176 \u51012  \u48148 \u46972 \u48372 \u47732 \u49436  \u51312 \u50857 \u55176  \u44208 \u49900 \u54664 \u49845 \u45768 \u45796 . 7\u45380  \u51204  \u49324 \u44148 \u51012  \u52376 \u51020 \u48512 \u53552  \u45796 \u49884  \u48400 \u50556  \u54633 \u45768 \u45796 . \u45572 \u44032  \u51060  \u51068 \u51012  \u47564 \u46308 \u50632 \u45716 \u51648 , \u50612 \u46523 \u44172  \u47564 \u46308 \u50632 \u45716 \u51648 . \u44536  \u45813 \u51012  \u52286 \u50500 \u50556  \u54664 \u49845 \u45768 \u45796 . \u51060 \u51228  \u45908  \u51060 \u49345  \u48120 \u47344  \u51060 \u50976 \u44032  \u50630 \u50632 \u49845 \u45768 \u45796 . \u44536 \u47532 \u44256  \u44536  \u44284 \u51221 \u50640 \u49436  \u51088 \u49888 \u51060  \u50620 \u47560 \u45208  \u53360  \u51096 \u47803 \u51012  \u54664 \u45716 \u51648 \u46020  \u47560 \u51452 \u54644 \u50556  \u54664 \u49845 \u45768 \u45796 . \u46160 \u47157 \u51648  \u50506 \u45796 \u47732  \u44144 \u51667 \u47568 \u51060 \u50632 \u49845 \u45768 \u45796 . \u54616 \u51648 \u47564  \u46160 \u47157 \u45796 \u44256  \u50808 \u47732 \u54616 \u45716  \u44163 \u51008  \u51060 \u48120  7\u45380  \u51204 \u50640  \u52649 \u48516 \u55176  \u54664 \u49845 \u45768 \u45796 .\
