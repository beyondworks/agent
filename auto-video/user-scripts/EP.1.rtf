\uc0\u44536 \u47532 \u44256  \u44032 \u44172  \u47928 \u51060  \u45803 \u54804 \u49845 \u45768 \u45796 .\
\uc0\u48124 \u51456 \u51008  \u45803 \u55180  \u47928  \u50526 \u50640  \u54844 \u51088  \u49456 \u49845 \u45768 \u45796 . \u48156 \u51060  \u48537 \u50612 \u48260 \u47536  \u44163 \u52376 \u47100  \u50880 \u51649 \u50668 \u51648 \u51648  \u50506 \u50520 \u49845 \u45768 \u45796 . \u51060 \u51228  \u50752 \u49436  \u50508  \u51088 \u44201 \u46020  \u50630 \u45796 . \u44536  \u47568 \u51060  \u44480  \u50504 \u50640 \u49436  \u47604 \u46028 \u50520 \u49845 \u45768 \u45796 . \u53952 \u47536  \u47568 \u51060  \u50500 \u45768 \u50632 \u49845 \u45768 \u45796 . \u44536 \u47000 \u49436  \u45908  \u47924 \u44144 \u50912 \u49845 \u45768 \u45796 . \u49436 \u50980 \u51060  \u51665 \u51012  \u45208 \u44032 \u45912  \u45216 , \u48124 \u51456 \u51008  \u49548 \u54028 \u50640  \u50505 \u50500  \u51080 \u50632 \u49845 \u45768 \u45796 . \u48537 \u51105 \u51648  \u50506 \u50520 \u49845 \u45768 \u45796 . \u54869 \u51064 \u54616 \u51648  \u50506 \u50520 \u49845 \u45768 \u45796 . \u44536  \u49440 \u53469 \u51060  \u51060 \u48120  \u51088 \u44201 \u51012  \u54252 \u44592 \u54620  \u44163 \u44284  \u44057 \u51008  \u51068 \u51060 \u50632 \u45716 \u51648  \u47784 \u47493 \u45768 \u45796 . \u48124 \u51456 \u51008  \u49552 \u51004 \u47196  \u47672 \u47532 \u47484  \u51674 \u51004 \u47728  \u52380 \u52380 \u55176  \u47800 \u51012  \u46028 \u47160 \u49845 \u45768 \u45796 . \u44264 \u47785  \u48148 \u45797 \u51012  \u48372 \u47732 \u49436  \u44152 \u50632 \u49845 \u45768 \u45796 . \u45796 \u47532 \u44032  \u51228 \u45824 \u47196  \u50880 \u51649 \u51060 \u45716 \u51648 \u46020  \u47784 \u47480  \u52292 . \u52264 \u50640  \u50732 \u46972  \u54648 \u46308 \u51012  \u51105 \u50520 \u51648 \u47564  \u54620 \u46041 \u50504  \u49884 \u46041 \u51012  \u44152 \u51648  \u50506 \u50520 \u49845 \u45768 \u45796 . \u52285 \u48150 \u51004 \u47196  \u44264 \u47785  \u50504  \u54413 \u44221 \u51060  \u48372 \u50688 \u49845 \u45768 \u45796 . \u51200  \u44032 \u44172  \u50504 \u50640  \u49436 \u50980 \u51060  \u5