\uc0\u51221 \u55148 \u44032  \u49688 \u51652 \u51012  \u45824 \u54364 \u49892 \u47196  \u48512 \u47480  \u44163 \u51008  \u49436 \u48260  \u48373 \u44396  \u44208 \u44284 \u47484  \u54869 \u51064 \u54616 \u44256  \u45208 \u55128 \u51704  \u46104 \u45912  \u45216 \u51060 \u50632 \u49845 \u45768 \u45796 . \u44536 \u49324 \u51060  \u51221 \u55148 \u45716  \u50808 \u48512  \u51312 \u49324 \u54016 \u51012  \u53685 \u54644  \u49688 \u51652 \u51032  \u53685 \u54868  \u44592 \u47197  \u54869 \u48372 \u47484  \u51032 \u47280 \u54644 \u46160 \u50632 \u44256 , \u45432 \u47924 \u49324 \u50752  \u54632 \u44760  \u48373 \u44396 \u46108  \u51088 \u47308 \u47484  \u45796 \u49884  \u54620 \u48264  \u44860 \u44860 \u55176  \u44160 \u53664 \u54664 \u49845 \u45768 \u45796 . \u50500 \u51649  \u49688 \u51652 \u51012  \u51649 \u51217  \u50517 \u48149 \u54616 \u44592 \u50640 \u45716  \u51060 \u47480  \u49884 \u51216 \u51060 \u50632 \u51648 \u47564 , \u54620  \u48264 \u51008  \u55124 \u46308 \u50612 \u48400 \u50556  \u54664 \u49845 \u45768 \u45796 . \u50612 \u46356 \u49436  \u44552 \u51060  \u44032 \u45716 \u51648  \u54869 \u51064 \u54644 \u50556  \u54664 \u49845 \u45768 \u45796 .\
\uc0\u49688 \u51652 \u51008  \u50676  \u49884  \u51221 \u44033 \u50640  \u45824 \u54364 \u49892  \u47928 \u51012  \u46160 \u46300 \u47532 \u44256  \u46308 \u50612 \u50772 \u49845 \u45768 \u45796 . \u49552 \u50640 \u45716  \u50724 \u51204  \u48372 \u44256 \u50857  \u49436 \u47448  \u54028 \u51068 \u51012  \u46308 \u44256  \u51080 \u50632 \u49845 \u45768 \u45796 . \u54217 \u49548 \u50752  \u45796 \u47476 \u51648  \u50506 \u51008  \u52264 \u47548 \u51060 \u50632 \u44256 , \u54364 \u51221 \u46020  \u45800 \u51221 \u54664 \u49845 \u45768 \u45796 . \u51221 \u55148 \u45716  \u52285 \u44032 \u50640  \u49436  \u51080 \u45796 \u44032  \u52380 \u52380 \u55176  \u52293 \u49345  \u51901 \u51004 \u47196  \u44152 \u50612 \u50752  \u50505 \u50520 \u49845 \u45768 \u45796 . \u49688 \u51652 \u46020  \u49548 \u54028 \u50640  \u51088 \u47532 \u47484  \u51105 \u50520 \u49845 \u45768 \u45796 .\
"\uc0\u50724 \u45720 \u51008  \u48372 \u44256  \u47568 \u44256 , \u51104 \u44624  \u47932 \u50612 \u48380  \u44172  \u51080 \u50612 \u49436 \u50836 ."\
\uc0\u51221 \u55148 \u51032  \u47785 \u49548 \u47532 \u44032  \u45230 \u44256  \u51312 \u50857 \u54664 \u49845 \u45768 \u45796 . \u49688 \u51652 \u51060  \u54028 \u51068 \u51012  \u47924 \u47502  \u50948 \u50640  \u50732 \u47140 \u46160 \u47728  \u44256 \u44060 \u47484  \u46308 \u50632 \u49845 \u45768 \u45796 .\
"\uc0\u47568 \u50432 \u54616 \u49464 \u50836 ."\
"7\uc0\u45380  \u51204  \u49436 \u50980 \u50472  \u54945 \u47161  \u49324 \u44148 \u51060 \u50836 . \u44536 \u46412  \u49436 \u50980 \u50472  \u47749 \u51032 \u47196  \u51060 \u52404 \u46108  \u45236 \u50669 \u51012  \u52376 \u51020  \u48156 \u44204 \u54620  \u44172  \u49688 \u51652 \u50472 \u50688 \u51424 ."\
\uc0\u49688 \u51652 \u51008  \u51104 \u44624  \u45576 \u51012  \u45236 \u47160 \u45796 \u44032  \u45796 \u49884  \u51221 \u55148 \u47484  \u48148 \u46972 \u48372 \u50520 \u49845 \u45768 \u45796 .\
"\uc0\u45348 , \u44536 \u47111 \u49845 \u45768 \u45796 . \u54924 \u44228  \u44048 \u49324  \u44284 \u51221 \u50640 \u49436  \u51228 \u44032  \u47676 \u51200  \u51060 \u49345 \u54620  \u44152  \u48156 \u44204 \u54644 \u49436  \u45824 \u54364 \u45784 \u44760  \u48372 \u44256 \u46300 \u47160 \u49845 \u45768 \u45796 ."\
"\uc0\u44536 \u44172  \u47582 \u50500 \u50836 ?"\
"\uc0\u44536 \u47111 \u49845 \u45768 \u45796 ."\
\uc0\u51221 \u55148 \u45716  \u51104 \u49884  \u49688 \u51652 \u51012  \u48148 \u46972 \u48372 \u45796 \u44032  \u52293 \u49345  \u49436 \u46989 \u51012  \u50676 \u50632 \u49845 \u45768 \u45796 . \u44536  \u50504 \u50640 \u49436  \u51333 \u51060  \u47751  \u51109 \u51012  \u44732 \u45236  \u49688 \u51652  \u51901 \u51004 \u47196  \u45236 \u48128 \u50632 \u49845 \u45768 \u45796 . \u49688 \u51652 \u51008  \u44536 \u44163 \u51012  \u48155 \u50500  \u46308 \u50632 \u49845 \u45768 \u45796 . \u48373 \u44396 \u46108  \u44144 \u47000  \u44592 \u47197 \u51032  \u51068 \u48512 \u50688 \u49845 \u45768 \u45796 . \u49688 \u51652 \u51032  \u49552 \u44032 \u46973 \u51060  \u51333 \u51060  \u45149 \u51012  \u51105 \u51008  \u52292 \u47196  \u50500 \u51452  \u51104 \u44624  \u47688 \u52628 \u50632 \u49845 \u45768 \u45796 .\
"\uc0\u49436 \u50980 \u50472  \u52636 \u51109  \u51068 \u51221 \u51060 \u46993  \u51060  \u44144 \u47000  \u45216 \u51676 \u44032  \u50504  \u47582 \u50500 \u50836 . \u49436 \u50980 \u50472 \u44032  \u51648 \u48169 \u50640  \u51080 \u45912  \u45216  \u49436 \u50872 \u50640 \u49436  \u44208 \u51228 \u44032  \u51060 \u47336 \u50612 \u51652  \u44172  \u48372 \u51060 \u45716 \u45936 ."\
\uc0\u49688 \u51652 \u51008  \u49436 \u47448 \u47484  \u52380 \u52380 \u55176  \u45236 \u47140 \u45796 \u48372 \u45796 \u44032  \u44256 \u44060 \u47484  \u46308 \u50632 \u49845 \u45768 \u45796 . \u47785 \u49548 \u47532 \u45716  \u55124 \u46308 \u47532 \u51648  \u50506 \u50520 \u49845 \u45768 \u45796 .\
"\uc0\u44536  \u48512 \u48516 \u51008  \u51200 \u46020  \u45817 \u49884 \u50640  \u54869 \u51064 \u54664 \u49845 \u45768 \u45796 . \u44208 \u51116  \u44428 \u54620 \u51060  \u44277 \u50976  \u49345 \u53468 \u47196  \u49444 \u51221 \u46104 \u50612  \u51080 \u50612 \u49436 , \u48120 \u47532  \u52376 \u47532 \u47484  \u54644 \u46164  \u44163 \u51004 \u47196  \u54016 \u50640 \u49436  \u54032 \u45800 \u54664 \u49845 \u45768 \u45796 . \u48372 \u44256 \u49436 \u50640 \u46020  \u44536 \u47111 \u44172  \u44592 \u51116 \u54664 \u44256 \u50836 ."\
"\uc0\u54016 \u50640 \u49436  \u54032 \u45800 \u54664 \u45796 \u45716  \u44172  \u45572 \u44032  \u44536 \u47020 \u50612 \u50836 ."\
"\uc0\u45817 \u49884  \u54924 \u44228 \u54016 \u51109 \u51060 \u50632 \u49845 \u45768 \u45796 . \u51060 \u48120  \u53748 \u51649 \u54616 \u49512 \u51648 \u47564 ."\
\uc0\u51221 \u55148 \u45716  \u44256 \u44060 \u47484  \u45124 \u45909 \u50688 \u49845 \u45768 \u45796 . \u47561 \u55192 \u51060  \u50630 \u50632 \u49845 \u45768 \u45796 . \u50612 \u45712  \u51648 \u51216 \u50640 \u49436  \u47932 \u50612 \u46020  \u48712 \u53960 \u51060  \u50630 \u50632 \u49845 \u45768 \u45796 . \u51456 \u48708 \u46108  \u45813 \u51060 \u50632 \u49845 \u45768 \u45796 . \u51221 \u55148 \u45716  \u44536 \u44163 \u51012  \u50508 \u47732 \u49436 \u46020  \u45908  \u44618 \u51060  \u46308 \u50612 \u44032 \u44592 \u47196  \u54664 \u49845 \u45768 \u45796 .\
"\uc0\u49688 \u51652 \u50472 , \u45208 \u45716  \u51648 \u44552  \u49688 \u51652 \u50472 \u47484  \u51032 \u49900 \u54616 \u45716  \u44172  \u50500 \u45768 \u50640 \u50836 . \u45796 \u47564  \u44536  \u49324 \u44148 \u51012  \u45796 \u49884  \u46308 \u50668 \u45796 \u48400 \u50556  \u54624  \u44163  \u44057 \u50500 \u49436  \u54869 \u51064 \u54616 \u45716  \u44144 \u50696 \u50836 ."\
\uc0\u49688 \u51652 \u51032  \u45576 \u51060  \u50500 \u51452  \u51104 \u44624  \u51329 \u50500 \u51276 \u49845 \u45768 \u45796 . \u44536 \u47084 \u45208  \u44552 \u49464  \u46028 \u50500 \u50772 \u49845 \u45768 \u45796 .\
"\uc0\u47924 \u49832  \u51060 \u50976 \u47196  \u45796 \u49884  \u46308 \u50668 \u45796 \u48372 \u49884 \u47140 \u45716  \u44148 \u51648  \u50668 \u52068 \u48400 \u46020  \u46112 \u44620 \u50836 ."\
"\uc0\u49436 \u50980 \u50472 \u54620 \u53580  \u50500 \u51060 \u44032  \u51080 \u50612 \u50836 . \u44536  \u50500 \u51060 \u44032  \u48124 \u51456 \u51060  \u50500 \u51060 \u51068  \u44032 \u45733 \u49457 \u51060  \u45458 \u50500 \u51276 \u44144 \u46304 \u50836 . \u44536 \u47084 \u47732  \u49436 \u50980 \u50472 \u44032  \u50780  \u44536 \u45285  \u45208 \u44052 \u45716 \u51648 \u47484  \u45796 \u49884  \u49373 \u44033 \u54644 \u48400 \u50556  \u54616 \u51648  \u50506 \u44192 \u50612 \u50836 ."\
\uc0\u49688 \u51652 \u51060  \u47568 \u50630 \u51060  \u51221 \u55148 \u47484  \u48148 \u46972 \u48372 \u50520 \u49845 \u45768 \u45796 . \u52840 \u47925 \u51060  \u55128 \u47104 \u49845 \u45768 \u45796 . \u49436 \u47448  \u54028 \u51068 \u51060  \u49688 \u51652 \u51032  \u49552  \u50504 \u50640 \u49436  \u51312 \u44552  \u45580 \u47160 \u49845 \u45768 \u45796 . \u51221 \u55148 \u45716  \u44536  \u49552 \u51012  \u48372 \u50520 \u49845 \u45768 \u45796 . \u54028 \u51068 \u51060  \u44396 \u44200 \u51648 \u44256  \u51080 \u50632 \u49845 \u45768 \u45796 .\
"\uc0\u49436 \u50980 \u50472 \u45716  \u50500 \u51060 \u47484  \u51060 \u50857 \u54644 \u49436  \u45796 \u49884  \u46308 \u50612 \u50724 \u47140 \u45716  \u44152  \u49688 \u46020  \u51080 \u49845 \u45768 \u45796 , \u45824 \u54364 \u45784 ."\
"\uc0\u44536 \u47092  \u49688 \u46020  \u51080 \u51424 . \u44540 \u45936  \u45208 \u45716  \u54869 \u51064 \u54616 \u44256  \u49910 \u50612 \u50836 . 7\u45380  \u51204 \u50640  \u51228 \u45824 \u47196  \u54869 \u51064 \u54664 \u45716 \u51648 \u47484 ."\
\uc0\u49688 \u51652 \u51008  \u45908  \u51060 \u49345  \u47568 \u54616 \u51648  \u50506 \u50520 \u49845 \u45768 \u45796 . \u51077 \u49696 \u51060  \u54620 \u48264  \u50880 \u51649 \u50688 \u45796 \u44032  \u47688 \u52628 \u50632 \u49845 \u45768 \u45796 . \u51221 \u55148 \u45716  \u44536  \u51077 \u49696 \u51032  \u50880 \u51649 \u51076 \u51012  \u45459 \u52824 \u51648  \u50506 \u50520 \u49845 \u45768 \u45796 . \u54624  \u47568 \u51060  \u51080 \u45716 \u45936  \u44732 \u45236 \u51648  \u47803 \u54616 \u45716  \u44163 \u51064 \u51648 , \u50500 \u45768 \u47732  \u44732 \u45236 \u49440  \u50504  \u46104 \u45716  \u47568 \u51060  \u47785  \u50504 \u50640  \u44152 \u47140  \u51080 \u45716  \u44163 \u51064 \u51648 . \u50612 \u45712  \u51901 \u51060 \u46304  \u49688 \u51652 \u51060  \u55124 \u46308 \u47532 \u44256  \u51080 \u45796 \u45716  \u44163 \u47564 \u53372 \u51008  \u48516 \u47749 \u54664 \u49845 \u45768 \u45796 . \u51221 \u55148 \u45716  \u44144 \u44592 \u49436  \u51088 \u47532 \u50640 \u49436  \u51068 \u50612 \u45228 \u49845 \u45768 \u45796 .\
"\uc0\u46096 \u50612 \u50836 , \u45208 \u44032 \u48400 \u50836 . \u49373 \u44033 \u54644 \u48380  \u44172  \u51080 \u50612 \u49436 ."\
\uc0\u49688 \u51652 \u51060  \u49548 \u54028 \u50640 \u49436  \u51068 \u50612 \u45208  \u47928  \u51901 \u51004 \u47196  \u44152 \u50612 \u44052 \u49845 \u45768 \u45796 . \u47928 \u49552 \u51105 \u51060 \u47484  \u51105 \u51004 \u47732 \u49436  \u51104 \u44624  \u46321 \u51060  \u44403 \u50612 \u51648 \u45716  \u44163 \u51060  \u48372 \u50688 \u49845 \u45768 \u45796 . \u54616 \u51648 \u47564  \u46244 \u46028 \u50500 \u48372 \u51648  \u50506 \u44256  \u45208 \u44052 \u49845 \u45768 \u45796 . \u47928 \u51060  \u45803 \u54804 \u49845 \u45768 \u45796 .\
\uc0\u51221 \u55148 \u45716  \u49688 \u51652 \u51060  \u45208 \u44036  \u47928 \u51012  \u48148 \u46972 \u48372 \u50520 \u49845 \u45768 \u45796 . \u55124 \u46308 \u47532 \u44596  \u54664 \u49845 \u45768 \u45796 . \u45576  \u54620 \u51901 \u51060  \u51329 \u50500 \u51276 \u44256 , \u49552 \u51060  \u54028 \u51068 \u51012  \u51312 \u44552  \u45908  \u45580 \u47104 \u49845 \u45768 \u45796 . \u51221 \u55148 \u45716  \u52293 \u49345 \u51004 \u47196  \u46028 \u50500 \u50752  \u51089 \u51008  \u47532 \u47784 \u52968 \u51012  \u51312 \u50857 \u55176  \u51665 \u50612  \u46308 \u50632 \u49845 \u45768 \u45796 . \u45824 \u54364 \u49892  \u52380 \u51109  \u54620 \u51901 \u50640  \u49444 \u52824 \u46108  \u49548 \u54805  \u45433 \u51020  \u51109 \u52824 \u51032  \u51204 \u50896 \u51012  \u53020 \u46164  \u52292 \u47196  \u49688 \u51652 \u51012  \u46308 \u50668 \u48372 \u45240  \u44163 \u51060 \u50632 \u49845 \u45768 \u45796 . \u51060 \u48120  \u51060  \u45824 \u54868 \u45716  \u45433 \u51020 \u46104 \u50612  \u51080 \u50632 \u49845 \u45768 \u45796 . \u49688 \u51652 \u51032  \u47561 \u55192 \u50630 \u45716  \u45813 \u48320 \u46308 , \u54028 \u51068 \u51012  \u51536 \u45716  \u49552 \u51032  \u55192 , \u51077 \u49696 \u51060  \u50880 \u51649 \u50688 \u45796  \u47688 \u52628 \u45716  \u44536  \u49692 \u44036 \u44620 \u51648 . \u51221 \u55148 \u45716  \u45433 \u51020  \u54028 \u51068 \u51012  \u51200 \u51109 \u54616 \u44256  \u52293 \u49345  \u49436 \u46989  \u50504 \u50640  \u45347 \u50632 \u49845 \u45768 \u45796 .\
\uc0\u44536 \u47088 \u45936  \u45908  \u54596 \u50836 \u54664 \u49845 \u45768 \u45796 . \u51060  \u51221 \u46020 \u47196 \u45716  \u48512 \u51313 \u54664 \u49845 \u45768 \u45796 . \u49688 \u51652 \u51060  \u45824 \u54364 \u49892  \u48150 \u50640 \u49436  \u50612 \u46523 \u44172  \u50880 \u51649 \u51060 \u45716 \u51648 \u44032  \u45908  \u51473 \u50836 \u54664 \u49845 \u45768 \u45796 . \u51648 \u44552  \u49688 \u51652 \u51060  \u50612 \u46360 \u44032 \u47196  \u50672 \u46973 \u54624  \u44163 \u51060 \u50632 \u49845 \u45768 \u45796 . \u51060  \u45824 \u54868 \u44032  \u50620 \u47560 \u45208  \u50948 \u54744 \u54620 \u51648  \u51204 \u45804 \u54616 \u47140  \u54624  \u44163 \u51060 \u50632 \u49845 \u45768 \u45796 . \u44536  \u53685 \u54868  \u50504 \u50640  \u51652 \u51676 \u44032  \u51080 \u51012  \u44163 \u51060 \u50632 \u49845 \u45768 \u45796 .\
\uc0\u48373 \u46020 \u47196  \u45208 \u50728  \u49688 \u51652 \u51008  \u54868 \u51109 \u49892 \u47196  \u46308 \u50612 \u44052 \u49845 \u45768 \u45796 . \u44144 \u50872  \u50526 \u50640  \u49436 \u49436  \u49552 \u51012  \u50491 \u45716  \u52377 \u54616 \u47728  \u54648 \u46300 \u54256 \u51012  \u44732 \u45256 \u49845 \u45768 \u45796 . \u51204 \u54868 \u47484  \u44152 \u50632 \u49845 \u45768 \u45796 . \u49888 \u54840 \u44032  \u46160  \u48264  \u50872 \u47532 \u44256  \u49345 \u45824 \u44032  \u48155 \u50520 \u49845 \u45768 \u45796 . \u49688 \u51652 \u51032  \u47785 \u49548 \u47532 \u44032  \u45230 \u50500 \u51276 \u49845 \u45768 \u45796 .\
"\uc0\u45208 \u50556 . \u51648 \u44552  \u45824 \u54364 \u45784 \u51060  7\u45380  \u51204  \u44144  \u45796 \u49884  \u46308 \u50668 \u45796 \u48376 \u45824 . \u49436 \u48260  \u48373 \u44396 \u46020  \u46308 \u50612 \u44036  \u44163  \u44057 \u44256 . \u50880 \u51649 \u50668 \u50556  \u54624  \u44163  \u44057 \u50500 ."\
\uc0\u49345 \u45824 \u48169 \u51060  \u47956 \u44032 \u47484  \u47568 \u54616 \u45716  \u46041 \u50504  \u49688 \u51652 \u51008  \u44144 \u50872 \u51012  \u48148 \u46972 \u48372 \u47728  \u46307 \u44256  \u51080 \u50632 \u49845 \u45768 \u45796 . \u49688 \u51652 \u51032  \u54364 \u51221 \u51060  \u44403 \u50612 \u51276 \u45796  \u54400 \u47160 \u45796  \u54664 \u49845 \u45768 \u45796 . \u49552 \u51060  \u49464 \u47732 \u45824  \u50948 \u47484  \u51105 \u50520 \u49845 \u45768 \u45796 .\
"\uc0\u47728 \u45712 \u47532  \u51923 \u50500 \u45236 \u47140 \u44256  \u47564 \u46304  \u51068 \u51064 \u45936  \u50780  \u51060 \u51228  \u50752 \u49436  \u47928 \u51228 \u44032  \u46076 . \u50612 \u52264 \u54588  7\u45380 \u51060 \u45208  \u51648 \u45212  \u51068 \u51060 \u51094 \u50500 ."\
\uc0\u48201 \u51008  \u47568 \u51060  \u54868 \u51109 \u49892  \u53440 \u51068  \u48317 \u50640  \u48512 \u46378 \u54784  \u46028 \u50500 \u50772 \u49845 \u45768 \u45796 . \u49688 \u51652 \u51008  \u51088 \u49888 \u51060  \u54620  \u47568 \u51012  \u46308 \u51004 \u47732 \u49436 \u46020  \u54648 \u46300 \u54256 \u51012  \u44480 \u50640 \u49436  \u46524 \u51648  \u50506 \u50520 \u49845 \u45768 \u45796 . \u49345 \u45824 \u44032  \u46608  \u47956 \u44032 \u47484  \u47568 \u54664 \u44256 , \u49688 \u51652 \u51008  \u51687 \u44172  \u45824 \u45813 \u54664 \u49845 \u45768 \u45796 .\
"\uc0\u50508 \u50520 \u50612 , \u50672 \u46973  \u44592 \u45796 \u47140 ."\
\uc0\u53685 \u54868 \u47484  \u45130 \u44256  \u54648 \u46300 \u54256 \u51012  \u51452 \u47672 \u45768 \u50640  \u45347 \u50632 \u49845 \u45768 \u45796 . \u44144 \u50872 \u51012  \u45796 \u49884  \u48372 \u50520 \u49845 \u45768 \u45796 . \u50620 \u44404 \u51060  \u50500 \u44620 \u48372 \u45796  \u45908  \u52285 \u48177 \u54664 \u49845 \u45768 \u45796 . \u49552 \u51012  \u47568 \u47532 \u44256 , \u49704 \u51012  \u44256 \u47476 \u44256 , \u54868 \u51109 \u49892  \u47928 \u51012  \u50676 \u50632 \u49845 \u45768 \u45796 .\
\uc0\u44536 \u47088 \u45936  \u48373 \u46020  \u45149 \u50640  \u51221 \u55148 \u44032  \u49436  \u51080 \u50632 \u49845 \u45768 \u45796 .\
\uc0\u49688 \u51652 \u51032  \u48156 \u51060  \u44403 \u50632 \u49845 \u45768 \u45796 . \u51221 \u55148 \u45716  \u50500 \u47924  \u47568 \u46020  \u54616 \u51648  \u50506 \u50520 \u49845 \u45768 \u45796 . \u44536 \u45285  \u49688 \u51652 \u51012  \u48148 \u46972 \u48372 \u44256  \u51080 \u50632 \u49845 \u45768 \u45796 . \u46160  \u49324 \u46988  \u49324 \u51060 \u51032  \u44144 \u47532 \u44032  \u47680 \u50612 \u49436  \u54868 \u51109 \u49892  \u50504 \u51032  \u49548 \u47532 \u44032  \u46308 \u47160 \u51012  \u47532  \u50630 \u50632 \u49845 \u45768 \u45796 . \u54616 \u51648 \u47564  \u44536  \u45576 \u48731 \u51060  \u47924 \u50616 \u44032 \u47484  \u50508 \u44256  \u51080 \u45716  \u49324 \u46988 \u51032  \u45576 \u51060 \u50632 \u49845 \u45768 \u45796 . \u51221 \u54869 \u55176 \u45716  \u50508 \u44256  \u51080 \u45716  \u44163 \u51012  \u54869 \u51064 \u54620  \u49324 \u46988 \u51032  \u45576 \u51060 \u50632 \u49845 \u45768 \u45796 . \u49688 \u51652 \u51008  \u51088 \u50672 \u49828 \u47101 \u44172  \u44152 \u50612 \u44032 \u47140  \u54664 \u51648 \u47564  \u45796 \u47532 \u44032  \u51096  \u50880 \u51649 \u51060 \u51648  \u50506 \u50520 \u49845 \u45768 \u45796 .\
"\uc0\u49688 \u51652 \u50472 ."\
\uc0\u51221 \u55148 \u44032  \u51312 \u50857 \u55176  \u48520 \u47104 \u49845 \u45768 \u45796 .\
\uc0\u49688 \u51652 \u51060  \u47688 \u52628 \u50632 \u49845 \u45768 \u45796 .\
"\uc0\u50724 \u45720  \u50724 \u54980 \u50640  \u48124 \u51456 \u51060 \u54620 \u53580  \u51204 \u54868 \u54664 \u50612 \u50836 . \u45433 \u52712  \u54028 \u51068  \u48155 \u45716  \u45824 \u47196  \u44057 \u51060  \u46307 \u51088 \u44256 ."\
\uc0\u49688 \u51652 \u51032  \u50620 \u44404 \u50640 \u49436  \u54607 \u44592 \u44032  \u44032 \u49512 \u49845 \u45768 \u45796 . \u47924 \u49832  \u45433 \u52712 \u51064 \u51648  \u47931 \u51648  \u50506 \u50520 \u49845 \u45768 \u45796 . \u47932 \u51012  \u49688  \u50630 \u50632 \u49845 \u45768 \u45796 . \u51221 \u55148 \u45716  \u44536 \u44163 \u51012  \u48372 \u47732 \u49436  \u51312 \u50857 \u55176  \u44256 \u44060 \u47484  \u45124 \u45909 \u50688 \u49845 \u45768 \u45796 . \u47931 \u51648  \u50506 \u45716 \u45796 \u45716  \u44163  \u51088 \u52404 \u44032  \u51060 \u48120  \u45813 \u51060 \u50632 \u49845 \u45768 \u45796 . \u50500 \u47924 \u44163 \u46020  \u47784 \u47476 \u45716  \u49324 \u46988 \u51060 \u46972 \u47732  \u50612 \u46500  \u45433 \u52712 \u45264 \u44256  \u47932 \u50632 \u51012  \u44163 \u51060 \u50632 \u49845 \u45768 \u45796 . \u49688 \u51652 \u51008  \u47931 \u51648  \u50506 \u50520 \u49845 \u45768 \u45796 .\
"\uc0\u45208 \u44032 \u48400 \u50836 ."\
\uc0\u49688 \u51652 \u51060  \u44256 \u44060 \u47484  \u49689 \u51060 \u44256  \u46028 \u50500 \u49456 \u49845 \u45768 \u45796 . \u48373 \u46020 \u47484  \u44152 \u50612 \u44032 \u45716  \u44536  \u46263 \u47784 \u49845 \u51060  \u54217 \u49548 \u48372 \u45796  \u51312 \u44552  \u51089 \u50500  \u48372 \u50688 \u49845 \u45768 \u45796 . \u50612 \u44648 \u44032  \u45236 \u47140 \u44032  \u51080 \u50632 \u44256 , \u44152 \u51020 \u51060  \u54217 \u49548 \u51032  \u44536  \u45800 \u51221 \u54620  \u47532 \u46316 \u51012  \u51075 \u50632 \u49845 \u45768 \u45796 . \u51221 \u55148 \u45716  \u44536  \u46263 \u47784 \u49845 \u51060  \u50648 \u47532 \u48288 \u51060 \u53552  \u50504 \u51004 \u47196  \u49324 \u46972 \u51656  \u46412 \u44620 \u51648  \u48148 \u46972 \u48372 \u45796 \u44032 , \u54648 \u46300 \u54256 \u51012  \u44732 \u45256 \u49845 \u45768 \u45796 . \u50808 \u48512  \u51312 \u49324 \u54016 \u50640  \u47928 \u51088 \u47484  \u48372 \u45256 \u49845 \u45768 \u45796 . \u53685 \u54868  \u45433 \u52712 , \u48736 \u47476 \u44172  \u54869 \u48372 \u54644 \u50836 .\
\uc0\u44536 \u45216  \u51200 \u45377 , \u51221 \u55148 \u45716  \u50500 \u46308 \u50640 \u44172  \u51204 \u54868 \u47484  \u44152 \u50632 \u49845 \u45768 \u45796 . \u48124 \u51456 \u51008  \u46160  \u48264 \u51704  \u49888 \u54840 \u50640  \u48155 \u50520 \u49845 \u45768 \u45796 .\
"\uc0\u54028 \u51068  \u54616 \u45208  \u48372 \u45244  \u44144 \u50556 . \u46307 \u44592  \u55192 \u46308  \u49688 \u46020  \u51080 \u50612 . \u44536 \u47000 \u46020  \u46308 \u50612 \u50556  \u54644 ."\
\uc0\u51204 \u54868 \u44592  \u45320 \u47672 \u50640 \u49436  \u48124 \u51456 \u51060  \u51104 \u49884  \u51312 \u50857 \u54664 \u49845 \u45768 \u45796 .\
"\uc0\u50612 \u46500  \u54028 \u51068 \u51060 \u50640 \u50836 ."\
"\uc0\u49688 \u51652 \u50472  \u47785 \u49548 \u47532 \u44032  \u46308 \u50612 \u51080 \u50612 . 7\u45380  \u51204  \u51068 \u50640  \u45824 \u54644 \u49436 ."\
\uc0\u44596  \u52840 \u47925 \u51060  \u55128 \u47104 \u49845 \u45768 \u45796 . \u48124 \u51456 \u51060  \u45230 \u44172  \u47568 \u54664 \u49845 \u45768 \u45796 .\
"\uc0\u48372 \u45236 \u51452 \u49464 \u50836 ."\
\uc0\u51221 \u55148 \u45716  \u54028 \u51068 \u51012  \u51204 \u49569 \u54664 \u49845 \u45768 \u45796 . \u51204 \u54868 \u47484  \u45130 \u44256  \u45208 \u49436  \u52285 \u48150 \u51012  \u48148 \u46972 \u48372 \u50520 \u49845 \u45768 \u45796 . \u50500 \u46308 \u51060  \u44536  \u45433 \u52712 \u47484  \u46307 \u44256  \u45208 \u47732  \u47924 \u45320 \u51656  \u44163 \u51060 \u50632 \u49845 \u45768 \u45796 . \u44536 \u44172  \u46160 \u47140 \u50912 \u49845 \u45768 \u45796 . \u54616 \u51648 \u47564  \u50508 \u50500 \u50556  \u54664 \u49845 \u45768 \u45796 . \u47784 \u47480  \u52292 \u47196  \u50526 \u51004 \u47196  \u45208 \u50500 \u44040  \u49688 \u45716  \u50630 \u50632 \u49845 \u45768 \u45796 . \u51221 \u55148 \u45716  \u54648 \u46300 \u54256 \u51012  \u52293 \u49345  \u50948 \u50640  \u45236 \u47140 \u45459 \u51004 \u47728  \u45576 \u51012  \u44048 \u50520 \u49845 \u45768 \u45796 . \u51060 \u51228  \u44144 \u51032  \u45796  \u50772 \u49845 \u45768 \u45796 . \u47560 \u51648 \u47561  \u54620  \u44152 \u51020 \u51060  \u45224 \u50500  \u51080 \u50632 \u49845 \u45768 \u45796 .\
\uc0\u49436 \u50872  \u50612 \u46360 \u44032 \u50640 \u49436  \u48124 \u51456 \u51008  \u54028 \u51068 \u51012  \u48155 \u44256  \u50676 \u50632 \u49845 \u45768 \u45796 . \u51116 \u49373  \u48260 \u53948  \u50948 \u50640  \u49552 \u44032 \u46973 \u51012  \u50732 \u47140 \u46160 \u44256  \u54620 \u52280  \u46041 \u50504  \u45572 \u47476 \u51648  \u50506 \u50520 \u49845 \u45768 \u45796 . \u51061 \u49689 \u54620  \u47785 \u49548 \u47532 \u44032  \u55128 \u47084 \u45208 \u50732  \u44163 \u51012  \u50508 \u50520 \u49845 \u45768 \u45796 . \u49688 \u51652 \u51032  \u47785 \u49548 \u47532 \u47484 . \u44536 \u47532 \u44256  \u44536  \u47785 \u49548 \u47532 \u44032  \u47568 \u54624  \u44163 \u46308 \u51012 . 7\u45380  \u51204 , \u51088 \u49888 \u51032  \u50500 \u45236 \u50640 \u44172  \u47924 \u49832  \u51068 \u51060  \u51080 \u50632 \u45716 \u51648 \u47484 . \u48124 \u51456 \u51008  \u45576 \u51012  \u44048 \u50520 \u45796 \u44032  \u46888 \u47728  \u51116 \u49373  \u48260 \u53948 \u51012  \u45580 \u47104 \u49845 \u45768 \u45796 .\
