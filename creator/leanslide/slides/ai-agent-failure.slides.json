  "subtitles": {
    "words": [],
    "sentences": [
      { "text": "올해 기업 앱의 40%가 AI 에이전트를 품을 거라고 합니다", "startMs": 0, "endMs": 5000 },
      { "text": "그런데 동시에 AI 에이전트 프로젝트의 80에서 90%는 실패합니다", "startMs": 5340, "endMs": 10420 },
      { "text": "이 두 숫자가 동시에 존재하는 상황 뭔가 이상하지 않습니까", "startMs": 10720, "endMs": 14380 },

      { "text": "에이전트를 한마디로 하면 스스로 판단하고 행동하는 AI입니다", "startMs": 15850, "endMs": 19500 },
      { "text": "챗지피티한테 이거 알려줘라고 묻는 건 챗봇이고", "startMs": 20000, "endMs": 24000 },
      { "text": "이 업무를 처음부터 끝까지 처리해줘라고 맡기는 게 에이전트입니다", "startMs": 24200, "endMs": 28500 },
      { "text": "챗봇은 콜센터 상담원 에이전트는 신입 직원이에요", "startMs": 28700, "endMs": 31500 },
      { "text": "업무를 주면 알아서 단계를 나누고 도구를 찾아 쓰고 결과를 가져옵니다", "startMs": 31700, "endMs": 36000 },

      { "text": "에이전트라는 개념은 새로운 게 아닙니다", "startMs": 37950, "endMs": 40750 },
      { "text": "왜 하필 2026년에 폭발하느냐", "startMs": 41270, "endMs": 44250 },
      { "text": "세 가지가 동시에 맞아떨어졌기 때문입니다", "startMs": 44250, "endMs": 47270 },
      { "text": "첫째 모델 성능이 임계점을 넘었습니다", "startMs": 47270, "endMs": 50390 },
      { "text": "둘째 MCP 같은 표준 프로토콜이 생겼습니다", "startMs": 50390, "endMs": 53750 },
      { "text": "파이어쉽이 이걸 AI의 USB-C라고 비유했는데 단자가 하나로 통일된 거예요", "startMs": 53750, "endMs": 59070 },
      { "text": "셋째 멀티 에이전트 시스템에 대한 기업 문의가 1445% 급증했습니다", "startMs": 59070, "endMs": 64370 },

      { "text": "여기서 냉정하게 볼 게 있습니다", "startMs": 65750, "endMs": 68230 },
      { "text": "에이전트라고 마케팅하는 것들 대부분이 그냥 챗봇에 자동화를 씌운 것이라는 겁니다", "startMs": 68530, "endMs": 75530 },
      { "text": "이커머스에서 에이전트 도입했다는 프로젝트 대부분이 챗봇이 주문 상태를 읽어주는 수준이었습니다", "startMs": 75750, "endMs": 84190 },
      { "text": "자동화에 AI 라벨을 붙인 거지 스스로 판단하는 구조는 아닌 거예요", "startMs": 84190, "endMs": 90730 },

      { "text": "진짜 중요한 건 에이전트를 쓰느냐 마느냐가 아니라 어떤 구조로 쓰느냐입니다", "startMs": 91530, "endMs": 97070 },
      { "text": "코딩 에이전트 시장만 봐도 클로드코드 커서 데빈이 각각 다른 포지션을 잡고 있습니다", "startMs": 97070, "endMs": 102950 },
      { "text": "그런데 도구가 좋아도 브리프가 엉망이면 결과도 엉망입니다", "startMs": 102950, "endMs": 106470 },
      { "text": "에이전트한테 주는 지시에 목적과 조건과 판단 기준이 없으면 그냥 비싼 자동완성이 됩니다", "startMs": 106470, "endMs": 111390 },

      { "text": "오늘 하나만 해보시죠", "startMs": 112880, "endMs": 115000 },
      { "text": "지금 반복하고 있는 업무 하나를 골라서 이 세 가지를 적어보세요", "startMs": 115200, "endMs": 118920 },
      { "text": "이 일의 목적이 뭔지 판단 기준이 뭔지 끝난 상태가 어떤 건지", "startMs": 119420, "endMs": 125000 },
      { "text": "이게 결국 브리프입니다 AI한테도 이 구조를 주면 일관된 결과가 나옵니다", "startMs": 125200, "endMs": 129160 },
      { "text": "지금은 이 구조를 주면 30분이면 결과를 봅니다 구조가 먼저예요", "startMs": 129420, "endMs": 135900 },

      { "text": "정리하겠습니다", "startMs": 137230, "endMs": 138500 },
      { "text": "2026년 AI 에이전트는 진짜 폭발합니다", "startMs": 138700, "endMs": 142410 },
      { "text": "그런데 90%는 실패할 겁니다", "startMs": 142790, "endMs": 144810 },
      { "text": "차이를 만드는 건 도구가 아니라 설계입니다", "startMs": 145050, "endMs": 147430 },
      { "text": "처음 AI로 만든 건 보기엔 그럴듯했는데 쓸 수가 없었어요", "startMs": 147970, "endMs": 151750 },
      { "text": "기획 없이 시작한 거였거든요 그때 배운 겁니다", "startMs": 152110, "endMs": 155250 },
      { "text": "코드를 모르니까 오히려 구조에 집중하게 됩니다", "startMs": 155830, "endMs": 158370 },
      { "text": "다음 영상에서는 실제로 에이전트를 설계하는 과정을 보여드리겠습니다", "startMs": 158950, "endMs": 163190 },
      { "text": "구독해두시면 놓치지 않습니다", "startMs": 163650, "endMs": 165190 }
    ]
  }
